{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "apply-migrations",
			"type": "shell",
			"command": "powershell -ExecutionPolicy Bypass -File \"scripts/apply-migrations.ps1\"",
			"isBackground": false
		},
		{
			"label": "db-connect-check-6543",
			"type": "shell",
			"command": "node",
			"args": [
				"-e",
				"const net=require('net'); const s=net.connect(6543,'aws-0-us-west-2.pooler.supabase.com',()=>{console.log('connected'); s.end();}); s.on('error',e=>{console.error(String(e)); process.exit(1);});"
			],
			"isBackground": false
		},
		{
			"label": "db-connect-check-5432",
			"type": "shell",
			"command": "node",
			"args": [
				"-e",
				"const net=require(\"net\"); const s=net.connect(5432,\"aws-0-us-west-2.pooler.supabase.com\",()=>{console.log(\"connected\"); s.end();}); s.on(\"error\",e=>{console.error(String(e)); process.exit(1);});"
			],
			"isBackground": false
		},
		{
			"label": "baseline-migrations",
			"type": "shell",
			"command": "npm run db:migrate:baseline",
			"isBackground": false
		},
		{
			"label": "test-prompt2",
			"type": "shell",
			"command": "npm run test:prompt2",
			"isBackground": false
		}
	]
