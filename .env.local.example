# Copy to `.env.local` for local development (do not commit secrets).
# Mirror these in Vercel → Project → Settings → Environment Variables.

# --- Start/Sit + Chimmy mini-route (`/api/start-sit/chimmy`) ---
OPENAI_API_KEY=
# Optional override (defaults to OPENAI_API_KEY)
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=
START_SIT_CHIMMY_MODEL=gpt-4o-mini

# --- Core sports data cascade (Rolling Insights → API-Sports → ClearSports → …) ---
ROLLING_INSIGHTS_CLIENT_ID=
ROLLING_INSIGHTS_CLIENT_SECRET=
API_SPORTS_KEY=
CLEAR_SPORTS_API_KEY=

# --- News / injury enrichment ---
NEWS_API_KEY=
NEWSAPI_KEY=

# --- Optional: Grok / X.AI ---
XAI_API_KEY=
GROK_API_KEY=
XAI_MODEL=grok-2-latest
