CFBD_KEY=""

# Yahoo OAuth
YAHOO_CLIENT_ID=""
YAHOO_CLIENT_SECRET=""
YAHOO_REDIRECT_URI="http://localhost:3000/api/league/yahoo/callback"

# League auth encryption (required for encrypted external credentials)
LEAGUE_AUTH_ENCRYPTION_KEY="replace-with-32+-char-secret"
LEAGUE_CRON_SECRET=""
AI_ADP_CRON_SECRET=""
AI_ADP_DAILY_CRON_UTC="0 6 * * *"
AI_ADP_LOOKBACK_DAYS="120"
AI_ADP_LOW_SAMPLE_THRESHOLD="5"
AI_ADP_MIN_SAMPLE_SIZE="2"

# Redis / queues (optional unless queue features enabled)
REDIS_URL=""
REDIS_HOST=""
REDIS_PORT="6379"

# Email / SMS / Billing
RESEND_API_KEY=""
RESEND_FROM="AllFantasy.ai <noreply@allfantasy.ai>"
RESEND_FROM_EMAIL="AllFantasy <no-reply@allfantasy.ai>"

# Twilio supports either mode:
# 1) Account SID + Auth Token, or
# 2) Account SID + API Key + API Secret
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_API_KEY=""
TWILIO_API_SECRET=""
TWILIO_PHONE_NUMBER=""
TWILIO_VERIFY_SERVICE_SID=""

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Optional commerce / analytics
COINBASE_COMMERCE_API_KEY=""
COINBASE_API_KEY=""
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""

META_CONVERSIONS_API_TOKEN=""
META_PIXEL_ID=""
META_TEST_EVENT_CODE=""
NEXT_PUBLIC_META_PIXEL_ID=""
NEXT_PUBLIC_FB_APP_ID=""
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Social auth toggles for frontend buttons
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH="false"
NEXT_PUBLIC_ENABLE_APPLE_AUTH="false"

# Dev-only switches
DEV_SIM_TOKEN=""
BRACKET_DEV_SECRET=""
NEXT_PUBLIC_BRACKET_DEV_SECRET=""
BRACKET_ADMIN_SECRET=""
BRACKET_CRON_SECRET=""
EARLY_ACCESS_CONFIRM_SECRET=""
EARLY_ACCESS_SYNC_SECRET=""
EARLY_ACCESS_SYNC_ALLOWED_ORIGINS=""
