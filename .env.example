# Core
NODE_ENV=development
DATABASE_URL="postgresql://user:password@host:5432/database"
DIRECT_URL="postgresql://user:password@host:5432/database"

# Auth / Sessions
NEXTAUTH_SECRET="replace-with-secure-random"
NEXTAUTH_URL="http://localhost:3000"
SESSION_SECRET="replace-with-secure-random"
ADMIN_SESSION_SECRET="replace-with-secure-random"
ADMIN_PASSWORD="replace-with-strong-password"
ADMIN_PASSWORD_HASH=""
ADMIN_EMAILS=""

# App URLs
APP_URL="http://localhost:3000"
# For scripts (smoke tests, QA, stress tests): base URL of running app (default 3000)
BASE_URL="http://localhost:3000"
PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenAI (canonical: OPENAI_API_KEY)
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o"
# Legacy / integration alias
AI_INTEGRATIONS_OPENAI_API_KEY=""
AI_INTEGRATIONS_OPENAI_BASE_URL="https://api.openai.com/v1"

# Openclaw Dev Assistant (server-side only)
OPENCLAW_WEBUI_URL="https://webui.clawship.ai/allfantasy-dev-assistant/"
OPENCLAW_GATEWAY_URL="wss://webui.clawship.ai/allfantasy-dev-assistant/ws"
OPENCLAW_TOKEN=""
# Openclaw Growth / Marketing Assistant (server-side only)
OPENCLAW_GROWTH_WEBUI_URL="https://webui.clawship.ai/allfantasy-growth-marketing-assistant/"
OPENCLAW_GROWTH_GATEWAY_URL="wss://webui.clawship.ai/allfantasy-growth-marketing-assistant/ws"
OPENCLAW_GROWTH_TOKEN=""
# Optional comma-separated host allowlist for OPENCLAW_WEBUI_URL / OPENCLAW_GATEWAY_URL
OPENCLAW_ALLOWED_HOSTS="webui.clawship.ai"

# DeepSeek (canonical: DEEPSEEK_API_KEY)
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"

# DeepL translation fallback (server-side only; optional)
DEEPL_API_KEY=""
DEEPL_API_BASE_URL="https://api-free.deepl.com"

# xAI / Grok (canonical: XAI_API_KEY)
XAI_API_KEY=""
XAI_MODEL="grok-2-latest"
XAI_BASE_URL="https://api.x.ai/v1"
# Legacy
GROK_API_KEY=""
GROK_MODEL="grok-4-0709"
GROK_BASE_URL="https://api.x.ai/v1"
GROK_TIMEOUT_MS="12000"
GROK_ENRICH_ENABLED="false"
GROK_ENRICH_MAX="8"
GROK_ENRICH_CONCURRENCY="3"
GROK_ENRICH_WAIVERS_ENABLED="false"
GROK_ENRICH_WAIVERS_MAX="10"
GROK_ENRICH_WAIVERS_CONCURRENCY="3"

# ClearSports (canonical: CLEARSPORTS_API_KEY + CLEARSPORTS_API_BASE)
CLEARSPORTS_API_KEY=""
CLEARSPORTS_API_BASE=""
# Optional: timeout (ms), retries, rate limit per minute (PROMPT 153)
# CLEARSPORTS_TIMEOUT_MS=15000
# CLEARSPORTS_MAX_RETRIES=2
# CLEARSPORTS_RATE_LIMIT_PER_MINUTE=60
# Optional: feature gates + health probe (PROMPT 153)
# CLEARSPORTS_PROJECTIONS_ENABLED=false
# CLEARSPORTS_NEWS_ALERTS_ENABLED=false
# Legacy
CLEAR_SPORTS_API_KEY=""
CLEAR_SPORTS_API_BASE=""

# AI Orchestration (optional; defaults used if unset)
# AI_ORCHESTRATION_TIMEOUT_MS=25000
# AI_ORCHESTRATION_RETRY_COUNT=1
# AI_PROVIDER_HEALTHCHECK_TIMEOUT_MS=2500
# AI_FALLBACK_MIN_PROVIDERS=1
# AI_QUALITY_GATE_STRICT_REJECT=false
# AI_QUALITY_GATE_MAX_WARNINGS=2

# News / Search / Weather
NEWSAPI_KEY=""
NEWS_API_KEY=""
SERPER_API_KEY=""
OPENWEATHERMAP_API_KEY=""

# Sports data providers
ROLLING_INSIGHTS_CLIENT_ID=""
ROLLING_INSIGHTS_CLIENT_SECRET=""
API_SPORTS_KEY=""
THESPORTSDB_API_KEY=""
THESPORTSDB_NCAAM_LEAGUE_ID="4607"
THESPORTSDB_NCAAF_LEAGUE_ID=""
THESPORTSDB_SOCCER_LEAGUE_ID=""
