{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "ignoreDeprecations": "5.0",
    "forceConsistentCasingInFileNames": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "app/**/*.d.ts",
    "types/**/*.d.ts",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "components/**/*.jsx",
    "app/**/*.ts",
    "app/**/*.tsx",
    "middleware.ts",
    "instrumentation.ts",
    "pages/**/*.ts",
    "pages/**/*.tsx",
    ".next/types/**/*.ts",
    ".next-dev-local/types/**/*.ts",
    ".next-playwright-3101/types/**/*.ts",
    ".next-dev-triage/types/**/*.ts",
    ".next-dev-3101/types/**/*.ts",
    ".next-dev-local-smoke/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "scripts",
    "e2e",
    "app/e2e",
    "tests",
    "__tests__",
    "**/e2e/**",
    "**/tests/**",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "playwright-report",
    "test-results"
  ]
}
