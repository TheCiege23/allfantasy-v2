enum VerificationMethod {
  EMAIL
  PHONE
}

model UserProfile {
  userId                    String              @id
  displayName               String?
  phone                     String?             @unique
  phoneVerifiedAt           DateTime?
  emailVerifiedAt           DateTime?
  ageConfirmedAt            DateTime?
  verificationMethod        VerificationMethod?
  sleeperUsername           String?
  sleeperUserId             String?             @unique
  sleeperLinkedAt           DateTime?
  sleeperVerifiedAt         DateTime?
  profileComplete           Boolean             @default(false)
  timezone                  String?
  preferredLanguage         String?
  themePreference           String? // "dark" | "light" | "legacy"
  avatarPreset              String?
  bio                       String?             @db.Text
  preferredSports           Json? // string[] e.g. ["NFL","NBA"]
  notificationPreferences   Json? // NotificationPreferences shape
  /// Aggregated scoring/league context after imports — feeds rankings / AI personalization.
  rankingsContext           Json?
  onboardingStep            String? // welcome | app_walkthrough | sport_selection | tool_suggestions | league_prompt | completed
  onboardingCompletedAt     DateTime?
  /// PROMPT 149: Dismissed retention nudge IDs -> ISO date, e.g. { "return_nudge_1": "2025-03-14T..." }
  retentionNudgeDismissedAt Json?
  /// Discord OAuth (Tier 1) — optional guild from bot install flow (Tier 2).
  discordUserId             String?             @unique
  discordUsername           String?
  discordEmail              String?
  discordAvatar             String?
  discordAccessToken        String?             @db.Text
  discordRefreshToken       String?             @db.Text
  discordConnectedAt        DateTime?
  discordGuildId            String?

  /// AF Commissioner subscription — unlocks premium league AI / playoff options.
  afCommissionerSub Boolean @default(false)
  /// Denormalized from userSubscription (System B) for legacy gates and quick checks.
  afProSub          Boolean @default(false)
  /// Denormalized from userSubscription (System B) for legacy gates and quick checks.
  afWarRoomSub      Boolean @default(false)

  /// Master switch: when false, AutoCoach does not run for any league (per-league prefs preserved).
  autoCoachGlobalEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sleeperUsername])
  @@index([phone])
  @@map("user_profiles")
}

/// Discord server linked by a commissioner (Tier 2 prep).
model DiscordGuildLink {
  id             String                 @id @default(cuid())
  guildId        String                 @unique
  guildName      String?
  linkedByUserId String
  user           AppUser                @relation(fields: [linkedByUserId], references: [id], onDelete: Cascade)
  leagueChannels DiscordLeagueChannel[]
  createdAt      DateTime               @default(now())

  @@index([linkedByUserId])
  @@map("discord_guild_links")
}

/// Maps an AllFantasy league to a Discord channel for chat sync.
model DiscordLeagueChannel {
  id                  String           @id @default(cuid())
  leagueId            String
  league              League           @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  guildId             String
  channelId           String           @unique
  channelName         String?
  webhookId           String?
  webhookToken        String?          @db.Text
  lastSyncedMessageId String?
  syncEnabled         Boolean          @default(true)
  syncOutbound        Boolean          @default(true)
  syncInbound         Boolean          @default(false)
  guild               DiscordGuildLink @relation(fields: [guildId], references: [guildId])
  createdAt           DateTime         @default(now())

  @@unique([leagueId, guildId])
  @@index([leagueId])
  @@index([guildId])
  @@map("discord_league_channels")
}

/// Dedup + audit for Discord ↔ AllFantasy message sync.
model DiscordMessageLink {
  id               String   @id @default(cuid())
  leagueMessageId  String?
  discordMessageId String?
  direction        String   @db.VarChar(16)
  guildId          String?
  channelId        String?
  createdAt        DateTime @default(now())

  @@index([leagueMessageId])
  @@index([discordMessageId])
  @@map("discord_message_links")
}

model PendingSignup {
