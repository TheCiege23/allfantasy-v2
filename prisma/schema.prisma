  user              AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([parentMessageId])
  @@index([leagueId])
  @@index([leagueId, source])
  @@index([createdAt])
  @@index([globalBroadcastId])
  @@map("league_chat_messages")
}

