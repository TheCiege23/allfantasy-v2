/// User-created league templates: save and reuse league settings, draft settings, AI/automation toggles (PROMPT 209).
model LeagueTemplate {
  id          String   @id @default(uuid())
  userId      String
  user        AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   @db.VarChar(120)
  description String?  @db.VarChar(500)
  /// Full wizard-compatible payload: sport, leagueType, draftType, name, teamCount, rosterSize, scoringPreset, leagueVariant, draftSettings, aiSettings, automationSettings, privacySettings.
  payload     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("league_templates")
}

// ========== Tournament Mode (PROMPT 2) — multi-league elimination ==========

/// Tournament: one parent record; creator is commissioner of all child leagues.
model Tournament {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(120)
  sport       String   @db.VarChar(8)   // NFL first
  season      Int      @default(0)
  variant     String   @default("black_vs_gold") @db.VarChar(32)
  creatorId   String
  /// qualificationWeeks, advancementPerLeague, redraftWeeks, draftType, participantPoolSize, leagueNamingMode, faabResetByRound, benchByRound, etc.
  settings    Json     @default("{}")
  /// visibility: public | unlisted | private. forumAnnouncements: boolean. bannerTheme: string.
  hubSettings Json     @default("{}")
  status      String   @default("setup") @db.VarChar(24)   // setup | qualification | elimination | finals | completed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Set when tournament is completed; prevents duplicate champion.
  championUserId String?  @db.VarChar(64)
  /// Locked at start of competition; no rebalance after this.
  lockedAt       DateTime?

  creator      AppUser                @relation("TournamentCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  conferences  TournamentConference[]
  leagues      TournamentLeague[]
  rounds       TournamentRound[]
  announcements TournamentAnnouncement[]
  participants TournamentParticipant[]
  auditLogs    TournamentAuditLog[]

  @@index([creatorId])
  @@index([sport, season])
  @@index([status])
  @@map("tournaments")
}

/// Conference: e.g. Black / Gold; themed names and styling.
model TournamentConference {
  id           String   @id @default(uuid())
  tournamentId String
  name         String   @db.VarChar(64)
  theme        String   @default("black") @db.VarChar(24)   // black | gold | custom
  themePayload Json?    // { primaryColor, secondaryColor, iconName }
  orderIndex   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournament   Tournament              @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  leagues      TournamentLeague[]
  participants TournamentParticipant[]

  @@index([tournamentId])
  @@map("tournament_conferences")
}

/// Join: League belongs to one Tournament and one Conference; round/phase tracked.
model TournamentLeague {
  id             String   @id @default(uuid())
  tournamentId   String
  conferenceId   String
  leagueId       String   @unique
  roundIndex     Int      @default(0)   // 0 = qualification
  phase          String   @default("qualification") @db.VarChar(24)   // qualification | elimination | elite_eight | championship
  orderInConference Int   @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tournament Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  conference TournamentConference @relation(fields: [conferenceId], references: [id], onDelete: Cascade)
  league     League             @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
  @@index([conferenceId])
  @@map("tournament_leagues")
}

/// Round container: qualification round, elimination rounds, finals.
model TournamentRound {
  id           String   @id @default(uuid())
  tournamentId String
  roundIndex   Int      // 0 = qualification, 1+ = elimination/finals
  phase        String   @db.VarChar(24)   // qualification | elimination | elite_eight | championship
  name         String?  @db.VarChar(64)   // e.g. "Qualification", "Elite Eight"
  startWeek    Int?     @default(0)
  endWeek      Int?     @default(0)
  status       String   @default("pending") @db.VarChar(24)   // pending | active | completed | archived
  settings     Json?    // advancementCount, redraftSchedule, faabReset, benchSpots
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, roundIndex])
  @@index([tournamentId])
  @@map("tournament_rounds")
}

/// Tournament-wide announcements (hub/forum).
model TournamentAnnouncement {
  id           String   @id @default(uuid())
  tournamentId String
  authorId     String?
  title        String?  @db.VarChar(200)
  body         String   @db.Text
  type         String   @default("general") @db.VarChar(32)   // general | round_start | round_end | redraft | league_disband | champion_story
  metadata     Json?    // roundIndex, leagueIds, linkedLeagueId
  pinned       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
  @@index([tournamentId, createdAt])
  @@map("tournament_announcements")
}

/// PROMPT 5: Audit log for advancement, elimination, redraft, overrides, tie resolution, lock, rebalance.
model TournamentAuditLog {
  id            String   @id @default(uuid())
  tournamentId  String
  actorId       String?  // commissioner userId
  action        String   @db.VarChar(48)   // advancement_run | elimination | force_advance | tie_resolution | lock | rebalance | rerun_standings | rerun_seeding | redraft_regenerate | draft_reopen | archive_round | resolve_state | bulk_update
  targetType    String?  @db.VarChar(24)   // participant | league | round | tournament
  targetId      String?  @db.VarChar(128)
  metadata      Json?    // userId, leagueId, roundIndex, before/after, reason
  createdAt     DateTime @default(now())

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([tournamentId])
  @@index([tournamentId, createdAt])
  @@map("tournament_audit_logs")
}

/// PROMPT 3: Participant progression — one row per user in a tournament; tracks qualification rank, current league, elimination.
model TournamentParticipant {
  id                        String   @id @default(uuid())
  tournamentId               String
  userId                     String   // AppUser.id (or platform user id that joined)
  conferenceId               String
  /// Qualification league/roster (feeder).
  qualificationLeagueId      String?
  qualificationRosterId      String?
  qualificationRankInConference Int?   // 1-based within conference
  qualificationWins         Int      @default(0)
  qualificationLosses        Int      @default(0)
  qualificationPointsFor     Float    @default(0)
  qualificationPointsAgainst Float   @default(0)
  /// Current league/roster (null if eliminated).
  currentLeagueId            String?
  currentRosterId             String?
  /// Last round index from which they advanced (0 = from qualification).
  advancedAtRoundIndex       Int      @default(0)
  /// Set when eliminated; null if still active.
  eliminatedAtRoundIndex     Int?
  status                     String   @default("active") @db.VarChar(24)   // active | eliminated
  bubbleAdvanced             Boolean  @default(false)
  /// For bracket display: which elimination round league (NORTH/SOUTH/EAST/WEST) they were assigned.
  bracketLabel               String?  @db.VarChar(32)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  tournament  Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  conference  TournamentConference @relation(fields: [conferenceId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([conferenceId])
  @@index([tournamentId, status])
  @@map("tournament_participants")
}

/// League chat (main app League). Syncs with draft chat when liveDraftChatSyncEnabled during active draft.
model LeagueChatMessage {
  id        String   @id @default(cuid())
  leagueId  String
  league    League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  userId    String
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String   @db.Text
  type      String   @default("text") @db.VarChar(32)
  imageUrl  String?  @db.Text
  metadata  Json?
  /// 'draft' = draft-only (when sync off); null = league chat (or draft when sync on)
  source    String?  @db.VarChar(16)
  createdAt DateTime @default(now())

  @@index([leagueId])
  @@index([leagueId, source])
  @@index([createdAt])
  @@map("league_chat_messages")
}

model AiCommissionerConfig {
