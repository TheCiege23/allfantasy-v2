  sport      String

  slotType     String
  isLocked     Boolean @default(false)
  injuryStatus String?
  byeWeek      Int?

  addedAt   DateTime  @default(now())
  droppedAt DateTime?

  acquisitionType String  @default("drafted")
  isKept          Boolean @default(false)

  @@index([rosterId])
  @@index([playerId])
  @@map("redraft_roster_players")
}

model RedraftMatchup {
  id       String        @id @default(cuid())
  seasonId String
  season   RedraftSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  leagueId String
  league   League        @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  week     Int
  type     String        @default("regular")

  homeRosterId String
  homeRoster   RedraftRoster  @relation("RedraftHomeRoster", fields: [homeRosterId], references: [id], onDelete: Cascade)
  awayRosterId String?
  awayRoster   RedraftRoster? @relation("RedraftAwayRoster", fields: [awayRosterId], references: [id], onDelete: SetNull)

  homeScore     Float  @default(0)
  awayScore     Float  @default(0)
  homeProjected Float?
  awayProjected Float?
  homeWinPct    Float?
  awayWinPct    Float?

  status          String  @default("scheduled")
  isMedianMatchup Boolean @default(false)
  medianScore     Float?
  lineupSnapshots Json?

  c2cMatchupScores C2CMatchupScore[]

  @@index([seasonId, week])
  @@index([homeRosterId])
  @@index([awayRosterId])
  @@map("redraft_matchups")
}

model RedraftWaiverClaim {
