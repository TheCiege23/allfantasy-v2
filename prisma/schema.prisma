  config          DynastyLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  season          Int
  /// JSON array of { teamId/rosterId, pickSlot } or full order
  overridePayload Json
  userId          String              @db.VarChar(64)
  reason          String?             @db.VarChar(256)
  createdAt       DateTime            @default(now())

  @@index([leagueId])
  @@index([configId])
  @@map("dynasty_draft_order_audit_logs")
}

/// IDP player eligibility tags (grouped/split position, external source). Used to resolve ambiguity and audit midseason position changes.
