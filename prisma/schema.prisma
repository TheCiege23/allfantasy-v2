  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verify_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model League {
  id               String      @id @default(uuid())
  userId           String
  platform         String
  platformLeagueId String
  name             String?
  sport            LeagueSport @default(NFL)
  leagueVariant    String?     @db.VarChar(32)
  /// Season year for this row (Sleeper may have one row per league per year).
  season           Int         @default(2024)
  leagueSize       Int?
  scoring          String?
  isDynasty        Boolean     @default(false)
  rosterSize       Int?
  starters         Json?
  status           String?
  avatarUrl        String?
  settings         Json?
  lastSyncedAt     DateTime?
  syncStatus       String?
  syncError        String?
  importBatchId    String?     @db.VarChar(64)
  importedAt       DateTime?
  /// True when the importing user is Sleeper commissioner (is_owner) for current-season imports.
  isCommissioner   Boolean     @default(false)

  /// League logo (AllFantasy commissioner upload; separate from imported avatarUrl when set).
  logoUrl  String?
  /// Official league timezone for waivers, trades, and scheduled events (synced to draft LeagueSettings when updated).
  timezone String? @default("America/New_York")

  waiverType            String? @default("rolling")
  waiverBudget          Int?    @default(100)
  waiverMinBid          Int?    @default(0)
  waiverClearAfterGames Boolean @default(true)
  waiverHours           Int?    @default(24)
  customDailyWaivers    Boolean @default(false)
  waiverProcessTime     String? @default("02:00")
  waiverSchedule        Json?

  tradeReviewHours  Int?    @default(48)
  tradeDeadlineWeek Int?
  draftPickTrading  Boolean @default(false)

  playoffStartWeek     Int?    @default(14)
  playoffTeams         Int?    @default(4)
  playoffWeeksPerRound Int?    @default(1)
  playoffSeedingRule   String? @default("default")
  playoffLowerBracket  String? @default("consolation")

  irSlots          Int?    @default(0)
  irAllowCovid     Boolean @default(false)
  irAllowOut       Boolean @default(true)
  irAllowSuspended Boolean @default(false)
  irAllowNA        Boolean @default(false)
  irAllowDNR       Boolean @default(false)
  irAllowDoubtful  Boolean @default(false)

  leagueType String? @default("redraft")
  devyYear   String?

  medianGame             Boolean @default(false)
  allowPreDraftMoves     Boolean @default(true)
  preventBenchDrops      Boolean @default(false)
  lockAllMoves           Boolean @default(false)
  dispersalDraftRounds   Int?    @default(0) @map("supplementalDraftRounds")
  taxiSlots              Int?    @default(0)
  taxiAllowNonRookies    Boolean @default(false)
  taxiYearsLimit         Int?    @default(2)
  taxiDeadlineWeek       Int?    @default(0)
  overrideInviteCapacity Boolean @default(false)
  disableInviteLinks     Boolean @default(false)

  aiChimmyEnabled            Boolean @default(true)
  aiWaiverSuggestions        Boolean @default(false)
  aiTradeAnalysis            Boolean @default(false)
  aiLineupHelp               Boolean @default(false)
  aiDraftRecs                Boolean @default(false)
  aiRecaps                   Boolean @default(false)
  /// League-wide toggle (distinct from AiCommissionerAlert records).
  leagueAiCommissionerAlerts Boolean @default(false)
  aiModeration               Boolean @default(false)
  aiPowerRankings            Boolean @default(false)

