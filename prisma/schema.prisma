  leagueId                    String             @unique
  totalCap                    Float              @default(200.0)
  isHardCap                   Boolean            @default(true)
  capFloorEnabled             Boolean            @default(false)
  capFloor                    Float?
  capRolloverEnabled          Boolean            @default(false)
  inSeasonHoldbackEnabled     Boolean            @default(false)
  inSeasonHoldbackPct         Float              @default(0.10)
  franchiseTagEnabled         Boolean            @default(false)
  franchiseTagValue           Float              @default(20.0)
  draftSalaryMethod           String             @default("auction")
  snakeScaleHighSalary        Float              @default(30.0)
  snakeScaleLowSalary         Float              @default(1.0)
  snakeScaleCurve             String             @default("linear")
  auctionDefaultContractYears Int                @default(1)
  snakeTopPickContractYears   Int                @default(3)
  snakeMidPickContractYears   Int                @default(2)
  snakeLatePickContractYears  Int                @default(1)
  isDynastyMode               Boolean            @default(false)
  contractsCarryOver          Boolean            @default(false)
