  @@map("guillotine_event_logs")
}

// ========== Salary Cap League Engine (PROMPT 339) ==========

/// Salary Cap league config (1:1 with League when leagueVariant is salary_cap).
model SalaryCapLeagueConfig {
  id                      String    @id @default(uuid())
  leagueId                String    @unique @db.VarChar(64)
  league                  League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  mode                    String    @default("dynasty") @db.VarChar(24) // dynasty | bestball
  startupCap              Int       @default(250)
  capGrowthPercent        Float     @default(5)
  contractMinYears        Int       @default(1)
  contractMaxYears        Int       @default(4)
  rookieContractYears     Int       @default(3)
  minimumSalary           Int       @default(1)
  deadMoneyEnabled        Boolean   @default(true)
  deadMoneyPercentPerYear Float     @default(25)
  rolloverEnabled         Boolean   @default(true)
  rolloverMax             Int       @default(25)
  capFloorEnabled         Boolean   @default(false)
  capFloorAmount          Int?
  extensionsEnabled       Boolean   @default(true)
  franchiseTagEnabled     Boolean   @default(true)
  rookieOptionEnabled     Boolean   @default(false)
  startupDraftType        String    @default("auction") @db.VarChar(24) // auction | snake | linear
  futureDraftType         String    @default("linear") @db.VarChar(24) // linear | auction | weighted_lottery
  auctionHoldback         Int       @default(50)
  weightedLotteryEnabled  Boolean   @default(false)
  lotteryOddsConfig       Json? // e.g. { nonPlayoff: number[], playoff: number[] } or seed->weight
  compPickEnabled         Boolean   @default(false)
  compPickFormula         Json?
  offseasonPhase          String?   @db.VarChar(32) // lock | expiration | rollover | extension | tag | draft | fa_open | in_season
  offseasonPhaseEndsAt    DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  ledgers   SalaryCapTeamLedger[]
  contracts PlayerContract[]
  eventLog  SalaryCapEventLog[]

  @@map("salary_cap_league_configs")
}

/// Per-roster, per-cap-year cap state (cap hit total, rollover, etc.).
model SalaryCapTeamLedger {
  id           String                @id @default(uuid())
  leagueId     String                @db.VarChar(64)
  configId     String
  config       SalaryCapLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  rosterId     String                @db.VarChar(64)
  capYear      Int // season year (e.g. 2025)
  totalCapHit  Int                   @default(0)
  deadMoneyHit Int                   @default(0)
  rolloverUsed Int                   @default(0)
  capSpace     Int                   @default(0) // derived: cap - totalCapHit - deadMoneyHit + rolloverUsed (stored for quick read)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([configId, rosterId, capYear])
  @@index([leagueId, capYear])
  @@index([rosterId, capYear])
  @@map("salary_cap_team_ledgers")
}

/// Player contract: roster + player + salary + years. One row per active/expired contract instance.
model PlayerContract {
  id                 String                @id @default(uuid())
  leagueId           String                @db.VarChar(64)
  configId           String
  config             SalaryCapLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  rosterId           String                @db.VarChar(64)
  playerId           String                @db.VarChar(64)
  playerName         String?               @db.VarChar(128)
  position           String?               @db.VarChar(16)
  salary             Int // annual salary (cap hit for standard contracts)
  yearsTotal         Int
  yearSigned         Int // cap year when signed
  contractYear       Int                   @default(1) // current year of contract (1..yearsTotal)
  status             String                @default("active") @db.VarChar(24) // active | expired | cut | traded | tagged | option_exercised
  source             String                @db.VarChar(32) // startup_auction | rookie_draft | waiver_bid | extension | franchise_tag | trade
  franchiseTagAt     DateTime?
  optionExercisedAt  DateTime?
  cutAt              DateTime?
  deadMoneyRemaining Json? // { capYear: amount } for future years
  metadata           Json?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([leagueId, rosterId])
  @@index([leagueId, playerId])
  @@index([configId, yearSigned])
  @@index([rosterId, status])
  @@map("player_contracts")
}

/// Append-only event log for salary cap (contract signed, cut, extension, tag, rollover, etc.).
model SalaryCapEventLog {
  id        String                @id @default(cuid())
  leagueId  String                @db.VarChar(64)
  configId  String
  config    SalaryCapLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  eventType String                @db.VarChar(64)
  metadata  Json?
  createdAt DateTime              @default(now())

  @@index([leagueId, eventType])
  @@index([createdAt])
  @@map("salary_cap_event_logs")
}

/// Weighted lottery result (deterministic, auditable). One row per league per season.
model SalaryCapLotteryResult {
  id        String   @id @default(uuid())
  leagueId  String   @db.VarChar(64)
  configId  String
  capYear   Int
  seed      String?  @db.VarChar(64) // audit: random seed used
  order     Json // [ { slot: number, rosterId: string, originalOrder: number } ]
  createdAt DateTime @default(now())

  @@unique([configId, capYear])
  @@index([leagueId, capYear])
  @@map("salary_cap_lottery_results")
}

// ========== Survivor League Engine (PROMPT 346) ==========

/// Survivor league config (1:1 with League when leagueVariant is survivor).
model SurvivorLeagueConfig {
  id                             String   @id @default(uuid())
  leagueId                       String   @unique @db.VarChar(64)
  league                         League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  mode                           String   @default("redraft") @db.VarChar(24) // redraft | bestball
  tribeCount                     Int      @default(4)
  tribeSize                      Int      @default(4) // target per tribe (tribeCount * tribeSize <= leagueSize)
  tribeFormation                 String   @default("random") @db.VarChar(24) // random | commissioner
  mergeTrigger                   String   @default("week") @db.VarChar(24) // week | player_count
  mergeWeek                      Int? // when mergeTrigger = week
  mergePlayerCount               Int? // when mergeTrigger = player_count
  juryStartAfterMerge            Int      @default(1) // first N vote-outs after merge are jury
  exileReturnEnabled             Boolean  @default(false)
  exileReturnTokens              Int      @default(4)
  idolCount                      Int      @default(2)
  idolPowerPool                  Json? // array of power type ids enabled
  tribeShuffleEnabled            Boolean  @default(false)
  tribeShuffleConsecutiveLosses  Int? // trigger after N consecutive council losses
  tribeShuffleImbalanceThreshold Float? // e.g. tribe size diff
  voteDeadlineDayOfWeek          Int? // 1-7
  voteDeadlineTimeUtc            String?  @db.VarChar(16)
  selfVoteDisallowed             Boolean  @default(true)
  tribalCouncilDayOfWeek         Int?
  tribalCouncilTimeUtc           String?  @db.VarChar(16)
  minigameFrequency              String   @default("none") @db.VarChar(24) // none | weekly | custom
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt

  tribes      SurvivorTribe[]
  idols       SurvivorIdol[]
  councils    SurvivorTribalCouncil[]
  exileLeague SurvivorExileLeague?
  auditLog    SurvivorAuditLog[]
  challenges  SurvivorChallenge[]

  @@map("survivor_league_configs")
}

/// Tribe within a Survivor league.
model SurvivorTribe {
  id            String               @id @default(uuid())
  leagueId      String               @db.VarChar(64)
  configId      String
  config        SurvivorLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  name          String               @db.VarChar(128)
  slotIndex     Int                  @default(0) // 0-based order
  logoUrl       String?
  colorHex      String?
  isActive      Boolean              @default(true)
  isMerged      Boolean              @default(false)
  phase         String               @default("pre_merge") @db.VarChar(24)
  chatChannelId String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  members         SurvivorTribeMember[]
  chatMembers     SurvivorTribeChatMember[]
  councils        SurvivorTribalCouncil[] // councils this tribe attended (pre-merge)
  survivorPlayers SurvivorPlayer[]

  @@unique([configId, slotIndex])
  @@index([leagueId])
  @@map("survivor_tribes")
}

/// Tribe membership: roster in a tribe. Pre-merge only; merge has no tribes.
model SurvivorTribeMember {
  id       String        @id @default(uuid())
  tribeId  String
  tribe    SurvivorTribe @relation(fields: [tribeId], references: [id], onDelete: Cascade)
  rosterId String        @db.VarChar(64)
  isLeader Boolean       @default(false)
  joinedAt DateTime      @default(now())

  @@unique([tribeId, rosterId])
  @@index([rosterId])
  @@index([tribeId])
  @@map("survivor_tribe_members")
}

/// Hidden idol: player-bound, one-time use. Ownership = current controlling rosterId.
model SurvivorIdol {
  id                  String               @id @default(uuid())
  leagueId            String               @db.VarChar(64)
  configId            String
  config              SurvivorLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  rosterId            String               @db.VarChar(64) // current owner (controls idol)
  playerId            String               @db.VarChar(64) // bound to this player (for transfer on trade/claim/steal)
  powerType           String               @db.VarChar(64)
  powerCategory       String?              @db.VarChar(64)
  powerLabel          String?              @db.VarChar(160)
  powerDesc           String?              @db.Text
  currentOwnerUserId  String?              @db.VarChar(64)
  originalOwnerUserId String?              @db.VarChar(64)
  isSecret            Boolean              @default(true)
  isPubliclyKnown     Boolean              @default(false)
  isTradable          Boolean              @default(false)
  transferHistory     Json?
  playWindowRule      String               @default("before_reveal") @db.VarChar(32)
  rarity              String               @default("common") @db.VarChar(24)
  expiresAtMerge      Boolean              @default(true)
  expiresAtWeek       Int?
  usedAtCouncilId     String?              @db.VarChar(64)
  isUsed              Boolean              @default(false)
  status              String               @default("hidden") @db.VarChar(24) // hidden | revealed | used | expired
  assignedAt          DateTime             @default(now())
  usedAt              DateTime?
  expiredAt           DateTime?
  validUntilPhase     String?              @db.VarChar(32) // e.g. merge = invalid after merge
  auditLog            Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  ledgerEntries SurvivorIdolLedgerEntry[]

  @@index([leagueId, rosterId])
  @@index([leagueId, playerId])
  @@index([configId, status])
  @@index([leagueId, currentOwnerUserId])
  @@index([leagueId, powerType])
  @@map("survivor_idols")
}

/// Chain-of-custody for idols: assignment, transfer, use, expiry.
model SurvivorIdolLedgerEntry {
  id           String       @id @default(cuid())
  leagueId     String       @db.VarChar(64)
  idolId       String
  idol         SurvivorIdol @relation(fields: [idolId], references: [id], onDelete: Cascade)
  eventType    String       @db.VarChar(32) // assigned | transferred | used | expired
  fromRosterId String?      @db.VarChar(64)
  toRosterId   String?      @db.VarChar(64)
  metadata     Json?
  createdAt    DateTime     @default(now())

  @@index([leagueId, eventType])
  @@index([idolId])
  @@map("survivor_idol_ledger_entries")
}

/// Tribal Council: one per week (or period). Pre-merge = one tribe attends; merge = all remaining.
model SurvivorTribalCouncil {
  id                   String               @id @default(uuid())
  leagueId             String               @db.VarChar(64)
  configId             String
  config               SurvivorLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  week                 Int
  councilNumber        Int                  @default(1)
  phase                String               @db.VarChar(24) // pre_merge | merge
  attendingTribeId     String?              @db.VarChar(64) // pre_merge: which tribe
  tribe                SurvivorTribe?       @relation(fields: [attendingTribeId], references: [id], onDelete: SetNull)
  status               String               @default("pending") @db.VarChar(24)
  votingOpensAt        DateTime?
  voteDeadlineAt       DateTime
  votingDeadline       DateTime?
  revealStartsAt       DateTime?
  closedAt             DateTime?
  eliminatedRosterId   String?              @db.VarChar(64)
  eliminatedUserId     String?              @db.VarChar(64)
  eliminatedName       String?              @db.VarChar(160)
  isTie                Boolean              @default(false)
  tiePhase             String?              @db.VarChar(32)
  tiePlayerIds         String[]             @default([])
  rockDrawerUserId     String?              @db.VarChar(64)
  idolsPlayed          Json?
  nullifiersPlayed     Json?
  doesNotCountVoteIds  String[]             @default([])
  revealSequence       Json?
  isRevealed           Boolean              @default(false)
  auditLog             Json?
  tieBreakSeasonPoints Json? // snapshot of season points for tie-break
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  votes SurvivorVote[]

  @@unique([configId, week, councilNumber])
  @@index([leagueId, week])
  @@map("survivor_tribal_councils")
}

/// Single vote in a Tribal Council (private ballot).
model SurvivorVote {
  id             String                @id @default(cuid())
  councilId      String
  council        SurvivorTribalCouncil @relation(fields: [councilId], references: [id], onDelete: Cascade)
  leagueId       String?               @db.VarChar(64)
  voterRosterId  String                @db.VarChar(64)
  targetRosterId String                @db.VarChar(64)
  voterUserId    String?               @db.VarChar(64)
  targetUserId   String?               @db.VarChar(64)
  voterName      String?               @db.VarChar(160)
  targetName     String?               @db.VarChar(160)
  isDoubleVote   Boolean               @default(false)
  doesNotCount   Boolean               @default(false)
  nullifiedBy    String?               @db.VarChar(64)
  isLateVote     Boolean               @default(false)
  submittedAt    DateTime              @default(now())

  @@unique([councilId, voterRosterId])
  @@index([councilId])
  @@index([voterUserId])
  @@index([leagueId])
  @@map("survivor_votes")
}

/// Link main Survivor league to its Exile Island league.
model SurvivorExileLeague {
  id            String               @id @default(uuid())
  mainLeagueId  String               @unique @db.VarChar(64)
  configId      String               @unique
  config        SurvivorLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  exileLeagueId String               @db.VarChar(64) // separate League row (exile island)
  createdAt     DateTime             @default(now())

  @@index([exileLeagueId])
  @@map("survivor_exile_leagues")
}

/// Exile token balance per roster (in exile league). Reset when Boss wins.
model SurvivorExileToken {
  id              String   @id @default(uuid())
  exileLeagueId   String   @db.VarChar(64)
  rosterId        String   @db.VarChar(64) // roster in exile league
  tokens          Int      @default(0)
  lastAwardedWeek Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([exileLeagueId, rosterId])
  @@index([exileLeagueId])
  @@map("survivor_exile_tokens")
}

/// Jury membership: rosterId = main league roster that was voted out and is now on jury.
model SurvivorJuryMember {
  id           String   @id @default(cuid())
  leagueId     String   @db.VarChar(64)
  rosterId     String   @db.VarChar(64)
  votedOutWeek Int
  joinedAt     DateTime @default(now())

  @@unique([leagueId, rosterId])
  @@index([leagueId])
  @@map("survivor_jury_members")
}

/// Survivor audit log: votes, idol use, shuffle, elimination, overrides.
model SurvivorAuditLog {
  id        String               @id @default(cuid())
  leagueId  String               @db.VarChar(64)
  configId  String
  config    SurvivorLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  eventType String               @db.VarChar(64)
  metadata  Json?
  createdAt DateTime             @default(now())

  @@index([leagueId, eventType])
  @@index([createdAt])
  @@map("survivor_audit_logs")
}

/// Mini-game / challenge definition per week.
model SurvivorChallenge {
  id              String               @id @default(uuid())
  leagueId        String               @db.VarChar(64)
  configId        String
  config          SurvivorLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  week            Int
  challengeNumber Int                  @default(1)
  challengeType   String               @db.VarChar(64) // score_prediction | over_under | player_prop | tribe_vs | immunity_auction | puzzle | trivia
  type            String?              @db.VarChar(64)
  title           String               @default("") @db.VarChar(256)
  description     String               @default("") @db.Text
  instructions    String               @default("") @db.Text
  scope           String               @default("tribe") @db.VarChar(24)
  submissionMode  String               @default("tribe_chat") @db.VarChar(32)
  configJson      Json? // type-specific params (line, options, reward type)
  lockAt          DateTime?
  locksAt         DateTime?
  closesAt        DateTime?
  status          String               @default("open") @db.VarChar(24)
  rewardType      String?              @db.VarChar(64)
  rewardAmount    Float?
  rewardDetails   Json?
  penaltyType     String?              @db.VarChar(64)
  penaltyDetails  Json?
  winnerUserIds   String[]             @default([])
  winnerTribeId   String?              @db.VarChar(64)
  resultSummary   String?              @db.Text
  auditLog        Json?
  resultJson      Json? // resolved outcome and rewards
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  submissions SurvivorChallengeSubmission[]

  @@unique([configId, week, challengeNumber, challengeType])
  @@index([leagueId, week])
  @@map("survivor_challenges")
}

/// One submission per roster (or tribe) per challenge.
model SurvivorChallengeSubmission {
  id           String            @id @default(cuid())
  challengeId  String
  challenge    SurvivorChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  leagueId     String?           @db.VarChar(64)
  userId       String?           @db.VarChar(64)
  rosterId     String?           @db.VarChar(64)
  tribeId      String?           @db.VarChar(64)
  submission   Json // type-specific (e.g. over/under choice, predicted score)
  isCorrect    Boolean?
  pointsEarned Float?
  isLocked     Boolean           @default(false)
  submittedAt  DateTime          @default(now())

  @@unique([challengeId, rosterId], name: "uniq_challenge_roster")
  @@unique([challengeId, tribeId], name: "uniq_challenge_tribe")
  @@unique([challengeId, userId], name: "uniq_challenge_user")
  @@index([challengeId])
  @@map("survivor_challenge_submissions")
}

/// Tribe-scoped chat: membership tracked here; messages can use LeagueChatMessage with source = tribe_<tribeId> or separate table.
/// For private tribe chat we use source on LeagueChatMessage = 'tribe_<tribeId>' and filter by roster membership.
model SurvivorTribeChatMember {
  id       String        @id @default(uuid())
  tribeId  String
  tribe    SurvivorTribe @relation(fields: [tribeId], references: [id], onDelete: Cascade)
  rosterId String        @db.VarChar(64)
  userId   String?       @db.VarChar(64) // for AI host: optional system userId
  isAiHost Boolean       @default(false)
  joinedAt DateTime      @default(now())

  @@unique([tribeId, rosterId], name: "uniq_tribe_roster")
  @@unique([tribeId, userId], name: "uniq_tribe_user")
  @@index([tribeId])
  @@map("survivor_tribe_chat_members")
}

/// Per-user Survivor game state (parallel to roster-based tribe membership).
model SurvivorPlayer {
  id          String  @id @default(cuid())
  leagueId    String
  league      League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  userId      String
  displayName String
  avatarUrl   String?

  tribeId String?
  tribe   SurvivorTribe? @relation(fields: [tribeId], references: [id], onDelete: SetNull)

  playerState      String @default("active")
  eliminatedWeek   Int?
  eliminationRound Int?

  idolIds String[] @default([])

  tokenBalance      Int @default(0)
  totalTokensEarned Int @default(0)

  hasImmunityThisWeek Boolean @default(false)
  immunitySource      String?

  exileReturnEligible Boolean @default(false)
  exileWeeksServed    Int     @default(0)

  redraftRosterId String?

  canAccessTribeChat  Boolean @default(true)
  canAccessMergeChat  Boolean @default(false)
  canAccessExileChat  Boolean @default(false)
  canAccessJuryChat   Boolean @default(false)
  canAccessFinaleChat Boolean @default(false)

  isJuryMember Boolean @default(false)
  isFinalist   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leagueId, userId])
  @@index([leagueId, playerState])
  @@index([tribeId])
  @@map("survivor_players")
}

/// Finale jury voting session (1:1 with league).
model JurySession {
  id       String @id @default(cuid())
  leagueId String @unique
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  status          String   @default("pending")
  finalistUserIds String[] @default([])
  jurorUserIds    String[] @default([])

  questionsDeadline DateTime?
  votingDeadline    DateTime?

  votes      JuryVote[]
  winnerId   String?
  winnerName String?
  revealedAt DateTime?

  createdAt DateTime @default(now())

  @@map("survivor_jury_sessions")
}

model JuryVote {
  id             String      @id @default(cuid())
  sessionId      String
  session        JurySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  jurorUserId    String
  finalistUserId String
  submittedAt    DateTime    @default(now())
  isLate         Boolean     @default(false)

  @@unique([sessionId, jurorUserId])
  @@index([sessionId])
  @@map("survivor_jury_votes")
}

model SurvivorHostMessage {
  id               String    @id @default(cuid())
  leagueId         String
  league           League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  channelType      String
  tribeId          String?
  targetUserId     String?
  messageType      String
  content          String    @db.Text
  isPosted         Boolean   @default(false)
  postedAt         DateTime?
  requiresApproval Boolean   @default(false)
  createdAt        DateTime  @default(now())

  @@index([leagueId, channelType])
  @@map("survivor_host_messages")
}

model SurvivorChatChannel {
  id              String                @id @default(cuid())
  leagueId        String
  league          League                @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  name            String
  channelType     String
  tribeId         String?
  memberUserIds   String[]              @default([])
  readOnlyUserIds String[]              @default([])
  isArchived      Boolean               @default(false)
  archivedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  messages        SurvivorChatMessage[] @relation("SurvivorChatChannelMessages")

  @@index([leagueId, channelType])
  @@map("survivor_chat_channels")
}

model SurvivorTribeSwap {
  id                     String   @id @default(cuid())
  leagueId               String
  league                 League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  week                   Int
  swapType               String   @default("random_shuffle")
  beforeSnapshot         Json
  afterSnapshot          Json
  newTribes              Json?
  originalTribesRetained Boolean  @default(true)
  executedAt             DateTime @default(now())

  @@index([leagueId])
  @@map("survivor_tribe_swaps")
}

model TokenPoolPick {
  id           String   @id @default(cuid())
  leagueId     String
  league       League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  userId       String
  week         Int
  sport        String
  pickType     String
  pick         Json
  isCorrect    Boolean?
  tokensEarned Int      @default(0)
  tokensLost   Int      @default(0)
  submittedAt  DateTime @default(now())

  @@index([leagueId, userId, week])
  @@map("survivor_token_pool_picks")
}

/// Exile parallel game — one row per Survivor-enabled league.
model ExileIsland {
  id                  String   @id @default(cuid())
  leagueId            String   @unique
  league              League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  isActive            Boolean  @default(false)
  currentWeek         Int      @default(0)
  bossName            String?  @default("The Exile Boss")
  bossRosterId        String?
  bossWinsEnabled     Boolean  @default(true)
  bossTokenResetOnWin Boolean  @default(true)
  chatChannelId       String?
  createdAt           DateTime @default(now())

  exilePlayers ExileWeeklyEntry[]

  @@index([leagueId])
  @@map("survivor_exile_islands")
}

model ExileWeeklyEntry {
  id              String      @id @default(cuid())
  exileId         String
  exile           ExileIsland @relation(fields: [exileId], references: [id], onDelete: Cascade)
  leagueId        String
