  remindersEnabled               Boolean     @default(true)
  disputeAnalysisEnabled         Boolean     @default(true)
  collusionMonitoringEnabled     Boolean     @default(true)
  voteSuggestionEnabled          Boolean     @default(true)
  inactivityMonitoringEnabled    Boolean     @default(true)
  commissionerNotificationMode   String      @default("in_app") @db.VarChar(24)
  createdAt                      DateTime    @default(now())
  updatedAt                      DateTime    @updatedAt

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId, sport])
  @@map("ai_commissioner_configs")
