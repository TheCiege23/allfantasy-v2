model IdpLeagueConfig {
  id                String                      @id @default(uuid())
  leagueId          String                      @unique @db.VarChar(64)
  /// standard = DL/LB/DB only; advanced = DE/DT/LB/CB/S only; hybrid = both grouped and split slots
  positionMode      String                      @default("standard") @db.VarChar(24)
  /// beginner | standard | advanced | custom (custom uses slotOverrides)
  rosterPreset      String                      @default("standard") @db.VarChar(24)
  /// Custom slot counts when rosterPreset = custom. JSON: { DL?: number, LB?: number, DB?: number, IDP_FLEX?: number, DE?: number, DT?: number, CB?: number, S?: number }
  slotOverrides     Json?
  /// balanced | tackle_heavy | big_play_heavy
  scoringPreset     String                      @default("balanced") @db.VarChar(24)
  /// Per-league scoring overrides. JSON: { idp_solo_tackle?: number, idp_sack?: number, ... }. Merged with preset; overrides take precedence.
  scoringOverrides  Json?
  bestBallEnabled   Boolean                     @default(false)
  /// snake | linear | auction
  draftType         String                      @default("snake") @db.VarChar(16)
  benchSlots        Int                         @default(7)
  irSlots           Int                         @default(2)
  /// When set, position mode and starter counts cannot be changed (prevents post-draft breakage). Cleared only by admin or explicit unlock.
  settingsLockedAt  DateTime?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  bestBallSnapshots IdpBestBallLineupSnapshot[]
  league            League                      @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  auditLogs         IdpSettingsAuditLog[]

  @@map("idp_league_configs")
}

/// Dynasty core league config (shared base for standard Dynasty, Devy, C2C). PROMPT 2/5 + PROMPT 3/5 taxi.
model DynastyLeagueConfig {
  id                        String                      @id @default(uuid())
  leagueId                  String                      @unique @db.VarChar(64)
  /// 13 or 14 weeks default; avoid Week 18 title
  regularSeasonWeeks        Int                         @default(14)
  /// reverse_standings | max_pf | commissioner
  rookiePickOrderMethod     String                      @default("max_pf") @db.VarChar(32)
  /// Non-playoff teams ordered by reverse Max PF (anti-tank)
  useMaxPfForNonPlayoff     Boolean                     @default(true)
  rookieDraftRounds         Int                         @default(4)
  /// linear | snake
  rookieDraftType           String                      @default("linear") @db.VarChar(16)
  divisionsEnabled          Boolean                     @default(false)
  /// Week number before fantasy playoffs; null = no deadline
  tradeDeadlineWeek         Int?
  /// FAAB recommended; stored in waiver settings
  waiverTypeRecommended     String                      @default("faab") @db.VarChar(24)
  /// Future picks tradable years out (2 or 3)
  futurePicksYearsOut       Int                         @default(3)
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime                    @updatedAt
  /// PROMPT 3: Taxi squad slot count (core dynasty default 4; Devy/C2C override via their config).
  taxiSlots                 Int                         @default(4)
  /// 1 = rookies only, 2 = rookies + 2nd year, 3 = rookies + 2nd + 3rd year
  taxiEligibilityYears      Int                         @default(1)
  /// once_promoted_no_return | free_move | commissioner_custom
  taxiLockBehavior          String                      @default("once_promoted_no_return") @db.VarChar(32)
  taxiInSeasonMoves         Boolean                     @default(true)
  taxiPostseasonMoves       Boolean                     @default(false)
  /// Default false: taxi players do not score; specialty modes (e.g. best ball) may override per league.
  taxiScoringOn             Boolean                     @default(false)
  /// Week number after which no taxi moves; null = no deadline
  taxiDeadlineWeek          Int?
  /// Week number after which no promotions from taxi; null = no deadline
  taxiPromotionDeadlineWeek Int?
  draftOrderAuditLogs       DynastyDraftOrderAuditLog[]
  league                    League                      @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@map("dynasty_league_configs")
}

/// Audit log for commissioner draft order overrides. PROMPT 2/5.
model DynastyDraftOrderAuditLog {
  id              String              @id @default(cuid())
  leagueId        String              @db.VarChar(64)
  configId        String
  season          Int
  /// JSON array of { teamId/rosterId, pickSlot } or full order
  overridePayload Json
  userId          String              @db.VarChar(64)
  reason          String?             @db.VarChar(256)
  createdAt       DateTime            @default(now())
  config          DynastyLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([leagueId])
  @@index([configId])
  @@map("dynasty_draft_order_audit_logs")
}

/// IDP player eligibility tags (grouped/split position, external source). Used to resolve ambiguity and audit midseason position changes.
/// leagueId = __global__ means global eligibility; otherwise league-specific override.
model IdpPlayerEligibility {
  id             String   @id @default(uuid())
  sportsPlayerId String   @db.VarChar(64)
  /// __global__ = global; otherwise league-specific override
  leagueId       String   @db.VarChar(64)
  /// Array of positions: ["DE","LB"] for multi-eligibility. Normalized uppercase.
  positionTags   Json
  /// sleeper | manual | sync | import
  source         String   @default("sleeper") @db.VarChar(24)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([sportsPlayerId, leagueId])
  @@index([sportsPlayerId])
  @@index([leagueId])
  @@map("idp_player_eligibility")
}

/// IDP best-ball lineup snapshot per roster/period. Includes IDP slots; starterIds is array of { playerId, slotName }.
model IdpBestBallLineupSnapshot {
  id          String          @id @default(uuid())
  leagueId    String          @db.VarChar(64)
  configId    String
  rosterId    String          @db.VarChar(64)
  periodKey   String          @db.VarChar(32)
  totalPoints Float?
  /// Array of { playerId: string, slotName: string } in optimal lineup order
  starterIds  Json
  createdAt   DateTime        @default(now())
  config      IdpLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([leagueId, rosterId, periodKey])
  @@index([leagueId])
  @@index([rosterId])
  @@map("idp_best_ball_lineup_snapshots")
}

/// Audit log for IDP config changes (scoring, position mode, starter counts). Preserves integrity on eligibility/setting updates.
model IdpSettingsAuditLog {
  id        String          @id @default(cuid())
  leagueId  String          @db.VarChar(64)
  configId  String
  actorId   String?         @db.VarChar(64)
  /// position_mode_change | scoring_change | starter_count_change | scoring_preset_apply | unlock | lock
  action    String          @db.VarChar(48)
  before    Json?
  after     Json?
  metadata  Json?
  createdAt DateTime        @default(now())
  config    IdpLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([leagueId])
  @@index([configId])
  @@index([createdAt])
  @@map("idp_settings_audit_logs")
}

model IDPCapConfig {
