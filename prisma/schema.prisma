  title        String    @db.VarChar(512)
  slug         String    @unique @db.VarChar(512)
  sport        String    @db.VarChar(16)
  category     String    @db.VarChar(64)
  excerpt      String?   @db.VarChar(1024)
  body         String    @db.Text
  seoTitle     String?   @db.VarChar(512)
  seoDescription String? @db.VarChar(512)
  tags         Json      @default("[]")
  publishStatus String   @db.VarChar(24)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  publishLogs  BlogPublishLog[]

  @@index([publishStatus])
  @@index([sport])
  @@index([category])
  @@index([publishedAt])
  @@index([createdAt])
  @@map("blog_articles")
}

/// Blog publish lifecycle log (publish, schedule, draft save).
model BlogPublishLog {
  publishId String   @id @default(cuid())
  articleId String   @db.VarChar(64)
  actionType String  @db.VarChar(32)
  status    String   @db.VarChar(32)
  createdAt DateTime @default(now())

  article BlogArticle @relation(fields: [articleId], references: [articleId], onDelete: Cascade)

  @@index([articleId])
  @@index([createdAt])
  @@map("blog_publish_logs")
}

/// League Broadcast Mode — session for watch parties / streams / big screens.
model BroadcastSession {
  id        String   @id @default(cuid())
  leagueId  String   @db.VarChar(64)
  sport     String   @db.VarChar(16)
  startedAt DateTime @default(now())
  createdBy String?  @db.VarChar(128)

  @@index([leagueId])
  @@index([startedAt])
  @@map("broadcast_sessions")
}

/// AI Commentary Engine — narrated reactions (matchup, trade, waiver, playoff).
model CommentaryEntry {
  id         String   @id @default(cuid())
  leagueId   String   @db.VarChar(64)
  sport      String   @db.VarChar(16)
  eventType  String   @db.VarChar(32)
  headline   String   @db.VarChar(256)
  body       String   @db.Text
  contextSnap Json    @default("{}")
  createdAt  DateTime @default(now())

  @@index([leagueId])
  @@index([leagueId, eventType])
  @@index([createdAt])
  @@map("commentary_entries")
}

enum VerificationMethod {
  EMAIL
  PHONE
}

model UserProfile {
  userId             String              @id
  displayName        String?
  phone              String?             @unique
  phoneVerifiedAt    DateTime?
  emailVerifiedAt    DateTime?
  ageConfirmedAt     DateTime?
  verificationMethod VerificationMethod?
  sleeperUsername    String?
  sleeperUserId      String?             @unique
  sleeperLinkedAt    DateTime?
  sleeperVerifiedAt  DateTime?
  profileComplete    Boolean             @default(false)
  timezone           String?
  preferredLanguage  String?
  themePreference    String?             // "dark" | "light" | "legacy"
  avatarPreset       String?
  bio                String?             @db.Text
  preferredSports         Json?   // string[] e.g. ["NFL","NBA"]
  notificationPreferences  Json?   // NotificationPreferences shape
  onboardingStep          String?  // welcome | app_walkthrough | sport_selection | tool_suggestions | league_prompt | completed
  onboardingCompletedAt   DateTime?
  /// PROMPT 149: Dismissed retention nudge IDs -> ISO date, e.g. { "return_nudge_1": "2025-03-14T..." }
  retentionNudgeDismissedAt Json?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sleeperUsername])
  @@index([phone])
  @@map("user_profiles")
}

model PendingSignup {
  email       String   @id
  displayName String?
  phone       String?
  createdAt   DateTime @default(now())

  @@map("pending_signups")
}

model EmailVerifyToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verify_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model League {
  id               String      @id @default(uuid())
  userId           String
  platform         String
  platformLeagueId String
  name             String?
  sport            LeagueSport @default(NFL)
  leagueVariant    String?     @db.VarChar(32)
  season           Int?
  leagueSize       Int?
  scoring          String?
  isDynasty        Boolean     @default(false)
  rosterSize       Int?
  starters         Json?
  status           String?
  avatarUrl        String?
  settings         Json?
  lastSyncedAt     DateTime?
  syncStatus       String?
  syncError        String?
  importBatchId    String?     @db.VarChar(64)
  importedAt       DateTime?

  rosters            Roster[]
  teams              LeagueTeam[]
  divisions          LeagueDivision[]
  promotionRules     PromotionRule[]
  waiverPickups      WaiverPickup[]
  waiverClaims       WaiverClaim[]
  waiverTransactions WaiverTransaction[]
  waiverSettings     LeagueWaiverSettings?
  guillotineConfig   GuillotineLeagueConfig?
  salaryCapConfig    SalaryCapLeagueConfig?
  survivorConfig     SurvivorLeagueConfig?
  zombieConfig       ZombieLeagueConfig?
  devyConfig         DevyLeagueConfig?
  devyRights         DevyRights[]
  devyLifecycleEvents         DevyLifecycleEvent[]
  devyCommissionerOverrides   DevyCommissionerOverride[]
  devyDraftHistories  DevyDraftHistory[]
  devyBestBallLineupSnapshots DevyBestBallLineupSnapshot[]
  c2cConfig           C2CLeagueConfig?
  zombieLeague       ZombieLeague?   // when league is in a zombie universe
  tournamentLeague   TournamentLeague? // PROMPT 2: when league is part of a tournament
  bigBrotherConfig   BigBrotherLeagueConfig?
  idpConfig          IdpLeagueConfig?
  dynastyConfig      DynastyLeagueConfig?
  mockDrafts         MockDraft[]
  draftSessions      DraftSession[]
  chatMessages       LeagueChatMessage[]
