  summary           String      @db.Text
  relatedManagerIds Json?       @default("[]")
  relatedTradeId    String?     @db.VarChar(128)
  relatedMatchupId  String?     @db.VarChar(128)
  status            String      @default("open") @db.VarChar(24)
  snoozedUntil      DateTime?
  createdAt         DateTime    @default(now())
  resolvedAt        DateTime?
