  killedByRosterId      String?          @db.VarChar(64)
  revivedAt             DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  ambushesRemaining     Int              @default(0)
  ambushesUsed          Int              @default(0)
  avatarUrl             String?
  displayName           String?
  fantasyTeamName       String?
  infectionCount        Int              @default(0)
  isVeteran             Boolean          @default(false)
  isWhisperer           Boolean          @default(false)
  killedAtWeek          Int?
  killedByUserId        String?
  losses                Int              @default(0)
  pointsAgainst         Float            @default(0)
  pointsFor             Float            @default(0)
