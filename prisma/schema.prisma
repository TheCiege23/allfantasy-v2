  orderInLevel Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teams     ZombieLeagueTeam[]
  infections ZombieInfectionLog[]
  resources ZombieResourceLedger[]
  winnings  ZombieWeeklyWinnings[]
  ambushes  ZombieAmbushEvent[]
  audit     ZombieAuditLog[]

  @@index([universeId])
  @@index([levelId])
