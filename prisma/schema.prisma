  supportsSnakeDraft          Boolean  @default(true)
  supportsLinearDraft         Boolean  @default(true)
  supportsTaxi                Boolean  @default(true)
  supportsFuturePicks         Boolean  @default(true)
  supportsTradeableDevyPicks  Boolean  @default(true)
  supportsTradeableRookiePicks Boolean  @default(true)
  /// Commissioner-controlled roster/draft settings.
  devySlotCount               Int      @default(6)
