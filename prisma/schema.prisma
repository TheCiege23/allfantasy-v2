  importTies                            Int?                                   @map("import_ties")
  importMadePlayoffs                    Boolean?                               @map("import_made_playoffs")
  importWonChampionship                 Boolean?                               @map("import_won_championship")
  importFinalStanding                   Int?                                   @map("import_final_standing")
