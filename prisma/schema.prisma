  lastTankingScanAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("league_integrity_settings")
}

/// Per-user per-league Chimmy AutoCoach™ (AF Pro); commissioner can block via `League.autoCoachEnabled` + `blockedByCommissioner`.
