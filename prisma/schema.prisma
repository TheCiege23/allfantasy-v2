/// Dynasty Projection Engine — long-term outlook snapshot per team
model DynastyProjectionSnapshot {
  id                        String   @id @default(cuid())
  leagueId                  String   @db.VarChar(64)
  teamId                    String   @db.VarChar(64)
  season                    Int
  projectedStrengthNextYear Float
  projectedStrength3Years   Float
  projectedStrength5Years   Float
  rebuildProbability        Float
  contenderProbability      Float
  windowStartYear           Int?
  windowEndYear             Int?
  volatilityScore           Float
  confidenceScore           Float
  generatedAt               DateTime @default(now())
  sportType                 String?  @db.VarChar(16)

  @@unique([leagueId, teamId, season], name: "uniq_dynasty_projection_league_team_season")
  @@index([leagueId, season])
  @@index([leagueId, teamId, season])
  @@index([leagueId, sportType, season])
  @@index([sportType, season])
  @@map("dynasty_projection_snapshots")
}

/// Player Aging Curve & Career Projection — multi-year player-level projections
model PlayerCareerProjection {
  id                   String   @id @default(cuid())
  sport                String   @db.VarChar(16)
  playerId             String
  season               Int
  projectedPointsYear1 Float
  projectedPointsYear2 Float
  projectedPointsYear3 Float
  projectedPointsYear4 Float
  projectedPointsYear5 Float
  breakoutProbability  Float
  declineProbability   Float
  volatilityScore      Float
  createdAt            DateTime @default(now())

  @@unique([sport, playerId, season], name: "uniq_player_career_projection_sport_player_season")
  @@index([sport, season])
  @@index([sport, playerId, season])
  @@map("player_career_projections")
}

/// Franchise Window Detection Engine — competitive lifecycle per team
model TeamWindowProfile {
  id                   String   @id @default(cuid())
  leagueId             String   @db.VarChar(64)
  teamId               String   @db.VarChar(64)
  season               Int
  windowStatus         String   @db.VarChar(32)
  windowStartYear      Int?
  windowEndYear        Int?
  rebuildRiskScore     Float
  dynastyStrengthScore Float
  trajectoryDirection  String   @db.VarChar(16)
  updatedAt            DateTime @updatedAt
  sportType            String?  @db.VarChar(16)

  @@unique([leagueId, teamId, season], name: "uniq_team_window_profile_league_team_season")
  @@index([leagueId, season])
  @@index([leagueId, teamId, season])
  @@index([leagueId, sportType, season])
  @@index([sportType, season])
  @@map("team_window_profiles")
}

/// League Intelligence Graph — nodes (entities). sport optional for cross-sport filtering.
model GraphNode {
  id        String   @id @default(cuid())
  nodeId    String   @unique
  nodeType  String   @db.VarChar(32)
  entityId  String   @db.VarChar(128)
  leagueId  String   @db.VarChar(64)
  season    Int?
  metadata  Json?
  createdAt DateTime @default(now())
  sport     String?  @db.VarChar(16)

  @@index([leagueId, season])
  @@index([nodeType, leagueId])
  @@index([entityId, leagueId])
  @@index([leagueId, sport])
  @@map("graph_nodes")
}

/// League Intelligence Graph — edges (relationships). edgeType: FACED, DEFEATED, TRADED_WITH, RIVAL_OF, etc.
model GraphEdge {
  id         String   @id @default(cuid())
  edgeId     String   @unique
  fromNodeId String
  toNodeId   String
  edgeType   String   @db.VarChar(32)
  weight     Float    @default(1)
  season     Int?
  metadata   Json?
  createdAt  DateTime @default(now())
  sport      String?  @db.VarChar(16)

  @@index([fromNodeId])
  @@index([toNodeId])
  @@index([edgeType, season])
  @@index([fromNodeId, toNodeId, edgeType])
  @@index([edgeType, sport])
  @@map("graph_edges")
}

/// League Intelligence Graph — snapshot summary per league/season
model LeagueGraphSnapshot {
  id           String   @id @default(cuid())
  leagueId     String   @db.VarChar(64)
  season       Int
  graphVersion Int      @default(1)
  nodeCount    Int      @default(0)
  edgeCount    Int      @default(0)
  summary      Json?
  generatedAt  DateTime @default(now())

  @@unique([leagueId, season], name: "uniq_league_graph_snapshot_league_season")
  @@index([leagueId, season])
  @@map("league_graph_snapshots")
}

/// Cached weekly power ranking rows per league (for trends / history UI)
model LeaguePowerRankingSnapshot {
  id           String   @id @default(cuid())
  leagueId     String
  season       Int
  week         Int
  rankingMode  String   @default("current_power") @db.VarChar(32)
  engine       String   @db.VarChar(32)
  teams        Json
  computedAt   DateTime @default(now())

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, season, week, rankingMode], map: "uniq_league_power_rank_snapshot_league_season_week_mode")
  @@index([leagueId, computedAt])
  @@map("league_power_ranking_snapshots")
}

/// Dynasty historical import — maps internal league to platform league id per season (for graph/history)
model LeagueDynastySeason {
  id               String   @id @default(cuid())
  leagueId         String   @db.VarChar(64)
  season           Int
  platformLeagueId String   @db.VarChar(64)
  provider         String   @db.VarChar(32)
  importedAt       DateTime @default(now())
  metadata         Json?

  @@unique([leagueId, season], name: "uniq_league_dynasty_season_league_season")
  @@index([leagueId])
  @@index([platformLeagueId])
  @@map("league_dynasty_seasons")
}

/// Dynasty backfill progress and observability — resumable, per-league
model DynastyBackfillStatus {
  id                String    @id @default(cuid())
  leagueId          String    @db.VarChar(64)
  provider          String    @db.VarChar(32)
  status            String    @db.VarChar(24)
  seasonsDiscovered Json?
  seasonsImported   Json?
  seasonsSkipped    Json?
  partialSeasons    Json?
  lastStartedAt     DateTime?
  lastCompletedAt   DateTime?
  failureMessage    String?
  metadata          Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([leagueId, provider], name: "uniq_dynasty_backfill_status_league_provider")
  @@index([leagueId])
  @@index([status])
  @@map("dynasty_backfill_status")
}

/// Player-level game fact (fantasy stats per game)
model PlayerGameFact {
  factId          String   @id @default(cuid())
  playerId        String   @db.VarChar(64)
  sport           String   @db.VarChar(12)
  gameId          String   @db.VarChar(64)
  teamId          String?  @db.VarChar(32)
  opponentTeamId  String?  @db.VarChar(32)
  statPayload     Json     @map("stat_payload")
  normalizedStats Json     @map("normalized_stats")
  fantasyPoints   Float    @default(0)
  scoringPeriod   Int      @default(0)
  season          Int?
  weekOrRound     Int?
  createdAt       DateTime @default(now())

  @@index([playerId, sport])
  @@index([sport, scoringPeriod])
  @@index([sport, season, weekOrRound])
  @@index([gameId])
  @@map("dw_player_game_facts")
}

/// Team-level game fact (points, result)
model TeamGameFact {
  factId         String   @id @default(cuid())
  teamId         String   @db.VarChar(32)
  sport          String   @db.VarChar(12)
  gameId         String   @db.VarChar(64)
  pointsScored   Float    @default(0)
  opponentPoints Float    @default(0)
  result         String?  @db.VarChar(8)
  season         Int?
  weekOrRound    Int?
  createdAt      DateTime @default(now())

  @@index([teamId, sport])
  @@index([sport, season, weekOrRound])
  @@index([gameId])
  @@map("dw_team_game_facts")
}

/// Roster snapshot per league/team/period (lineup + bench)
model RosterSnapshot {
  snapshotId    String   @id @default(cuid())
  leagueId      String   @db.VarChar(64)
  teamId        String   @db.VarChar(64)
  sport         String   @db.VarChar(12)
  weekOrPeriod  Int
  season        Int?
  rosterPlayers Json     @map("roster_players")
  lineupPlayers Json     @map("lineup_players")
  benchPlayers  Json     @map("bench_players")
  createdAt     DateTime @default(now())

  @@index([leagueId, weekOrPeriod])
  @@index([teamId, sport])
  @@index([sport, season])
  @@map("dw_roster_snapshots")
}

/// Matchup fact (head-to-head result per period)
model MatchupFact {
  matchupId    String   @id @default(cuid())
  leagueId     String   @db.VarChar(64)
  sport        String   @db.VarChar(12)
  weekOrPeriod Int
  teamA        String   @db.VarChar(64)
  teamB        String   @db.VarChar(64)
  scoreA       Float    @default(0)
  scoreB       Float    @default(0)
  winnerTeamId String?  @db.VarChar(64)
  season       Int?
  createdAt    DateTime @default(now())

  @@index([leagueId, weekOrPeriod])
  @@index([leagueId, season])
  @@map("dw_matchup_facts")
}

/// Draft fact (pick record)
model DraftFact {
  draftId    String   @id @default(cuid())
  leagueId   String   @db.VarChar(64)
  sport      String   @db.VarChar(12)
  round      Int
  pickNumber Int
  playerId   String   @db.VarChar(64)
  managerId  String?  @db.VarChar(64)
  season     Int?
  createdAt  DateTime @default(now())

  @@index([leagueId])
  @@index([leagueId, round])
  @@index([playerId, sport])
  @@map("dw_draft_facts")
}

/// Transaction fact (add/drop/trade)
model TransactionFact {
  transactionId String   @id @default(cuid())
  leagueId      String   @db.VarChar(64)
  sport         String   @db.VarChar(12)
  type          String   @db.VarChar(24)
  playerId      String?  @db.VarChar(64)
  managerId     String?  @db.VarChar(64)
  rosterId      String?  @db.VarChar(64)
  payload       Json?
  season        Int?
  weekOrPeriod  Int?
  createdAt     DateTime @default(now())

  @@index([leagueId, createdAt])
  @@index([playerId, sport])
  @@index([type])
  @@map("dw_transaction_facts")
}

/// Season standing fact (rank, W-L, PF/PA per team per season)
model SeasonStandingFact {
  standingId    String   @id @default(cuid())
  leagueId      String   @db.VarChar(64)
  sport         String   @db.VarChar(12)
  season        Int
  teamId        String   @db.VarChar(64)
  wins          Int      @default(0)
  losses        Int      @default(0)
  ties          Int      @default(0)
  pointsFor     Float    @default(0)
  pointsAgainst Float    @default(0)
  rank          Int?
  createdAt     DateTime @default(now())

  @@unique([leagueId, season, teamId], name: "uniq_dw_standing_league_season_team")
  @@index([leagueId, season])
  @@index([teamId, sport])
  @@map("dw_season_standing_facts")
}

/// Matchup simulation result (single head-to-head)
model MatchupSimulationResult {
  simulationId       String   @id @default(cuid())
  sport              String   @db.VarChar(12)
  leagueId           String?  @db.VarChar(64)
  weekOrPeriod       Int
  teamAId            String?  @db.VarChar(64)
  teamBId            String?  @db.VarChar(64)
  expectedScoreA     Float
  expectedScoreB     Float
  winProbabilityA    Float
  winProbabilityB    Float
  scoreDistributionA Json?    @map("score_distribution_a")
  scoreDistributionB Json?    @map("score_distribution_b")
  iterations         Int      @default(2000)
  createdAt          DateTime @default(now())

  @@index([leagueId, weekOrPeriod])
  @@index([sport])
  @@map("sim_matchup_results")
}

/// Season simulation result (per-team playoff/championship odds, expected wins/rank)
model SeasonSimulationResult {
  resultId                String   @id @default(cuid())
  sport                   String   @db.VarChar(12)
  leagueId                String   @db.VarChar(64)
  teamId                  String   @db.VarChar(64)
  season                  Int
  weekOrPeriod            Int
  playoffProbability      Float    @default(0)
  championshipProbability Float    @default(0)
  expectedWins            Float    @default(0)
  expectedRank            Float    @default(0)
  simulationsRun          Int      @default(0)
  createdAt               DateTime @default(now())

  @@index([leagueId, season, weekOrPeriod])
  @@index([teamId])
  @@index([sport])
  @@map("sim_season_results")
}

/// Unified dynasty projection output (3/5-year strength, championship window, rebuild, aging, future assets)
model DynastyProjection {
  projectionId            String   @id @default(cuid())
  teamId                  String   @db.VarChar(64)
  leagueId                String   @db.VarChar(64)
  sport                   String   @db.VarChar(12)
  championshipWindowScore Float    @default(0)
  rebuildProbability      Float    @default(0)
  rosterStrength3Year     Float    @default(0)
  rosterStrength5Year     Float    @default(0)
  agingRiskScore          Float    @default(0)
  futureAssetScore        Float    @default(0)
  season                  Int?
  createdAt               DateTime @default(now())

  @@unique([leagueId, teamId], name: "uniq_dynasty_projection_league_team")
  @@index([leagueId])
  @@index([teamId])
  @@index([sport])
  @@map("dynasty_projections")
}

/// Platform-wide feature toggles and config (admin-editable without deployment).
model PlatformConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("platform_config")
}

model AIRuleViolationLog {
  id        String   @id @default(uuid())
  userId    String?
  feature   String
  ruleId    String
  severity  String
  reason    String
  iteration Int      @default(1)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([feature])
  @@index([ruleId])
  @@index([severity])
  @@index([createdAt])
  @@map("ai_rule_violation_logs")
}

model AICustomRule {
  id              String   @id @default(uuid())
  description     String
  prompt          String
  severity        String
  category        String
  blockedPattern  String?
  requiredPattern String?
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([enabled])
  @@index([category])
  @@map("ai_custom_rules")
}

/// Unified mock draft room (AllFantasy Draft Room UI). Distinct from legacy `mock_drafts`.
model MockDraftRoom {
  id             String                @id @default(uuid())
  createdById    String?
  sport          String                @default("NFL")
  numTeams       Int                   @default(12)
  numRounds      Int                   @default(15)
  timerSeconds   Int                   @default(60)
  scoringType    String                @default("PPR")
  rosterSettings Json?
  playerPool     String                @default("all")
  inviteCode     String?               @unique
  status         String                @default("waiting")
  draftOrder     Json?
  settings       Json?
  createdAt      DateTime              @default(now())
  picks          DraftRoomPickRecord[]
  createdBy      AppUser?              @relation("MockDraftRoomCreator", fields: [createdById], references: [id])

  @@index([createdById])
  @@map("mock_draft_rooms")
}

/// Picks for mock/live draft room UI (separate from legacy `draft_picks` / DraftSession engine).
model DraftRoomPickRecord {
  id              String         @id @default(uuid())
  leagueId        String?
  roomId          String?
  round           Int
  pickNumber      Int
  overallPick     Int
  originalOwnerId String
  currentOwnerId  String
  pickedById      String?
  playerId        String?
  playerName      String?
  position        String?
  team            String?
  isTraded        Boolean        @default(false)
  tradeSource     Json?
  autopicked      Boolean        @default(false)
  timestamp       DateTime       @default(now())
  mockRoom        MockDraftRoom? @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([leagueId])
  @@index([roomId])
  @@index([roomId, overallPick])
  @@index([leagueId, overallPick])
  @@map("draft_room_pick_records")
}

model DraftRoomUserQueue {
  id         String   @id @default(uuid())
  userId     String
  sessionKey String
  leagueId   String?
  roomId     String?
  playerIds  Json     @default("[]")
  updatedAt  DateTime @updatedAt
  user       AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sessionKey])
  @@index([sessionKey])
  @@map("draft_room_user_queues")
}

model DraftRoomChatMessage {
  id                String   @id @default(uuid())
  sessionKey        String
  leagueId          String?
  roomId            String?
  userId            String?
  authorDisplayName String?
  authorAvatar      String?
  message           String
  type              String   @default("user")
  createdAt         DateTime @default(now())
  user              AppUser? @relation(fields: [userId], references: [id])

  @@index([sessionKey, createdAt])
  @@map("draft_room_chat_messages")
}

model DraftRoomStateRow {
  id               String    @id
  mode             String
  status           String    @default("waiting")
  currentPick      Int       @default(1)
  currentRound     Int       @default(1)
  currentTeamIndex Int       @default(0)
  timerEndsAt      DateTime?
  timerPaused      Boolean   @default(false)
  pickOrder        Json?
  leagueId         String?
  roomId           String?
  numTeams         Int       @default(12)
  numRounds        Int       @default(15)
  timerSeconds     Int       @default(60)
  updatedAt        DateTime  @updatedAt

  @@index([leagueId])
  @@index([roomId])
  @@map("draft_room_state")
}

model DraftAutopickSetting {
  userId     String
  sessionKey String
  enabled    Boolean  @default(false)
  updatedAt  DateTime @updatedAt
  user       AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, sessionKey])
  @@map("draft_autopick_settings")
}

model SportConfig {
  id                       String   @id @default(cuid())
  sport                    String   @unique
  /// Legacy redraft: weekly | daily | per_match
  lineupFrequency          String
  /// Legacy: points | categories — mirrors defaultScoringSystem when possible
  scoringType              String
  hasIR                    Boolean  @default(true)
  hasTaxi                  Boolean  @default(false)
  hasBye                   Boolean  @default(false)
  maxRosterSize            Int      @default(15)
  defaultPositions         Json
  statCategories           Json
  /// Human-readable label (e.g. "NFL Football")
  displayName              String   @default("")
  /// URL slug — unique when set (seed backfills per sport)
  slug                     String?  @unique
  /// Centralized defaults (see lib/sportConfig)
  defaultScoringSystem     String   @default("points")
  scoringCategories        Json?
  scoringPresets           Json?
  defaultRosterSlots       Json?
  defaultBenchSlots        Int      @default(6)
  defaultIRSlots           Int      @default(0)
  defaultTaxiSlots         Int      @default(0)
  defaultDevySlots         Int      @default(0)
  positionEligibility      Json?
  defaultSeasonWeeks       Int      @default(17)
  defaultPlayoffStartWeek  Int      @default(15)
  defaultPlayoffTeams      Int      @default(4)
  defaultMatchupPeriodDays Int      @default(7)
  lineupLockType           String   @default("per_player_kickoff")
  supportsRedraft          Boolean  @default(true)
  supportsDynasty          Boolean  @default(false)
  supportsKeeper           Boolean  @default(false)
  supportsDevy             Boolean  @default(false)
  supportsC2C              Boolean  @default(false)
  supportsIDP              Boolean  @default(false)
  supportsSuperflex        Boolean  @default(false)
  supportsTEPremium        Boolean  @default(false)
  supportsPPR              Boolean  @default(false)
  supportsCategories       Boolean  @default(false)
  supportsDailyLineups     Boolean  @default(false)
  commissionerSettings     Json?
  aiMetadata               Json?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("sport_configs")
}

model RedraftSeason {
  id                       String                     @id @default(cuid())
  leagueId                 String
  sport                    String
  season                   Int
  status                   String                     @default("setup")
  totalWeeks               Int
  playoffStartWeek         Int
  currentWeek              Int                        @default(0)
  medianGame               Boolean                    @default(false)
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  bestBallOptimizedLineups BestBallOptimizedLineup[]
  guillotineSeason         GuillotineSeason?
  keeperAuditLogs          KeeperAuditLog[]
  keeperEligibilities      KeeperEligibility[]
  keeperPickAdjustments    KeeperPickAdjustment[]
  keeperRecords            KeeperRecord[]
  keeperSelectionSession   KeeperSelectionSession?
  aiLeagueInsights         RedraftAILeagueInsight[]
  redraftLeagueTrades      RedraftLeagueTrade[]
  redraftTransactions      RedraftLeagueTransaction[]
  schedule                 RedraftMatchup[]
  playoffBracket           RedraftPlayoffBracket?
  playoffMatchups          RedraftPlayoffMatchup[]
  playoffRounds            RedraftPlayoffRound[]
  playoffSeeds             RedraftPlayoffSeed[]
  rosters                  RedraftRoster[]
  league                   League                     @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  redraftTradeProposals    RedraftTradeProposal[]
  redraftWaiverClaims      RedraftWaiverClaim[]

  @@index([leagueId])
  @@map("redraft_seasons")
}

model RedraftRoster {
  id                       String                     @id @default(cuid())
  seasonId                 String
  leagueId                 String
  ownerId                  String
  ownerName                String
  teamName                 String?
  avatarUrl                String?
  wins                     Int                        @default(0)
  losses                   Int                        @default(0)
  ties                     Int                        @default(0)
  pointsFor                Float                      @default(0)
  pointsAgainst            Float                      @default(0)
  streak                   String?
  playoffSeed              Int?
  faabBalance              Float?                     @default(100)
  waiverPriority           Int                        @default(0)
  isEliminated             Boolean                    @default(false)
  bestBallOptimizedLineups BestBallOptimizedLineup[]
  c2cPlayerStates          C2CPlayerState[]
  devyDevySlots            DevyDevySlot[]
  devyPlayerStates         DevyPlayerState[]
  devyRookieTransitions    DevyRookieTransition[]
  devyTaxiSlots            DevyTaxiSlot[]
  guillotineSurvivalLogs   GuillotineSurvivalLog[]
  idpCapProjections        IDPCapProjection[]
  idpDeadMoneyHits         IDPDeadMoney[]             @relation("RedraftRosterIdpDeadMoney")
  idpSalaryRecords         IDPSalaryRecord[]
  keeperRecords            KeeperRecord[]
  aiRosterInsights         RedraftAIRosterInsight[]
  tradesProposed           RedraftLeagueTrade[]       @relation("RedraftTradeProposer")
  tradesReceived           RedraftLeagueTrade[]       @relation("RedraftTradeReceiver")
  transactions             RedraftLeagueTransaction[]
  awayMatchups             RedraftMatchup[]           @relation("RedraftAwayRoster")
  homeMatchups             RedraftMatchup[]           @relation("RedraftHomeRoster")
  playoffAwayMatchups      RedraftPlayoffMatchup[]    @relation("RedraftPlayoffAwayRoster")
  playoffHomeMatchups      RedraftPlayoffMatchup[]    @relation("RedraftPlayoffHomeRoster")
  playoffWinningMatchups   RedraftPlayoffMatchup[]    @relation("RedraftPlayoffWinnerRoster")
  playoffSeeds             RedraftPlayoffSeed[]
  players                  RedraftRosterPlayer[]
  season                   RedraftSeason              @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  tradeAssetsFrom          RedraftTradeAsset[]        @relation("RedraftTradeAssetFrom")
  tradeAssetsTo            RedraftTradeAsset[]        @relation("RedraftTradeAssetTo")
  tradeProposalsMade       RedraftTradeProposal[]     @relation("RedraftTradeProposalProposer")
  tradeProposalsReceived   RedraftTradeProposal[]     @relation("RedraftTradeProposalReceiver")
  tradeProposalVotes       RedraftTradeVote[]
  waiverClaims             RedraftWaiverClaim[]

  @@unique([seasonId, ownerId])
  @@index([seasonId])
  @@map("redraft_rosters")
}

model RedraftRosterPlayer {
  id              String        @id @default(cuid())
  rosterId        String
  playerId        String
  playerName      String
  position        String
  team            String?
  sport           String
  slotType        String
  isLocked        Boolean       @default(false)
  injuryStatus    String?
  byeWeek         Int?
  addedAt         DateTime      @default(now())
  droppedAt       DateTime?
  acquisitionType String        @default("drafted")
  isKept          Boolean       @default(false)
  roster          RedraftRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  @@index([rosterId])
  @@index([playerId])
  @@map("redraft_roster_players")
}

model RedraftMatchup {
  id               String            @id @default(cuid())
  seasonId         String
  leagueId         String
  week             Int
  type             String            @default("regular")
  homeRosterId     String
  awayRosterId     String?
  homeScore        Float             @default(0)
  awayScore        Float             @default(0)
  homeProjected    Float?
  awayProjected    Float?
  homeWinPct       Float?
  awayWinPct       Float?
  status           String            @default("scheduled")
  isMedianMatchup  Boolean           @default(false)
  medianScore      Float?
  lineupSnapshots  Json?
  c2cMatchupScores C2CMatchupScore[]
