  @@index([createdByUserId])
  @@index([createdByUserId, type, createdAt])
  @@index([type])
  @@index([type, targetId])
  @@index([status])
  @@index([status, expiresAt])
  @@index([token])
  @@map("invite_links")
}

model InviteLinkEvent {
