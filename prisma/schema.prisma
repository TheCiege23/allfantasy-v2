/// League hierarchy — divisions (tiers) within a league for promotion/relegation.
model LeagueDivision {
  id         String   @id @default(cuid())
  leagueId   String   @db.VarChar(64)
  tierLevel  Int      @default(1)
  sport      String   @db.VarChar(16)
  name       String?  @db.VarChar(128)

  league League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  teams  LeagueTeam[]

  @@unique([leagueId, tierLevel])
  @@index([leagueId])
  @@map("league_divisions")
}

/// Promotion/relegation rule: how many teams move between two tiers at season end.
model PromotionRule {
  id             String   @id @default(cuid())
  leagueId       String   @db.VarChar(64)
  fromTierLevel  Int      @default(1)
  toTierLevel    Int      @default(2)
  promoteCount   Int      @default(1)
  relegateCount  Int      @default(1)

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, fromTierLevel, toTierLevel])
  @@index([leagueId])
  @@map("promotion_rules")
}

model TeamPerformance {
  id        String   @id @default(uuid())
  teamId    String
  week      Int
  season    Int
  points    Float
  opponent  String?
  result    String?
  data      Json?
  createdAt DateTime @default(now())

  team LeagueTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, season, week])
  @@index([teamId, season])
  @@map("team_performances")
}

model LeagueAuth {
  id          String   @id @default(uuid())
  userId      String
  platform    String
  apiKey      String?  @db.Text
  oauthToken  String?  @db.Text
  oauthSecret String?  @db.Text
  espnSwid    String?
  espnS2      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
  @@map("league_auths")
}

model LeagueWaiverSettings {
  id                  String    @id @default(uuid())
  leagueId            String    @unique
  league              League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  waiverType          String    @default("standard")
  processingDayOfWeek Int?
  processingTimeUtc   String?
  claimLimitPerPeriod Int?
  faabBudget          Int?
  faabResetDate       DateTime?
  tiebreakRule        String?
  lockType            String?
  instantFaAfterClear Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("league_waiver_settings")
}

// ========== Guillotine League Engine (PROMPT 332) ==========

/// Guillotine league config (1:1 with League when leagueVariant/format is guillotine).
model GuillotineLeagueConfig {
  id                    String   @id @default(uuid())
  leagueId              String   @unique
  league                League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  /// First scoring period when elimination runs (1-based).
  eliminationStartWeek  Int      @default(1)
  /// Last scoring period for elimination (e.g. week 17); after this, no more chops.
  eliminationEndWeek    Int?
  /// Number of teams chopped per period (1 = classic).
  teamsPerChop          Int      @default(1)
  /// When to run chop: immediate | after_stat_corrections | custom_cutoff
  correctionWindow      String   @default("after_stat_corrections") @db.VarChar(32)
  /// Custom cutoff: ISO weekday (1–7) and/or time UTC (e.g. "Wednesday 14:00").
  customCutoffDayOfWeek Int?
  customCutoffTimeUtc   String?  @db.VarChar(16)
  /// Hours after period end to wait for stat corrections (if correctionWindow = after_stat_corrections).
  statCorrectionHours   Int?     @default(48)
  /// Tiebreaker order: season_points | previous_period | draft_slot | commissioner | random
  tiebreakerOrder       Json?
  /// Danger tier: points margin below lowest projected to count as "in danger".
  dangerMarginPoints    Float?   @default(10)
  /// Release chopped roster to waivers: immediate | next_waiver_run | custom_time
  rosterReleaseTiming   String   @default("next_waiver_run") @db.VarChar(32)
  /// Allow commissioner to override who is chopped (with audit).
  commissionerOverride  Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("guillotine_league_configs")
}

/// Per-roster chop state (eliminated at which period).
model GuillotineRosterState {
  id              String    @id @default(uuid())
  leagueId        String    @db.VarChar(64)
  rosterId        String    @db.VarChar(64)
  choppedAt       DateTime?
  choppedInPeriod Int?
  choppedReason   String?   @db.VarChar(128)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([rosterId])
  @@index([leagueId])
  @@index([leagueId, choppedInPeriod])
  @@map("guillotine_roster_states")
}

/// Period score per roster for guillotine (lowest-score elimination).
model GuillotinePeriodScore {
  id                 String   @id @default(uuid())
  leagueId           String   @db.VarChar(64)
  rosterId           String   @db.VarChar(64)
  weekOrPeriod       Int
  season             Int?
  periodPoints       Float    @default(0)
  seasonPointsCumul  Float    @default(0)
  createdAt          DateTime @default(now())

  @@unique([leagueId, rosterId, weekOrPeriod])
  @@index([leagueId, weekOrPeriod])
  @@index([leagueId, rosterId])
  @@map("guillotine_period_scores")
}

/// Append-only event log: chop, commissioner_override, media events.
model GuillotineEventLog {
  id        String   @id @default(cuid())
  leagueId  String   @db.VarChar(64)
  eventType String   @db.VarChar(64)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([leagueId])
  @@index([leagueId, eventType])
  @@index([createdAt])
  @@map("guillotine_event_logs")
}

// ========== Salary Cap League Engine (PROMPT 339) ==========

/// Salary Cap league config (1:1 with League when leagueVariant is salary_cap).
model SalaryCapLeagueConfig {
  id                      String    @id @default(uuid())
  leagueId                String    @unique @db.VarChar(64)
  league                  League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  mode                    String    @default("dynasty")   @db.VarChar(24)   // dynasty | bestball
  startupCap              Int       @default(250)
  capGrowthPercent        Float     @default(5)
  contractMinYears        Int       @default(1)
  contractMaxYears        Int       @default(4)
  rookieContractYears     Int       @default(3)
  minimumSalary           Int       @default(1)
  deadMoneyEnabled        Boolean   @default(true)
  deadMoneyPercentPerYear Float     @default(25)
  rolloverEnabled         Boolean   @default(true)
  rolloverMax             Int       @default(25)
  capFloorEnabled         Boolean   @default(false)
  capFloorAmount          Int?
  extensionsEnabled       Boolean   @default(true)
  franchiseTagEnabled     Boolean   @default(true)
  rookieOptionEnabled     Boolean   @default(false)
  startupDraftType        String    @default("auction")  @db.VarChar(24)   // auction | snake | linear
  futureDraftType         String    @default("linear")   @db.VarChar(24)   // linear | auction | weighted_lottery
  auctionHoldback         Int       @default(50)
  weightedLotteryEnabled  Boolean   @default(false)
  lotteryOddsConfig       Json?     // e.g. { nonPlayoff: number[], playoff: number[] } or seed->weight
  compPickEnabled         Boolean   @default(false)
  compPickFormula         Json?
  offseasonPhase          String?   @db.VarChar(32)      // lock | expiration | rollover | extension | tag | draft | fa_open | in_season
  offseasonPhaseEndsAt     DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  ledgers    SalaryCapTeamLedger[]
  contracts  PlayerContract[]
  eventLog   SalaryCapEventLog[]

  @@map("salary_cap_league_configs")
}

/// Per-roster, per-cap-year cap state (cap hit total, rollover, etc.).
model SalaryCapTeamLedger {
  id              String   @id @default(uuid())
  leagueId        String   @db.VarChar(64)
  configId        String
  config          SalaryCapLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  rosterId        String   @db.VarChar(64)
  capYear         Int      // season year (e.g. 2025)
  totalCapHit     Int      @default(0)
  deadMoneyHit    Int      @default(0)
  rolloverUsed    Int      @default(0)
  capSpace        Int      @default(0)   // derived: cap - totalCapHit - deadMoneyHit + rolloverUsed (stored for quick read)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([configId, rosterId, capYear])
  @@index([leagueId, capYear])
  @@index([rosterId, capYear])
  @@map("salary_cap_team_ledgers")
}

/// Player contract: roster + player + salary + years. One row per active/expired contract instance.
model PlayerContract {
  id                String   @id @default(uuid())
  leagueId          String   @db.VarChar(64)
  configId          String
  config            SalaryCapLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  rosterId          String   @db.VarChar(64)
  playerId          String   @db.VarChar(64)
  playerName        String?  @db.VarChar(128)
  position          String?  @db.VarChar(16)
  salary            Int      // annual salary (cap hit for standard contracts)
  yearsTotal        Int
  yearSigned        Int      // cap year when signed
  contractYear      Int      @default(1)   // current year of contract (1..yearsTotal)
  status            String   @default("active") @db.VarChar(24)  // active | expired | cut | traded | tagged | option_exercised
  source            String   @db.VarChar(32)   // startup_auction | rookie_draft | waiver_bid | extension | franchise_tag | trade
  franchiseTagAt    DateTime?
  optionExercisedAt DateTime?
  cutAt             DateTime?
  deadMoneyRemaining Json?   // { capYear: amount } for future years
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([leagueId, rosterId])
  @@index([leagueId, playerId])
  @@index([configId, yearSigned])
  @@index([rosterId, status])
  @@map("player_contracts")
}

/// Append-only event log for salary cap (contract signed, cut, extension, tag, rollover, etc.).
model SalaryCapEventLog {
  id        String   @id @default(cuid())
  leagueId  String   @db.VarChar(64)
  configId  String
  config    SalaryCapLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  eventType String   @db.VarChar(64)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([leagueId, eventType])
  @@index([createdAt])
  @@map("salary_cap_event_logs")
}

/// Weighted lottery result (deterministic, auditable). One row per league per season.
model SalaryCapLotteryResult {
  id          String   @id @default(uuid())
  leagueId    String   @db.VarChar(64)
  configId    String
  capYear     Int
  seed        String?  @db.VarChar(64)   // audit: random seed used
  order       Json     // [ { slot: number, rosterId: string, originalOrder: number } ]
  createdAt   DateTime @default(now())

  @@unique([configId, capYear])
  @@index([leagueId, capYear])
  @@map("salary_cap_lottery_results")
}

// ========== Survivor League Engine (PROMPT 346) ==========

/// Survivor league config (1:1 with League when leagueVariant is survivor).
model SurvivorLeagueConfig {
  id                    String   @id @default(uuid())
  leagueId              String   @unique @db.VarChar(64)
  league                League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  mode                  String   @default("redraft") @db.VarChar(24)   // redraft | bestball
  tribeCount            Int      @default(4)
  tribeSize             Int      @default(4)   // target per tribe (tribeCount * tribeSize <= leagueSize)
  tribeFormation        String   @default("random") @db.VarChar(24)   // random | commissioner
  mergeTrigger          String   @default("week") @db.VarChar(24)     // week | player_count
  mergeWeek             Int?     // when mergeTrigger = week
  mergePlayerCount      Int?     // when mergeTrigger = player_count
  juryStartAfterMerge   Int      @default(1)   // first N vote-outs after merge are jury
  exileReturnEnabled    Boolean  @default(false)
  exileReturnTokens     Int      @default(4)
  idolCount             Int      @default(2)
  idolPowerPool         Json?    // array of power type ids enabled
  tribeShuffleEnabled   Boolean  @default(false)
  tribeShuffleConsecutiveLosses Int?  // trigger after N consecutive council losses
  tribeShuffleImbalanceThreshold Float?  // e.g. tribe size diff
  voteDeadlineDayOfWeek Int?     // 1-7
  voteDeadlineTimeUtc   String?  @db.VarChar(16)
  selfVoteDisallowed    Boolean  @default(true)
  tribalCouncilDayOfWeek Int?
  tribalCouncilTimeUtc  String?  @db.VarChar(16)
  minigameFrequency     String   @default("none") @db.VarChar(24)   // none | weekly | custom
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tribes        SurvivorTribe[]
  idols         SurvivorIdol[]
  councils      SurvivorTribalCouncil[]
  exileLeague   SurvivorExileLeague?
  auditLog      SurvivorAuditLog[]
  challenges    SurvivorChallenge[]

  @@map("survivor_league_configs")
}

/// Tribe within a Survivor league.
model SurvivorTribe {
  id         String   @id @default(uuid())
  leagueId   String   @db.VarChar(64)
  configId   String
  config     SurvivorLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  name       String   @db.VarChar(128)
  slotIndex  Int      @default(0)   // 0-based order
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  members     SurvivorTribeMember[]
  chatMembers SurvivorTribeChatMember[]
  councils    SurvivorTribalCouncil[]  // councils this tribe attended (pre-merge)

  @@unique([configId, slotIndex])
  @@index([leagueId])
  @@map("survivor_tribes")
}

/// Tribe membership: roster in a tribe. Pre-merge only; merge has no tribes.
model SurvivorTribeMember {
  id        String   @id @default(uuid())
  tribeId   String
  tribe     SurvivorTribe @relation(fields: [tribeId], references: [id], onDelete: Cascade)
  rosterId  String   @db.VarChar(64)
  isLeader  Boolean  @default(false)
  joinedAt  DateTime @default(now())

  @@unique([tribeId, rosterId])
  @@index([rosterId])
  @@index([tribeId])
  @@map("survivor_tribe_members")
}

/// Hidden idol: player-bound, one-time use. Ownership = current controlling rosterId.
model SurvivorIdol {
  id          String   @id @default(uuid())
  leagueId    String   @db.VarChar(64)
  configId    String
  config      SurvivorLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  rosterId    String   @db.VarChar(64)   // current owner (controls idol)
  playerId    String   @db.VarChar(64)   // bound to this player (for transfer on trade/claim/steal)
  powerType   String   @db.VarChar(64)
  status      String   @default("hidden") @db.VarChar(24)   // hidden | revealed | used | expired
  assignedAt  DateTime @default(now())
  usedAt      DateTime?
  expiredAt   DateTime?
  validUntilPhase String? @db.VarChar(32)   // e.g. merge = invalid after merge
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ledgerEntries SurvivorIdolLedgerEntry[]

  @@index([leagueId, rosterId])
  @@index([leagueId, playerId])
  @@index([configId, status])
  @@map("survivor_idols")
}

/// Chain-of-custody for idols: assignment, transfer, use, expiry.
model SurvivorIdolLedgerEntry {
  id        String   @id @default(cuid())
  leagueId  String   @db.VarChar(64)
  idolId    String
  idol      SurvivorIdol @relation(fields: [idolId], references: [id], onDelete: Cascade)
  eventType String   @db.VarChar(32)   // assigned | transferred | used | expired
  fromRosterId String? @db.VarChar(64)
  toRosterId   String? @db.VarChar(64)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([leagueId, eventType])
  @@index([idolId])
  @@map("survivor_idol_ledger_entries")
}

/// Tribal Council: one per week (or period). Pre-merge = one tribe attends; merge = all remaining.
model SurvivorTribalCouncil {
  id               String   @id @default(uuid())
  leagueId         String   @db.VarChar(64)
  configId         String
  config           SurvivorLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  week             Int
  phase            String   @db.VarChar(24)   // pre_merge | merge
  attendingTribeId String?  @db.VarChar(64)   // pre_merge: which tribe
  tribe            SurvivorTribe? @relation(fields: [attendingTribeId], references: [id], onDelete: SetNull)
  voteDeadlineAt   DateTime
  closedAt         DateTime?
  eliminatedRosterId String? @db.VarChar(64)
  tieBreakSeasonPoints Json?  // snapshot of season points for tie-break
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  votes SurvivorVote[]

  @@unique([configId, week])
  @@index([leagueId, week])
  @@map("survivor_tribal_councils")
}

/// Single vote in a Tribal Council (private ballot).
model SurvivorVote {
  id         String   @id @default(cuid())
  councilId  String
  council    SurvivorTribalCouncil @relation(fields: [councilId], references: [id], onDelete: Cascade)
  voterRosterId String @db.VarChar(64)
  targetRosterId String @db.VarChar(64)
  createdAt  DateTime @default(now())

  @@unique([councilId, voterRosterId])
  @@index([councilId])
  @@map("survivor_votes")
}

/// Link main Survivor league to its Exile Island league.
model SurvivorExileLeague {
  id             String   @id @default(uuid())
  mainLeagueId   String   @unique @db.VarChar(64)
  configId       String   @unique
  config         SurvivorLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  exileLeagueId  String   @db.VarChar(64)   // separate League row (exile island)
  createdAt      DateTime @default(now())

  @@index([exileLeagueId])
  @@map("survivor_exile_leagues")
}

/// Exile token balance per roster (in exile league). Reset when Boss wins.
model SurvivorExileToken {
  id              String   @id @default(uuid())
  exileLeagueId   String   @db.VarChar(64)
  rosterId        String   @db.VarChar(64)   // roster in exile league
  tokens          Int      @default(0)
  lastAwardedWeek Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([exileLeagueId, rosterId])
  @@index([exileLeagueId])
  @@map("survivor_exile_tokens")
}

/// Jury membership: rosterId = main league roster that was voted out and is now on jury.
model SurvivorJuryMember {
  id         String   @id @default(cuid())
  leagueId   String   @db.VarChar(64)
  rosterId   String   @db.VarChar(64)
  votedOutWeek Int
  joinedAt   DateTime @default(now())

  @@unique([leagueId, rosterId])
  @@index([leagueId])
  @@map("survivor_jury_members")
}

/// Survivor audit log: votes, idol use, shuffle, elimination, overrides.
model SurvivorAuditLog {
  id        String   @id @default(cuid())
  leagueId  String   @db.VarChar(64)
  configId  String
  config    SurvivorLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  eventType String   @db.VarChar(64)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([leagueId, eventType])
  @@index([createdAt])
  @@map("survivor_audit_logs")
}

/// Mini-game / challenge definition per week.
model SurvivorChallenge {
  id          String   @id @default(uuid())
  leagueId    String   @db.VarChar(64)
  configId    String
  config      SurvivorLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  week        Int
  challengeType String @db.VarChar(64)   // score_prediction | over_under | player_prop | tribe_vs | immunity_auction | puzzle | trivia
  configJson  Json?    // type-specific params (line, options, reward type)
  lockAt      DateTime?
  resultJson  Json?    // resolved outcome and rewards
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions SurvivorChallengeSubmission[]

  @@unique([configId, week, challengeType])
  @@index([leagueId, week])
  @@map("survivor_challenges")
}

/// One submission per roster (or tribe) per challenge.
model SurvivorChallengeSubmission {
  id          String   @id @default(cuid())
  challengeId String
  challenge   SurvivorChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  rosterId    String?  @db.VarChar(64)
  tribeId     String?  @db.VarChar(64)
  submission  Json     // type-specific (e.g. over/under choice, predicted score)
  submittedAt DateTime @default(now())

  @@unique([challengeId, rosterId], name: "uniq_challenge_roster")
  @@unique([challengeId, tribeId], name: "uniq_challenge_tribe")
  @@index([challengeId])
  @@map("survivor_challenge_submissions")
}

/// Tribe-scoped chat: membership tracked here; messages can use LeagueChatMessage with source = tribe_<tribeId> or separate table.
/// For private tribe chat we use source on LeagueChatMessage = 'tribe_<tribeId>' and filter by roster membership.
model SurvivorTribeChatMember {
  id        String   @id @default(uuid())
  tribeId   String
  tribe     SurvivorTribe @relation(fields: [tribeId], references: [id], onDelete: Cascade)
  rosterId  String   @db.VarChar(64)
  userId    String?  @db.VarChar(64)   // for AI host: optional system userId
  isAiHost  Boolean  @default(false)
  joinedAt  DateTime @default(now())

  @@unique([tribeId, rosterId], name: "uniq_tribe_roster")
  @@unique([tribeId, userId], name: "uniq_tribe_user")
  @@index([tribeId])
  @@map("survivor_tribe_chat_members")
}

// ========== Big Brother League Engine (PROMPT 2/6) ==========

/// Big Brother league config: HOH, nomination, veto, vote, eviction, jury, finale settings.
model BigBrotherLeagueConfig {
  id                        String   @id @default(uuid())
  leagueId                  String   @unique @db.VarChar(64)
  league                    League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  /// HOH challenge day of week (1-7) and time UTC for when HOH runs.
  hohChallengeDayOfWeek     Int?     // 1-7
  hohChallengeTimeUtc       String?  @db.VarChar(16)
  /// Nomination deadline (day of week 1-7, time UTC) for HOH to submit noms.
  nominationDeadlineDayOfWeek Int?
  nominationDeadlineTimeUtc String?  @db.VarChar(16)
  /// Veto draw day/time (when random veto players are selected).
  vetoDrawDayOfWeek         Int?
  vetoDrawTimeUtc           String?  @db.VarChar(16)
  /// Veto decision deadline (veto winner must use or leave same).
  vetoDecisionDeadlineDayOfWeek Int?
  vetoDecisionDeadlineTimeUtc   String?  @db.VarChar(16)
  /// Replacement nominee deadline if veto used (HOH must name replacement).
  replacementNomineeDeadlineDayOfWeek Int?
  replacementNomineeDeadlineTimeUtc   String?  @db.VarChar(16)
  /// Eviction vote window: open/close day and time UTC.
  evictionVoteOpenDayOfWeek  Int?
  evictionVoteOpenTimeUtc    String?  @db.VarChar(16)
  evictionVoteCloseDayOfWeek Int?
  evictionVoteCloseTimeUtc   String?  @db.VarChar(16)
  /// Final nominee count on ballot (always 2 for classic).
  finalNomineeCount         Int      @default(2)
  /// Veto competitor count (HOH + 2 noms + this many random = default 6 total).
  vetoCompetitorCount       Int      @default(6)
  /// Consecutive HOH allowed: false = cannot win HOH back-to-back.
  consecutiveHohAllowed     Boolean  @default(false)
  /// HOH votes only in tie (true = default).
  hohVotesOnlyInTie         Boolean  @default(true)
  /// Jury start: after_eliminations | when_remaining | fixed_week
  juryStartMode             String   @default("after_eliminations") @db.VarChar(32)
  juryStartAfterEliminations Int?    // when mode = after_eliminations
  juryStartWhenRemaining    Int?     // when mode = when_remaining (e.g. 7 players left)
  juryStartWeek             Int?     // when mode = fixed_week
  /// Finale format: final_2 | final_3
  finaleFormat               String   @default("final_2") @db.VarChar(16)
  /// Waiver release after eviction: immediate | next_waiver_run | faab_window
  waiverReleaseTiming       String   @default("next_waiver_run") @db.VarChar(32)
  /// Public vote totals: exact | evicted_only
  publicVoteTotalsVisibility String  @default("evicted_only") @db.VarChar(24)
  /// Challenge mode: ai_theme | deterministic_score | hybrid
  challengeMode             String   @default("hybrid") @db.VarChar(32)
  /// Anti-collusion logging on/off.
  antiCollusionLogging       Boolean  @default(true)
  /// Inactive player handling: none | replacement_after_n_weeks | commissioner_only
  inactivePlayerHandling    String   @default("commissioner_only") @db.VarChar(32)
  /// Auto-nomination fallback if HOH times out: lowest_season_points | random | commissioner
  autoNominationFallback    String   @default("lowest_season_points") @db.VarChar(32)
  /// Eviction tie-break when vote is tied: hoh_vote | season_points | random | commissioner
  evictionTieBreakMode       String   @default("season_points") @db.VarChar(24)
  /// When true, automation does not advance week (commissioner can still force).
  weekProgressionPaused     Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  cycles   BigBrotherCycle[]
  jury     BigBrotherJuryMember[]
  auditLog BigBrotherAuditLog[]

  @@map("big_brother_league_configs")
}

/// One eviction cycle per week: HOH, nominees, veto, vote, eviction.
/// PROMPT 3: phase drives week state machine (HOH_OPEN .. EVICTION_RESOLVED, JURY_UPDATE, RESET_NEXT_WEEK).
model BigBrotherCycle {
  id                    String   @id @default(uuid())
  leagueId              String   @db.VarChar(64)
  configId              String
  config                BigBrotherLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  week                  Int
  /// Week state machine: HOH_OPEN | HOH_LOCKED | NOMINATION_OPEN | NOMINATION_LOCKED | VETO_DRAW | VETO_CHALLENGE_OPEN | VETO_DECISION_OPEN | REPLACEMENT_NOMINATION_OPEN | VOTING_OPEN | VOTING_LOCKED | EVICTION_RESOLVED | JURY_UPDATE | RESET_NEXT_WEEK
  phase                 String   @default("HOH_OPEN") @db.VarChar(40)
  hohRosterId           String?  @db.VarChar(64)
  nominee1RosterId      String?  @db.VarChar(64)
  nominee2RosterId      String?  @db.VarChar(64)
  vetoWinnerRosterId    String?  @db.VarChar(64)
  vetoParticipantRosterIds Json?  // [rosterId,...] HOH + 2 noms + random (auditable)
  vetoUsed              Boolean  @default(false)
  vetoSavedRosterId     String?  @db.VarChar(64)   // which nominee was saved (if veto used)
  replacementNomineeRosterId String? @db.VarChar(64)
  evictedRosterId       String?  @db.VarChar(64)
  voteDeadlineAt        DateTime?
  voteOpenedAt          DateTime?
  closedAt              DateTime?
  tieBreakSeasonPoints  Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  votes BigBrotherEvictionVote[]

  @@unique([configId, week])
  @@index([leagueId, week])
  @@map("big_brother_cycles")
}

/// Private eviction vote: one per voter per cycle (last before deadline counts).
model BigBrotherEvictionVote {
  id          String   @id @default(cuid())
  cycleId     String
  cycle       BigBrotherCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  voterRosterId String @db.VarChar(64)
  targetRosterId String @db.VarChar(64)
  createdAt   DateTime @default(now())

  @@unique([cycleId, voterRosterId])
  @@index([cycleId])
  @@map("big_brother_eviction_votes")
}

/// Jury member: eliminated roster that votes at finale.
model BigBrotherJuryMember {
  id             String   @id @default(cuid())
  leagueId       String   @db.VarChar(64)
  configId       String
  config         BigBrotherLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  rosterId       String   @db.VarChar(64)
  evictedWeek    Int
  joinedAt       DateTime @default(now())

  @@unique([leagueId, rosterId])
  @@index([leagueId])
  @@map("big_brother_jury_members")
}

/// Finale vote: jury votes for winner (one per jury member).
model BigBrotherFinaleVote {
  id             String   @id @default(cuid())
  leagueId       String   @db.VarChar(64)
  juryRosterId   String   @db.VarChar(64)
  targetRosterId String   @db.VarChar(64)
  createdAt      DateTime @default(now())

  @@unique([leagueId, juryRosterId])
  @@index([leagueId])
  @@map("big_brother_finale_votes")
}

/// Big Brother audit log: HOH, noms, veto, votes, eviction, jury.
model BigBrotherAuditLog {
  id        String   @id @default(cuid())
  leagueId  String   @db.VarChar(64)
  configId  String
  config    BigBrotherLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  eventType String   @db.VarChar(64)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([leagueId, eventType])
  @@index([createdAt])
  @@map("big_brother_audit_logs")
}

// ========== Zombie League Engine (PROMPT 353) ==========

/// Zombie universe: groups multiple leagues into levels (e.g. Gamma, Beta, Alpha).
model ZombieUniverse {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(128)
  sport     String   @default("NFL") @db.VarChar(12)
  settings  Json?    // leagueCount, levelNames, teamsPerLeague, movementRules, tieBreakers
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  levels  ZombieUniverseLevel[]
  leagues ZombieLeague[]
  audit   ZombieAuditLog[]

  @@map("zombie_universes")
}

/// Level within a Zombie universe (e.g. Gamma, Beta, Alpha).
model ZombieUniverseLevel {
  id          String   @id @default(uuid())
  universeId  String
  universe    ZombieUniverse @relation(fields: [universeId], references: [id], onDelete: Cascade)
  name        String   @db.VarChar(64)
  rankOrder   Int      @default(1)   // 1 = bottom (Gamma), higher = top (Alpha)
  leagueCount Int     @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leagues ZombieLeague[]

  @@unique([universeId, rankOrder])
  @@index([universeId])
  @@map("zombie_universe_levels")
}

/// Links a League to a Zombie universe and level. One league belongs to at most one universe.
model ZombieLeague {
  id          String   @id @default(uuid())
  universeId  String
  universe    ZombieUniverse @relation(fields: [universeId], references: [id], onDelete: Cascade)
