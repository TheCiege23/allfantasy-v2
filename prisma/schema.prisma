  serumAwardHighScore     Boolean  @default(true)
  serumAwardOnBashMaul    Boolean  @default(true)
  serumUseBeforeLastStarter Boolean @default(true)
  weaponScoreThresholds   Json?    // e.g. [ { minPoints: 120, weaponType: "base" } ]
  weaponTopTwoActive      Boolean  @default(true)
  bombOneTimeOverride     Boolean  @default(false)
  ambushCountPerWeek      Int      @default(1)
  ambushRemapMatchup      Boolean  @default(true)
  noWaiverFreeAgency      Boolean  @default(true)
