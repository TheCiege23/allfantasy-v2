  importPointsAgainst                   Float?                                 @map("import_points_against")
  /// Commissioner-configurable week after which unused idols expire (null = Final 5 default).
  survivorIdolExpiryWeek                Int?
  /// Short join code for native AllFantasy-created leagues (manual platform).
  joinCode                              String?                                @db.VarChar(16)
  /// Commissioner UI language (e.g. en, es).
