model AiCommissionerActionLog {
  actionId     String      @id @default(uuid())
  leagueId     String
  sport        LeagueSport @default(NFL)
  actionType   String      @db.VarChar(48)
  source       String      @db.VarChar(48)
  summary      String      @db.Text
  relatedAlertId String?   @db.VarChar(128)
  createdAt    DateTime    @default(now())

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId, createdAt(sort: Desc)])
  @@index([leagueId, actionType])
