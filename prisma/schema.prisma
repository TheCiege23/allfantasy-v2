  roster    RedraftRoster?   @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  contestId String?
  contest   BestBallContest? @relation(fields: [contestId], references: [id], onDelete: Cascade)
  entryId   String?
  entry     BestBallEntry?   @relation(fields: [entryId], references: [id], onDelete: Cascade)

  week            Int
  scoringPeriod   String    @default("weekly")
  starterIds      String[]
  benchIds        String[]
  totalPoints     Float     @default(0)
  lineupBreakdown Json
  alternateExists Boolean   @default(false)
  alternateLineup Json?
  optimizerLog    Json?
  isFinalized     Boolean   @default(false)
  finalizedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([seasonId, week])
  @@index([rosterId])
  @@index([contestId, entryId])
  @@map("best_ball_optimized_lineups")
}

model BestBallContest {
  id                 String    @id @default(cuid())
  name               String
  sport              String
  variant            String    @default("tournament")
  status             String    @default("open")
  podSize            Int       @default(12)
  rosterSize         Int       @default(18)
  rounds             Int       @default(1)
  advancersPerPod    Int       @default(1)
  draftType          String    @default("snake")
  draftSpeed         String    @default("slow")
  entryType          String    @default("single")
  maxEntriesPerUser  Int?
  totalEntries       Int?
  scoringPeriod      String    @default("weekly")
  cumulativeScoring  Boolean   @default(true)
  resetBetweenRounds Boolean   @default(false)
  draftStartsAt      DateTime?
  contestStartsAt    DateTime?
  contestEndsAt      DateTime?

  pods             BestBallPod[]
  entries          BestBallEntry[]
  leagues          League[]                  @relation("LeagueBestBallContest")
  optimizedLineups BestBallOptimizedLineup[]
  aiInsights       BestBallAIInsight[]

  createdAt DateTime @default(now())

  @@index([sport, status])
  @@map("best_ball_contests")
}

model BestBallPod {
  id             String          @id @default(cuid())
  contestId      String
  contest        BestBallContest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  roundNumber    Int             @default(1)
  podNumber      Int
  name           String?
  status         String          @default("forming")
  draftSessionId String?
  advancers      String[]
  entries        BestBallEntry[]

  createdAt DateTime @default(now())

  @@unique([contestId, roundNumber, podNumber])
  @@index([contestId])
  @@map("best_ball_pods")
}

model BestBallEntry {
  id        String          @id @default(cuid())
  contestId String
  contest   BestBallContest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  podId     String?
  pod       BestBallPod?    @relation(fields: [podId], references: [id], onDelete: SetNull)

  userId       String
  entryName    String?
  entryNumber  Int     @default(1)
  podRank      Int?
  overallRank  Int?
  currentRound Int     @default(1)
  totalPoints  Float   @default(0)
  isEliminated Boolean @default(false)
  hasAdvanced  Boolean @default(false)
  roster       Json?
  weeklyScores Json?

  optimizedLineups BestBallOptimizedLineup[]

  createdAt DateTime @default(now())

  @@index([contestId, podId])
  @@index([userId])
  @@map("best_ball_entries")
}

model BestBallRosterValidation {
  id             String   @id @default(cuid())
  leagueId       String
  league         League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  seasonId       String?
  contestId      String?
  rosterId       String?
  entryId        String?
  isValid        Boolean
  warnings       Json
  criticalErrors Json
  checkedAt      DateTime @default(now())

  @@index([seasonId, rosterId])
  @@index([contestId, entryId])
  @@map("best_ball_roster_validations")
}

/// Best ball AI output (AF Commissioner Subscription tier).
model BestBallAIInsight {
  id          String           @id @default(cuid())
  leagueId    String?
  league      League?          @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  contestId   String?
  contest     BestBallContest? @relation(fields: [contestId], references: [id], onDelete: Cascade)
  rosterId    String?
  entryId     String?
  week        Int?
  type        String
  content     Json
  narrative   String?
  generatedAt DateTime         @default(now())

  @@index([leagueId, type])
  @@index([contestId, type])
  @@map("best_ball_ai_insights")
}

// ========== Guillotine survival engine (elimination seasons) ==========

model GuillotineSeason {
  id              String         @id @default(cuid())
  leagueId        String
  league          League         @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  redraftSeasonId String?        @unique
  redraftSeason   RedraftSeason? @relation(fields: [redraftSeasonId], references: [id], onDelete: SetNull)

  sport                 String
  season                Int
  status                String  @default("setup")
  totalTeamsStarted     Int
  currentTeamsActive    Int
  currentScoringPeriod  Int     @default(0)
  isInFinalStage        Boolean @default(false)
  finalStageStartPeriod Int?

  eliminations   GuillotineElimination[]
  survivalLog    GuillotineSurvivalLog[]
  waiverReleases GuillotineWaiverRelease[]
  aiInsights     GuillotineAIInsight[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leagueId])
  @@map("guillotine_seasons")
}

model GuillotineElimination {
  id       String           @id @default(cuid())
  seasonId String
  season   GuillotineSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  leagueId String

  eliminatedRosterId String
  eliminatedTeamName String
  eliminatedOwnerId  String

  scoringPeriod   Int
  finalScore      Float
  rankAmongActive Int
  marginBelowSafe Float

  wasTiebreaker    Boolean @default(false)
  tiebreakerType   String?
  tiedWithRosterId String?

  aiEliminationSummary String?
  aiCollapseReason     String?

  eliminatedAt DateTime @default(now())

  @@index([seasonId, scoringPeriod])
  @@index([leagueId])
  @@map("guillotine_eliminations")
}

model GuillotineSurvivalLog {
  id       String           @id @default(cuid())
  seasonId String
  season   GuillotineSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  leagueId String
  rosterId String
  roster   RedraftRoster    @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  scoringPeriod         Int
  totalScore            Float
  rankAmongActive       Int
  teamsActiveThisPeriod Int
  survivalStatus        String
  marginAboveChopLine   Float
  wasInDangerZone       Boolean @default(false)

  @@unique([seasonId, rosterId, scoringPeriod])
  @@index([seasonId, scoringPeriod])
  @@index([rosterId])
  @@map("guillotine_survival_logs")
}

model GuillotineWaiverRelease {
  id       String           @id @default(cuid())
  seasonId String
  season   GuillotineSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  leagueId String

  eliminatedRosterId String
  scoringPeriod      Int

  playerId   String
  playerName String
  position   String
  team       String?
  sport      String

  releaseStatus     String    @default("pending")
  availableAt       DateTime
  claimedByRosterId String?
  claimedAt         DateTime?
  winningBid        Float?

  @@index([seasonId, releaseStatus])
  @@index([leagueId, scoringPeriod])
  @@map("guillotine_waiver_releases")
}

model GuillotineAIInsight {
  id            String           @id @default(cuid())
  leagueId      String
  league        League           @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  seasonId      String
  season        GuillotineSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  scoringPeriod Int?

  rosterId  String?
  type      String
  content   Json
  narrative String?

  generatedAt DateTime @default(now())

  @@index([seasonId, type])
  @@index([rosterId, type])
  @@map("guillotine_ai_insights")
}

model WeatherCache {
  id              String   @id @default(cuid())
  cacheKey        String   @unique
  latitude        Float
  longitude       Float
  forecastForTime DateTime
  fetchedAt       DateTime @default(now())
  expiresAt       DateTime

  temperatureF     Float?
  feelsLikeF       Float?
  windSpeedMph     Float?
  windGustsMph     Float?
  windDirectionDeg Float?
  precipChancePct  Float?
  rainInches       Float?
  snowInches       Float?
  humidityPct      Float?
  visibilityMiles  Float?
  conditionCode    String?
  conditionLabel   String?
  cloudCoverPct    Float?

  isIndoor   Boolean @default(false)
  isDome     Boolean @default(false)
  roofClosed Boolean @default(false)
  sport      String?
  eventId    String?

  dataSource     String @default("openweathermap")
  apiResponseRaw Json?

  @@index([cacheKey])
  @@index([fetchedAt])
  @@index([forecastForTime])
}

model AFProjectionSnapshot {
  id         String  @id @default(cuid())
  playerId   String
  playerName String
  sport      String
  position   String
  week       Int?
  season     Int
  eventId    String?

  baselineProjection Float
  weatherAdjustment  Float @default(0)
  afProjection       Float

  weatherCacheId    String?
  adjustmentFactors Json?
  adjustmentReason  String?
  confidenceLevel   String  @default("medium")

  isOutdoorGame Boolean @default(true)
  venueOverride Boolean @default(false)

  computedAt DateTime  @default(now())
  validUntil DateTime?

  /// Stable key: `${playerId}|${season}|${week ?? 'w'}|${eventId ?? 'none'}`
  snapshotLookupKey String @unique

  @@index([playerId, week, season])
  @@index([sport, week, season])
}
