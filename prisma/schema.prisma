/// Live draft session for a league. One active session per league at a time.
model DraftSession {
  id                    String    @id @default(uuid())
  leagueId              String
  sportType             String?   @db.VarChar(16)
  league                League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  status                String    @default("pre_draft") // pre_draft | in_progress | paused | completed
  draftType             String    @default("snake")    // snake | linear | auction
  rounds                Int       @default(15)
  teamCount             Int       @default(12)
  thirdRoundReversal    Boolean   @default(false)
  timerSeconds          Int?      // null = no timer
  /// When status=in_progress, server time when current pick expires (UTC).
  timerEndAt            DateTime?
  /// When status=paused, remaining seconds for current pick.
  pausedRemainingSeconds Int?
  /// Draft order: JSON array of { slot: number, rosterId: string, displayName: string }
  slotOrder             Json      @default("[]")
  /// Draft pick trades: JSON array of { round, originalRosterId, previousOwnerName, newRosterId, newOwnerName } for ownership resolution
  tradedPicks            Json?     @default("[]")
  /// Auction: default budget per team (e.g. 200).
  auctionBudgetPerTeam   Int?
  /// Auction: optional per-roster remaining budget { [rosterId]: number }. Initialized from auctionBudgetPerTeam on start.
  auctionBudgets         Json?
  /// Auction: current nomination/bid state { nominationOrderIndex, currentNomination?, currentBid?, currentBidderRosterId?, bidTimerEndAt?, minNextBid? }
  auctionState           Json?
  /// Keeper: config { maxKeepers, deadline?: ISO string, maxKeepersPerPosition?: Record<position, number> }
  keeperConfig           Json?
  /// Keeper: selections [{ rosterId, roundCost, playerName, position, team, playerId }] (roundCost = which round pick is spent)
  keeperSelections       Json?
  /// Devy: { enabled: boolean, devyRounds: number[] } (1-based round numbers that are devy-only; e.g. [14, 15])
  devyConfig             Json?
  /// C2C: { enabled: boolean, collegeRounds: number[] } (1-based rounds that are college-only; rest are pro-only)
  c2cConfig              Json?
  version               Int       @default(0)          // optimistic lock
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  picks   DraftPick[]
  queues  DraftQueue[]
  tradeProposals DraftPickTradeProposal[]

  @@unique([leagueId])
  @@index([leagueId])
  @@index([status])
  @@index([leagueId, sportType])
  @@index([sportType, status])
  @@map("draft_sessions")
}

/// Single pick in a live draft.
model DraftPick {
  id          String   @id @default(uuid())
  sessionId   String
  sportType   String?  @db.VarChar(16)
  session     DraftSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  overall     Int      // 1-based
  round       Int
  slot        Int      // 1-based slot in round (after snake/3RR)
  rosterId    String   // owner at time of pick (our Roster.id or stable id)
  displayName String?  // manager display name
  playerName  String
  position    String
  team        String?
  byeWeek     Int?     // for display where data exists
  playerId    String?  // optional external id
  /// Optional UI metadata when pick was traded: { originalRosterId, previousOwnerName, newOwnerName, showNewOwnerInRed?, tintColor? }
  tradedPickMeta Json?
  source       String? @default("user") // user | auto | commissioner
  /// Auction: winning bid amount (dollars or nominal units).
  amount       Int?
  createdAt    DateTime @default(now())

  @@unique([sessionId, overall])
  @@index([sessionId])
  @@index([sessionId, rosterId])
  @@index([sessionId, sportType])
  @@index([sportType])
  @@map("draft_picks")
}

/// Draft pick trade proposal during live draft. Accept creates entries in session.tradedPicks.
model DraftPickTradeProposal {
  id               String   @id @default(cuid())
  sessionId        String
  session          DraftSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  proposerRosterId String
  receiverRosterId String
  /// Pick proposer gives: round, slot, originalRosterId (must equal proposerRosterId)
  giveRound        Int
  giveSlot         Int
  giveOriginalRosterId String
  /// Pick proposer receives: round, slot, originalRosterId (must equal receiverRosterId)
  receiveRound     Int
  receiveSlot      Int
  receiveOriginalRosterId String
  proposerName     String?
  receiverName     String?
  status           String   @default("pending")   // pending | accepted | rejected | countered
  respondedAt      DateTime?
  responsePayload Json?     // optional counter details or decline reason
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([sessionId])
  @@index([sessionId, receiverRosterId])
  @@index([sessionId, status])
  @@map("draft_pick_trade_proposals")
}

/// Audit log for orphan/empty team AI manager actions (draft picks, trade decisions). Deterministic reasoning only.
