  userId    String
  source    String   @db.VarChar(32) // referral | league_invite | draft_share | ai_share | competition_invite | organic
  sourceId  String?  @db.VarChar(128) // referrerId | leagueId | shareId | momentId
  metadata  Json? // e.g. inviteCode, utm_campaign, channel
  createdAt DateTime @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([source])
  @@index([source, sourceId])
  @@map("growth_attributions")
}

/// Viral Invite Engine (PROMPT 142) — unified invite links for league, bracket, creator league, referral, reactivation, waitlist.
model InviteLink {
  id              String    @id @default(uuid())
  type            String    @db.VarChar(24) // league | bracket | creator_league | referral | reactivation | waitlist
  token           String    @unique @db.VarChar(32)
  createdByUserId String
  targetId        String?   @db.VarChar(128) // leagueId | bracketLeagueId | creatorLeagueId etc
  expiresAt       DateTime?
  maxUses         Int       @default(0) // 0 = unlimited
  useCount        Int       @default(0)
  status          String    @default("active") @db.VarChar(16) // active | expired | revoked | max_used
  metadata        Json? // e.g. label, channel, sport
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  createdBy AppUser           @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  events    InviteLinkEvent[]

  @@index([createdByUserId])
  @@index([createdByUserId, type, createdAt])
  @@index([type])
  @@index([type, targetId])
  @@index([status])
  @@index([status, expiresAt])
  @@index([token])
  @@map("invite_links")
}

model InviteLinkEvent {
  id           String   @id @default(uuid())
  inviteLinkId String
  eventType    String   @db.VarChar(32) // viewed | shared | accepted | expired_shown | copy_link | sms | email | twitter | discord | reddit | whatsapp
  channel      String?  @db.VarChar(24)
  metadata     Json?
  createdAt    DateTime @default(now())

  inviteLink InviteLink @relation(fields: [inviteLinkId], references: [id], onDelete: Cascade)

  @@index([inviteLinkId, createdAt])
  @@index([inviteLinkId, eventType, createdAt])
  @@index([eventType])
  @@index([channel, createdAt])
  @@map("invite_link_events")
}

/// Creator League System (PROMPT 141) — public creators run branded leagues and brackets.
model CreatorProfile {
  id                  String    @id @default(uuid())
  userId              String    @unique
  handle              String    @unique
  slug                String    @unique @db.VarChar(128)
  displayName         String?   @db.VarChar(128)
  creatorType         String?   @db.VarChar(32)
  bio                 String?   @db.Text
  communitySummary    String?   @db.Text
  avatarUrl           String?   @db.VarChar(512)
  bannerUrl           String?   @db.VarChar(512)
  websiteUrl          String?   @db.VarChar(512)
  socialHandles       Json? // { twitter?, youtube?, twitch?, instagram? }
  verifiedAt          DateTime?
  verificationBadge   String?   @db.VarChar(32) // e.g. "verified" | "partner"
  visibility          String    @default("public") @db.VarChar(16) // public | unlisted | private
  communityVisibility String    @default("public") @db.VarChar(16) // public | unlisted | private
  branding            Json? // CreatorBranding: logoUrl, primaryColor, accentColor
  featuredRank        Int?
