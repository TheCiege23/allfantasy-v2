/// Subscription plan catalog. Backed by monetization SKU families (AF Pro, Commissioner, War Room, All-Access, Supreme).
model SubscriptionPlan {
  id            String             @id @default(uuid())
  code          String             @unique @db.VarChar(64)
  name          String             @db.VarChar(128)
  description   String?
  isBundle      Boolean            @default(false)
  isActive      Boolean            @default(true)
  metadata      Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  subscriptions UserSubscription[]

  @@index([isActive])
  @@map("subscription_plans")
}

/// User subscription grants from Stripe checkout/webhook lifecycle.
model UserSubscription {
  id                      String           @id @default(uuid())
  userId                  String
  subscriptionPlanId      String
  status                  String           @default("active") @db.VarChar(32)
  source                  String           @default("stripe") @db.VarChar(32)
  sku                     String?          @db.VarChar(64)
  stripeCustomerId        String?          @db.VarChar(128)
  stripeSubscriptionId    String?          @unique @db.VarChar(128)
  stripeCheckoutSessionId String?          @db.VarChar(128)
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  gracePeriodEnd          DateTime?
  canceledAt              DateTime?
  expiresAt               DateTime?
  metadata                Json?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  plan                    SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id], onDelete: Cascade)
  user                    AppUser          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([subscriptionPlanId, status])
  @@index([stripeCustomerId])
  @@index([currentPeriodEnd])
  @@index([gracePeriodEnd])
  @@map("user_subscriptions")
}

/// Token package catalog for one-time token purchases.
model TokenPackage {
  id            String        @id @default(uuid())
  sku           String        @unique @db.VarChar(64)
  title         String        @db.VarChar(128)
  description   String?
  tokenAmount   Int
  priceUsdCents Int
  isActive      Boolean       @default(true)
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  ledgerEntries TokenLedger[]

  @@index([isActive])
  @@map("token_packages")
}

/// User-level AI token balance snapshot.
model UserTokenBalance {
  id                String        @id @default(uuid())
  userId            String        @unique
  balance           Int           @default(0)
  lifetimePurchased Int           @default(0)
  lifetimeSpent     Int           @default(0)
  lifetimeRefunded  Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  entries           TokenLedger[]
  user              AppUser       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([balance])
  @@map("user_token_balances")
}

/// Centralized per-feature spend pricing for token deductions.
model TokenSpendRule {
  id                   String        @id @default(uuid())
  code                 String        @unique @db.VarChar(64)
  category             String        @db.VarChar(32)
  featureLabel         String        @db.VarChar(128)
  description          String?
  tokenCost            Int
  requiresConfirmation Boolean       @default(true)
  isActive             Boolean       @default(true)
  metadata             Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  ledgerEntries        TokenLedger[]

  @@index([isActive])
  @@index([category, isActive])
  @@map("token_spend_rules")
}

/// Refund policy metadata used when auto-refunding failed executions.
model TokenRefundRule {
  id            String        @id @default(uuid())
  code          String        @unique @db.VarChar(64)
  description   String?
  maxAgeMinutes Int?
  isActive      Boolean       @default(true)
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  ledgerEntries TokenLedger[]

  @@index([isActive])
  @@map("token_refund_rules")
}

/// Immutable ledger of all token credits/debits/refunds.
model TokenLedger {
  id                 String           @id @default(uuid())
  userId             String
  userTokenBalanceId String
  entryType          String           @db.VarChar(32)
  tokenDelta         Int
  balanceBefore      Int
  balanceAfter       Int
  tokenPackageSku    String?          @db.VarChar(64)
  spendRuleCode      String?          @db.VarChar(64)
  refundRuleCode     String?          @db.VarChar(64)
  sourceType         String?          @db.VarChar(64)
  sourceId           String?          @db.VarChar(128)
  idempotencyKey     String?          @unique @db.VarChar(191)
  description        String?
  metadata           Json?
  createdAt          DateTime         @default(now())
  refundRule         TokenRefundRule? @relation(fields: [refundRuleCode], references: [code])
  spendRule          TokenSpendRule?  @relation(fields: [spendRuleCode], references: [code])
  tokenPackage       TokenPackage?    @relation(fields: [tokenPackageSku], references: [sku])
  user               AppUser          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenBalance       UserTokenBalance @relation(fields: [userTokenBalanceId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([entryType, createdAt])
  @@index([tokenPackageSku])
  @@index([spendRuleCode])
  @@index([refundRuleCode])
  @@index([sourceType, sourceId])
  @@map("token_ledger")
}

