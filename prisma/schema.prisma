  excerpt        String?   @db.VarChar(1024)
  body           String    @db.Text
  seoTitle       String?   @db.VarChar(512)
  seoDescription String?   @db.VarChar(512)
  tags           Json      @default("[]")
  publishStatus  String    @db.VarChar(24)
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  publishLogs BlogPublishLog[]
  draft       BlogDraft?

  @@index([publishStatus])
  @@index([sport])
  @@index([category])
  @@index([publishedAt])
  @@index([createdAt])
  @@map("blog_articles")
