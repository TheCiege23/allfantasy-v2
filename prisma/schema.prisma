  @@index([leagueId, rosterId])
  @@index([leagueId, transactionType])
  @@map("idp_cap_transactions")
}

/// Devy Dynasty league config. Sport adapter derived from League.sport (nfl_devy | nba_devy).
model DevyLeagueConfig {
  id                            String   @id @default(uuid())
  leagueId                      String   @unique @db.VarChar(64)
  /// Format flags (all true for devy_dynasty).
  dynastyOnly                   Boolean  @default(true)
  supportsStartupVetDraft       Boolean  @default(true)
  supportsRookieDraft           Boolean  @default(true)
  supportsDevyDraft             Boolean  @default(true)
  supportsBestBall              Boolean  @default(true)
  supportsSnakeDraft            Boolean  @default(true)
  supportsLinearDraft           Boolean  @default(true)
  supportsTaxi                  Boolean  @default(true)
  supportsFuturePicks           Boolean  @default(true)
  supportsTradeableDevyPicks    Boolean  @default(true)
  supportsTradeableRookiePicks  Boolean  @default(true)
  /// Commissioner-controlled roster/draft settings.
  devySlotCount                 Int      @default(6)
  taxiSize                      Int      @default(6)
  rookieDraftRounds             Int      @default(4)
  devyDraftRounds               Int      @default(4)
  startupVetRounds              Int?
  bestBallEnabled               Boolean  @default(false)
  startupDraftType              String   @default("snake") @db.VarChar(16)
  rookieDraftType               String   @default("snake") @db.VarChar(16)
  devyDraftType                 String   @default("snake") @db.VarChar(16)
  maxYearlyDevyPromotions       Int?
  earlyDeclareBehavior          String   @default("allow") @db.VarChar(24)
  rookiePickOrderMethod         String   @default("reverse_standings") @db.VarChar(32)
  devyPickOrderMethod           String   @default("reverse_standings") @db.VarChar(32)
  devyPickTradeRules            String   @default("allowed") @db.VarChar(24)
  rookiePickTradeRules          String   @default("allowed") @db.VarChar(24)
  /// NFL-only: exclude K/DST from devy pool (default false = include eligible only; devy pool is QB/RB/WR/TE).
  nflDevyExcludeKDST            Boolean  @default(false)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
  /// PROMPT 3: When to apply promotion: immediate_after_pro_draft | rollover | manager_choice_before_rookie_draft
  promotionTiming               String   @default("manager_choice_before_rookie_draft") @db.VarChar(48)
  /// Allow devy players (NCAA, not rostered) on waivers/FA when enabled; FAAB or priority per league.
  dispersalDevyFAEnabled        Boolean  @default(false) @map("supplementalDevyFAEnabled")
  /// If enabled, rights expire after configured period when not promoted (commissioner tool to clean).
  rightsExpirationEnabled       Boolean  @default(false)
  /// PROMPT 4: When best ball is ON, if true then taxi-eligible pro rookies can contribute to best ball lineup; otherwise taxi players do not score.
  taxiProRookiesScoreInBestBall Boolean  @default(false)
  /// PROMPT 4: Superflex slot in best ball (NFL). When true, lineup has SUPER_FLEX in addition to FLEX.
  bestBallSuperflex             Boolean  @default(false)
  /// PROMPT 3: When player returns to school: restore_rights | hold_rights | commissioner
  returnToSchoolHandling        String   @default("restore_rights") @db.VarChar(32)
  devyIRSlots                   Int      @default(0)
  devyScoringEnabled            Boolean  @default(false)
  collegeSports                 Json?
  league                        League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@map("devy_league_configs")
}

/// Full devy league engine config (roster buckets, taxi, devy draft). Distinct from legacy `DevyLeagueConfig`.
model DevyLeague {
  id                        String                 @id @default(cuid())
  leagueId                  String                 @unique
  isDynastyOnly             Boolean                @default(true)
  createdByTheCiege         Boolean                @default(true)
  startupDraftFormat        String                 @default("combined")
  futureDraftFormat         String                 @default("combined")
  activeRosterSize          Int                    @default(20)
  benchSlots                Int                    @default(6)
  irSlots                   Int                    @default(2)
  taxiSlots                 Int                    @default(5)
  devySlots                 Int                    @default(10)
  maxDevyPerTeam            Int                    @default(10)
  taxiRookieOnly            Boolean                @default(true)
  taxiAllowNonRookies       Boolean                @default(false)
  taxiMaxExperienceYears    Int                    @default(1)
  taxiLockDeadline          DateTime?
  taxiCanReturnAfterPromo   Boolean                @default(false)
  taxiAutoQualifyRookies    Boolean                @default(true)
  taxiDevyToRookieEligible  Boolean                @default(true)
  taxiPointsVisibleDisplay  Boolean                @default(true)
  taxiPointsCountToward     Boolean                @default(false)
  taxiPoachaingEnabled      Boolean                @default(false)
  devyFreshmenEligible      Boolean                @default(false)
  devyAutoPromoteToRookie   Boolean                @default(true)
  devyDeclarationVisibility Boolean                @default(true)
  rookiePickTradingEnabled  Boolean                @default(true)
  devyPickTradingEnabled    Boolean                @default(true)
  devyGradBehavior          String                 @default("move_to_taxi")
  season                    Int                    @default(2025)
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  devySlotRecords           DevyDevySlot[]
  draftPicks                DevyDraftPick[]
  league                    League                 @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  playerStates              DevyPlayerState[]
  rookieTransitions         DevyRookieTransition[]
  taxiSlotRecords           DevyTaxiSlot[]

  @@index([leagueId])
  @@map("devy_leagues")
}

