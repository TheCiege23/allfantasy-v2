/// AF War Room AI — audit / telemetry for recommendations (Chimmy, waiver, trade hooks).
model AiRecommendationLog {
  id                 String        @id @default(cuid())
  userId             String
  leagueId           String?
  draftSessionId     String?
  feature            String        @db.VarChar(64)
  inputJson          Json          @default("{}")
  outputJson         Json          @default("{}")
  providerSummary    String?
  tokenEstimate      Int?
  createdAt          DateTime      @default(now())
  recommendationType String?       @db.VarChar(32)
  confidencePct      Float?
  accepted           Boolean?
  draftSession       DraftSession? @relation(fields: [draftSessionId], references: [id])
  league             League?       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user               AppUser       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([leagueId, feature])
  @@index([feature, createdAt])
  @@map("ai_recommendation_logs")
}

model RankingsBacktestResult {
  id            String   @id @default(cuid())
  leagueId      String
  season        String   @db.VarChar(8)
  weekEvaluated Int
  targetType    String   @db.VarChar(32)
  horizonWeeks  Int      @default(3)
  segmentKey    String   @db.VarChar(32)
  nTeams        Int
  brier         Float
  ece           Float
  ndcg          Float
  spearman      Float
  payloadJson   Json?
  createdAt     DateTime @default(now())

  @@unique([leagueId, season, weekEvaluated, targetType], name: "uniq_backtest_league_week_target")
  @@index([leagueId, season])
  @@index([segmentKey])
  @@index([createdAt])
  @@map("rankings_backtest_results")
}

model DraftPredictionSnapshot {
  id             String               @id @default(uuid())
  leagueId       String
  userId         String
  season         Int
  draftId        String?
  rounds         Int                  @default(2)
  simulations    Int                  @default(250)
  scenarios      Json                 @default("[]")
  snapshotJson   Json
  createdAt      DateTime             @default(now())
  sportType      String?              @db.VarChar(16)
  retrospectives DraftRetrospective[]

  @@index([leagueId, season])
  @@index([userId, createdAt])
  @@index([leagueId, sportType, season])
  @@index([sportType, season])
  @@map("draft_prediction_snapshots")
}

model DraftRetrospective {
  id                   String                  @id @default(uuid())
  leagueId             String
  userId               String
  season               Int
  draftId              String
  snapshotId           String
  actualDraftJson      Json
  managerAccuracyJson  Json
  biggestMissesJson    Json
  calibrationDeltaJson Json                    @default("{}")
  overallAccuracy      Float                   @default(0)
  top3HitRate          Float                   @default(0)
  createdAt            DateTime                @default(now())
  sportType            String?                 @db.VarChar(16)
  snapshot             DraftPredictionSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([leagueId, season])
  @@index([snapshotId])
  @@index([leagueId, sportType, season])
  @@index([sportType, season])
  @@map("draft_retrospectives")
}

model LeagueDraftCalibration {
  id             String   @id @default(uuid())
  leagueId       String
  season         Int
  adpWeight      Float    @default(1.0)
  needWeight     Float    @default(1.0)
  tendencyWeight Float    @default(1.0)
  newsWeight     Float    @default(1.0)
  rookieWeight   Float    @default(1.0)
  sampleSize     Int      @default(0)
  lastUpdatedAt  DateTime @default(now())
  createdAt      DateTime @default(now())
  sportType      String?  @db.VarChar(16)

  @@unique([leagueId, season])
  @@index([leagueId])
  @@index([leagueId, sportType, season])
  @@index([sportType, season])
  @@map("league_draft_calibrations")
}

/// AI ADP snapshot: computed from app draft picks (DraftPick + MockDraft results), segmented by sport/leagueType/format.
/// Updated daily by cron; used when commissioner enables AI ADP for draft room.
model AiAdpSnapshot {
  id           String   @id @default(uuid())
  sport        String   @db.VarChar(16)
  leagueType   String   @db.VarChar(16)
  formatKey    String   @db.VarChar(32)
  /// Array of { playerName, position, team?, adp, sampleSize }; sorted by adp ascending
  snapshotData Json     @default("[]")
  totalDrafts  Int      @default(0)
  totalPicks   Int      @default(0)
  computedAt   DateTime @default(now())
  /// Optional: { minSampleSize, lowSampleThreshold, segmentLabel }
  meta         Json?

  @@unique([sport, leagueType, formatKey])
  @@index([sport])
  @@index([computedAt])
  @@map("ai_adp_snapshots")
}

/// AI ADP snapshot history: immutable records from each daily/triggered run.
/// Keeps audit trail and diagnostics across time for each segment.
model AiAdpSnapshotHistory {
  id           String   @id @default(uuid())
  sport        String   @db.VarChar(16)
  leagueType   String   @db.VarChar(16)
  formatKey    String   @db.VarChar(32)
  snapshotData Json     @default("[]")
  totalDrafts  Int      @default(0)
  totalPicks   Int      @default(0)
  computedAt   DateTime @default(now())
  /// Optional run context: cutoffApplied, lookbackDays, source counts, thresholds.
  runMeta      Json?

  @@index([sport, leagueType, formatKey, computedAt(sort: Desc)])
  @@index([computedAt(sort: Desc)])
  @@map("ai_adp_snapshot_history")
}

