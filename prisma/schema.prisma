/// Big Brother league config: HOH, nomination, veto, vote, eviction, jury, finale settings.
model BigBrotherLeagueConfig {
  id                                  String                 @id @default(uuid())
  leagueId                            String                 @unique @db.VarChar(64)
  /// HOH challenge day of week (1-7) and time UTC for when HOH runs.
  hohChallengeDayOfWeek               Int?
  hohChallengeTimeUtc                 String?                @db.VarChar(16)
  /// Nomination deadline (day of week 1-7, time UTC) for HOH to submit noms.
  nominationDeadlineDayOfWeek         Int?
  nominationDeadlineTimeUtc           String?                @db.VarChar(16)
  /// Veto draw day/time (when random veto players are selected).
  vetoDrawDayOfWeek                   Int?
  vetoDrawTimeUtc                     String?                @db.VarChar(16)
  /// Veto decision deadline (veto winner must use or leave same).
  vetoDecisionDeadlineDayOfWeek       Int?
  vetoDecisionDeadlineTimeUtc         String?                @db.VarChar(16)
  /// Replacement nominee deadline if veto used (HOH must name replacement).
  replacementNomineeDeadlineDayOfWeek Int?
  replacementNomineeDeadlineTimeUtc   String?                @db.VarChar(16)
  /// Eviction vote window: open/close day and time UTC.
  evictionVoteOpenDayOfWeek           Int?
  evictionVoteOpenTimeUtc             String?                @db.VarChar(16)
  evictionVoteCloseDayOfWeek          Int?
  evictionVoteCloseTimeUtc            String?                @db.VarChar(16)
  /// Final nominee count on ballot (always 2 for classic).
  finalNomineeCount                   Int                    @default(2)
  /// Veto competitor count (HOH + 2 noms + this many random = default 6 total).
  vetoCompetitorCount                 Int                    @default(6)
  /// Consecutive HOH allowed: false = cannot win HOH back-to-back.
  consecutiveHohAllowed               Boolean                @default(false)
  /// HOH votes only in tie (true = default).
  hohVotesOnlyInTie                   Boolean                @default(true)
  /// Jury start: after_eliminations | when_remaining | fixed_week
  juryStartMode                       String                 @default("after_eliminations") @db.VarChar(32)
  juryStartAfterEliminations          Int?
  juryStartWhenRemaining              Int?
  juryStartWeek                       Int?
  /// Finale format: final_2 | final_3
  finaleFormat                        String                 @default("final_2") @db.VarChar(16)
  /// Waiver release after eviction: immediate | next_waiver_run | faab_window
  waiverReleaseTiming                 String                 @default("next_waiver_run") @db.VarChar(32)
  /// Public vote totals: exact | evicted_only
  publicVoteTotalsVisibility          String                 @default("evicted_only") @db.VarChar(24)
  /// Challenge mode: ai_theme | deterministic_score | hybrid
  challengeMode                       String                 @default("hybrid") @db.VarChar(32)
  /// Anti-collusion logging on/off.
  antiCollusionLogging                Boolean                @default(true)
  /// Inactive player handling: none | replacement_after_n_weeks | commissioner_only
  inactivePlayerHandling              String                 @default("commissioner_only") @db.VarChar(32)
  /// Auto-nomination fallback if HOH times out: lowest_season_points | random | commissioner
  autoNominationFallback              String                 @default("lowest_season_points") @db.VarChar(32)
  createdAt                           DateTime               @default(now())
  updatedAt                           DateTime               @updatedAt
  /// Eviction tie-break when vote is tied: hoh_vote | season_points | random | commissioner
  evictionTieBreakMode                String                 @default("season_points") @db.VarChar(24)
  /// When true, automation does not advance week (commissioner can still force).
  weekProgressionPaused               Boolean                @default(false)
  /// Twists, competition presets, optional America’s vote — see `lib/big-brother/big-brother-premium-engine-spec.ts`.
  premiumEngineSpec                   Json?
  auditLog                            BigBrotherAuditLog[]
  cycles                              BigBrotherCycle[]
  jury                                BigBrotherJuryMember[]
  league                              League                 @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@map("big_brother_league_configs")
}

/// One eviction cycle per week: HOH, nominees, veto, vote, eviction.
/// PROMPT 3: phase drives week state machine (HOH_OPEN .. EVICTION_RESOLVED, JURY_UPDATE, RESET_NEXT_WEEK).
model BigBrotherCycle {
  id                         String                   @id @default(uuid())
  leagueId                   String                   @db.VarChar(64)
  configId                   String
  week                       Int
  hohRosterId                String?                  @db.VarChar(64)
  nominee1RosterId           String?                  @db.VarChar(64)
  nominee2RosterId           String?                  @db.VarChar(64)
  vetoWinnerRosterId         String?                  @db.VarChar(64)
  vetoParticipantRosterIds   Json?
  vetoUsed                   Boolean                  @default(false)
  vetoSavedRosterId          String?                  @db.VarChar(64)
  replacementNomineeRosterId String?                  @db.VarChar(64)
  evictedRosterId            String?                  @db.VarChar(64)
  voteDeadlineAt             DateTime?
  voteOpenedAt               DateTime?
  closedAt                   DateTime?
  tieBreakSeasonPoints       Json?
  createdAt                  DateTime                 @default(now())
  updatedAt                  DateTime                 @updatedAt
  /// Week state machine: HOH_OPEN | HOH_LOCKED | NOMINATION_OPEN | NOMINATION_LOCKED | VETO_DRAW | VETO_CHALLENGE_OPEN | VETO_DECISION_OPEN | REPLACEMENT_NOMINATION_OPEN | VOTING_OPEN | VOTING_LOCKED | EVICTION_RESOLVED | JURY_UPDATE | RESET_NEXT_WEEK
  phase                      String                   @default("HOH_OPEN") @db.VarChar(40)
  /// League chat message id for live-updating vote progress (same row edited in place).
  voteProgressMessageId      String?                  @db.VarChar(64)
  config                     BigBrotherLeagueConfig   @relation(fields: [configId], references: [id], onDelete: Cascade)
  votes                      BigBrotherEvictionVote[]

  @@unique([configId, week])
  @@index([leagueId, week])
  @@map("big_brother_cycles")
}

/// Private eviction vote: one per voter per cycle (last before deadline counts).
model BigBrotherEvictionVote {
  id             String          @id @default(cuid())
  cycleId        String
  voterRosterId  String          @db.VarChar(64)
  targetRosterId String          @db.VarChar(64)
  createdAt      DateTime        @default(now())
  cycle          BigBrotherCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([cycleId, voterRosterId])
  @@index([cycleId])
  @@map("big_brother_eviction_votes")
}

/// Jury member: eliminated roster that votes at finale.
model BigBrotherJuryMember {
  id          String                 @id @default(cuid())
  leagueId    String                 @db.VarChar(64)
  configId    String
  rosterId    String                 @db.VarChar(64)
  evictedWeek Int
  joinedAt    DateTime               @default(now())
