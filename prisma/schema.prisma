model UserProfile {
  /// AllFantasy account id (primary). Same as `AppUser.id` — canonical user key for the product.
  userId                    String              @id
  displayName               String?
  phone                     String?             @unique
  phoneVerifiedAt           DateTime?
  emailVerifiedAt           DateTime?
  ageConfirmedAt            DateTime?
  verificationMethod        VerificationMethod?
  /// Current Sleeper handle (display); can change — do not use as primary key.
  sleeperUsername           String?
  /// Stable Sleeper `user_id` from API — provider scope only; links imports to this AF user.
  sleeperUserId             String?             @unique
  sleeperLinkedAt           DateTime?
  sleeperVerifiedAt         DateTime?
  profileComplete           Boolean             @default(false)
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  avatarPreset              String?
  preferredLanguage         String?
  timezone                  String?
  themePreference           String?
  bio                       String?
  preferredSports           Json?
  notificationPreferences   Json?
  onboardingStep            String?
  onboardingCompletedAt     DateTime?
  /// PROMPT 149: Dismissed retention nudge IDs -> ISO date, e.g. { "return_nudge_1": "2025-03-14T..." }
  retentionNudgeDismissedAt Json?
  /// Aggregated scoring/league context after imports — feeds rankings / AI personalization.
  rankingsContext           Json?
  /// Discord OAuth (Tier 1) — optional guild from bot install flow (Tier 2).
  discordUserId             String?             @unique
  discordUsername           String?
  discordEmail              String?
  discordAvatar             String?
  discordAccessToken        String?
  discordRefreshToken       String?
  discordConnectedAt        DateTime?
  discordGuildId            String?
  /// AF Commissioner subscription — unlocks premium league AI / playoff options.
  afCommissionerSub         Boolean             @default(false)
  /// Denormalized from userSubscription (System B) for legacy gates and quick checks.
  afProSub                  Boolean             @default(false)
  /// Denormalized from userSubscription (System B) for legacy gates and quick checks.
  afWarRoomSub              Boolean             @default(false)
  /// Master switch: when false, AutoCoach does not run for any league (per-league prefs preserved).
  autoCoachGlobalEnabled    Boolean             @default(true)
  /// Auto sign-out after this many minutes of inactivity (null/0 = off). Allowed: 30, 60, 240, 720, 1440.
  sessionIdleTimeoutMinutes Int?
  rankTier                  String?             @map("rank_tier")
  xpTotal                   BigInt?             @map("xp_total")
  xpLevel                   Int?                @map("xp_level")
  rankCalculatedAt          DateTime?           @map("rank_calculated_at")
  careerWins                Int?                @map("career_wins")
  careerLosses              Int?                @map("career_losses")
  careerChampionships       Int?                @map("career_championships")
  careerPlayoffAppearances  Int?                @map("career_playoff_appearances")
  careerSeasonsPlayed       Int?                @map("career_seasons_played")
  careerLeaguesPlayed       Int?                @map("career_leagues_played")
  leagueImportDetailPending Boolean?            @default(false) @map("league_import_detail_pending")
  chimmyTtsVoiceId          String?             @map("chimmy_tts_voice_id")
  dashboardOnboarding       Json?
  /// Draft / war-room: risk and build prefs (AF War Room AI).
  riskProfile               String?             @db.VarChar(32)
  draftStyle                String?             @db.VarChar(32)
  dynastyWindow             String?             @db.VarChar(32)
  preferredBuild            String?             @db.VarChar(64)
  preferredPositionsJson    Json?
  fadePositionsJson         Json?
  aiStrategyModeDefault     String?             @db.VarChar(32)
  aiExplanationStyle        String?             @db.VarChar(32)
  aiVoicePreference         String?             @db.VarChar(64)
  /// Spotify Web Playback integration.
  spotifyAccessToken        String?
  spotifyRefreshToken       String?
  spotifyExpiresAt          DateTime?
  spotifyDisplayName        String?
  spotifyConnectedAt        DateTime?
  /// Denormalized legacy-career snapshot on the profile. Lives on
  /// UserProfile so the rank route can read it in a single query
  /// without joining the career tier computation service.
  legacyCareerTier          Int?                @map("legacy_career_tier")
  legacyCareerTierName      String?             @map("legacy_career_tier_name")
  legacyCareerLevel         Int?                @map("legacy_career_level")
  legacyCareerXp            BigInt?             @map("legacy_career_xp")
  user                      AppUser             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sleeperUsername])
  @@index([phone])
  @@map("user_profiles")
}

