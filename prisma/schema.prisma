  faabRemaining        Int?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  waiverPriority       Int?
  /// Optional commissioner flags: `isAdvertised`, `aiManaged`, `aiManagerType`, etc.
  settings             Json?
  dispersalDraftPasses Boolean             @default(false)
  devyRights           DevyRights[]
  keeperDeclarations   KeeperDeclaration[]
  redraftDraftPicks    RedraftDraftPick[]
  redraftDraftQueue    RedraftDraftQueue[]
  league               League              @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  waiverClaims         WaiverClaim[]
  waiverTransactions   WaiverTransaction[]

  @@unique([leagueId, platformUserId])
  @@index([leagueId])
  @@index([platformUserId])
  @@map("rosters")
}

model LeagueTeam {
  id                  String            @id @default(uuid())
  leagueId            String
  externalId          String
  ownerName           String
  teamName            String
  avatarUrl           String?
  wins                Int               @default(0)
  losses              Int               @default(0)
  ties                Int               @default(0)
  pointsFor           Float             @default(0)
  pointsAgainst       Float             @default(0)
  currentRank         Int?
  aiPowerScore        Float?
  projectedWins       Float?
  strengthNotes       String?
  riskNotes           String?
  lastUpdatedAt       DateTime          @updatedAt
  legacyRosterId      String?           @unique
  divisionId          String?           @db.VarChar(64)
  role                String            @default("member")
  isOrphan            Boolean           @default(false)
  claimedByUserId     String?
  platformUserId      String?
  /// Sleeper is_owner for this team’s user; co-commissioners are AF-only via isCoCommissioner.
  isCommissioner      Boolean           @default(false)
  isCoCommissioner    Boolean           @default(false)
  seasonChampionships LeagueSeason[]    @relation("LeagueSeasonChampion")
  division            LeagueDivision?   @relation(fields: [divisionId], references: [id])
  league              League            @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  legacyRoster        LegacyRoster?     @relation(fields: [legacyRosterId], references: [id])
  performances        TeamPerformance[]

  @@unique([leagueId, externalId])
  @@index([leagueId, pointsFor])
  @@index([divisionId])
  @@index([aiPowerScore])
  @@map("league_teams")
}

/// League hierarchy — divisions (tiers) within a league for promotion/relegation.
model LeagueDivision {
  id        String       @id @default(cuid())
  leagueId  String       @db.VarChar(64)
  tierLevel Int          @default(1)
  sport     String       @db.VarChar(16)
  name      String?      @db.VarChar(128)
  league    League       @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  teams     LeagueTeam[]

  @@unique([leagueId, tierLevel])
  @@index([leagueId])
  @@map("league_divisions")
}

/// Promotion/relegation rule: how many teams move between two tiers at season end.
model PromotionRule {
  id            String @id @default(cuid())
  leagueId      String @db.VarChar(64)
  fromTierLevel Int    @default(1)
  toTierLevel   Int    @default(2)
  promoteCount  Int    @default(1)
  relegateCount Int    @default(1)
  league        League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, fromTierLevel, toTierLevel])
  @@index([leagueId])
  @@map("promotion_rules")
}

model TeamPerformance {
  id        String     @id @default(uuid())
  teamId    String
  week      Int
  season    Int
  points    Float
  opponent  String?
  result    String?
  data      Json?
  createdAt DateTime   @default(now())
  team      LeagueTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, season, week])
  @@index([teamId, season])
  @@map("team_performances")
}

model LeagueAuth {
  id          String   @id @default(uuid())
  userId      String
  platform    String
  apiKey      String?
  oauthToken  String?
  oauthSecret String?
  espnSwid    String?
  espnS2      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
  @@map("league_auths")
}

model LeagueWaiverSettings {
  id                  String    @id @default(uuid())
  leagueId            String    @unique
  waiverType          String    @default("standard")
  processingDayOfWeek Int?
  processingTimeUtc   String?
  claimLimitPerPeriod Int?
  faabBudget          Int?
  faabResetDate       DateTime?
  tiebreakRule        String?
  lockType            String?
  instantFaAfterClear Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  league              League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@map("league_waiver_settings")
}

/// Guillotine league config (1:1 with League when leagueVariant/format is guillotine).
model GuillotineLeagueConfig {
  id                    String   @id @default(uuid())
  leagueId              String   @unique
  /// First scoring period when elimination runs (1-based).
  eliminationStartWeek  Int      @default(1)
  /// Last scoring period for elimination (e.g. week 17); after this, no more chops.
  eliminationEndWeek    Int?
  /// Number of teams chopped per period (1 = classic).
  teamsPerChop          Int      @default(1)
  /// When to run chop: immediate | after_stat_corrections | custom_cutoff
  correctionWindow      String   @default("after_stat_corrections") @db.VarChar(32)
  /// Custom cutoff: ISO weekday (1–7) and/or time UTC (e.g. "Wednesday 14:00").
  customCutoffDayOfWeek Int?
  customCutoffTimeUtc   String?  @db.VarChar(16)
  /// Hours after period end to wait for stat corrections (if correctionWindow = after_stat_corrections).
  statCorrectionHours   Int?     @default(48)
  /// Tiebreaker order: season_points | previous_period | draft_slot | commissioner | random
  tiebreakerOrder       Json?
  /// Danger tier: points margin below lowest projected to count as "in danger".
  dangerMarginPoints    Float?   @default(10)
  /// Release chopped roster to waivers: immediate | next_waiver_run | custom_time
  rosterReleaseTiming   String   @default("next_waiver_run") @db.VarChar(32)
  /// Allow commissioner to override who is chopped (with audit).
  commissionerOverride  Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  league                League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@map("guillotine_league_configs")
}

/// Per-roster chop state (eliminated at which period).
model GuillotineRosterState {
  id              String    @id @default(uuid())
  leagueId        String    @db.VarChar(64)
  rosterId        String    @unique @db.VarChar(64)
  choppedAt       DateTime?
  choppedInPeriod Int?
  choppedReason   String?   @db.VarChar(128)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([leagueId])
  @@index([leagueId, choppedInPeriod])
  @@map("guillotine_roster_states")
}

/// Period score per roster for guillotine (lowest-score elimination).
model GuillotinePeriodScore {
  id                String   @id @default(uuid())
  leagueId          String   @db.VarChar(64)
  rosterId          String   @db.VarChar(64)
  weekOrPeriod      Int
  season            Int?
  periodPoints      Float    @default(0)
  seasonPointsCumul Float    @default(0)
  createdAt         DateTime @default(now())

  @@unique([leagueId, rosterId, weekOrPeriod])
  @@index([leagueId, weekOrPeriod])
  @@index([leagueId, rosterId])
  @@map("guillotine_period_scores")
}

/// Append-only event log: chop, commissioner_override, media events.
model GuillotineEventLog {
  id        String   @id @default(cuid())
  leagueId  String   @db.VarChar(64)
  eventType String   @db.VarChar(64)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([leagueId])
  @@index([leagueId, eventType])
  @@index([createdAt])
  @@map("guillotine_event_logs")
}

/// Salary Cap league config (1:1 with League when leagueVariant is salary_cap).
model SalaryCapLeagueConfig {
  id                      String                @id @default(uuid())
  leagueId                String                @unique @db.VarChar(64)
  mode                    String                @default("dynasty") @db.VarChar(24)
  startupCap              Int                   @default(250)
  capGrowthPercent        Float                 @default(5)
  contractMinYears        Int                   @default(1)
  contractMaxYears        Int                   @default(4)
  rookieContractYears     Int                   @default(3)
  minimumSalary           Int                   @default(1)
  deadMoneyEnabled        Boolean               @default(true)
  deadMoneyPercentPerYear Float                 @default(25)
  rolloverEnabled         Boolean               @default(true)
  rolloverMax             Int                   @default(25)
  capFloorEnabled         Boolean               @default(false)
  capFloorAmount          Int?
  extensionsEnabled       Boolean               @default(true)
  franchiseTagEnabled     Boolean               @default(true)
  rookieOptionEnabled     Boolean               @default(false)
  startupDraftType        String                @default("auction") @db.VarChar(24)
  futureDraftType         String                @default("linear") @db.VarChar(24)
  auctionHoldback         Int                   @default(50)
  weightedLotteryEnabled  Boolean               @default(false)
  lotteryOddsConfig       Json?
  compPickEnabled         Boolean               @default(false)
  compPickFormula         Json?
  offseasonPhase          String?               @db.VarChar(32)
  offseasonPhaseEndsAt    DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  contracts               PlayerContract[]
  eventLog                SalaryCapEventLog[]
  league                  League                @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  ledgers                 SalaryCapTeamLedger[]

  @@map("salary_cap_league_configs")
}

/// Per-roster, per-cap-year cap state (cap hit total, rollover, etc.).
model SalaryCapTeamLedger {
  id           String                @id @default(uuid())
  leagueId     String                @db.VarChar(64)
  configId     String
  rosterId     String                @db.VarChar(64)
  capYear      Int
  totalCapHit  Int                   @default(0)
  deadMoneyHit Int                   @default(0)
  rolloverUsed Int                   @default(0)
  capSpace     Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  config       SalaryCapLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, rosterId, capYear])
  @@index([leagueId, capYear])
  @@index([rosterId, capYear])
  @@map("salary_cap_team_ledgers")
}

/// Player contract: roster + player + salary + years. One row per active/expired contract instance.
model PlayerContract {
  id                 String                @id @default(uuid())
  leagueId           String                @db.VarChar(64)
  configId           String
  rosterId           String                @db.VarChar(64)
  playerId           String                @db.VarChar(64)
  playerName         String?               @db.VarChar(128)
  position           String?               @db.VarChar(16)
  salary             Int
  yearsTotal         Int
  yearSigned         Int
  contractYear       Int                   @default(1)
  status             String                @default("active") @db.VarChar(24)
  source             String                @db.VarChar(32)
  franchiseTagAt     DateTime?
  optionExercisedAt  DateTime?
  cutAt              DateTime?
  deadMoneyRemaining Json?
  metadata           Json?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  config             SalaryCapLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([leagueId, rosterId])
  @@index([leagueId, playerId])
  @@index([configId, yearSigned])
  @@index([rosterId, status])
  @@map("player_contracts")
}

/// Append-only event log for salary cap (contract signed, cut, extension, tag, rollover, etc.).
model SalaryCapEventLog {
  id        String                @id @default(cuid())
  leagueId  String                @db.VarChar(64)
  configId  String
  eventType String                @db.VarChar(64)
  metadata  Json?
  createdAt DateTime              @default(now())
  config    SalaryCapLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([leagueId, eventType])
  @@index([createdAt])
  @@map("salary_cap_event_logs")
}

/// Weighted lottery result (deterministic, auditable). One row per league per season.
model SalaryCapLotteryResult {
  id        String   @id @default(uuid())
  leagueId  String   @db.VarChar(64)
  configId  String
  capYear   Int
  seed      String?  @db.VarChar(64)
  order     Json
  createdAt DateTime @default(now())

  @@unique([configId, capYear])
  @@index([leagueId, capYear])
  @@map("salary_cap_lottery_results")
}

/// Survivor league config (1:1 with League when leagueVariant is survivor).
model SurvivorLeagueConfig {
  id                             String                  @id @default(uuid())
  leagueId                       String                  @unique @db.VarChar(64)
  mode                           String                  @default("redraft") @db.VarChar(24)
  tribeCount                     Int                     @default(4)
  tribeSize                      Int                     @default(4)
  tribeFormation                 String                  @default("random") @db.VarChar(24)
  mergeTrigger                   String                  @default("week") @db.VarChar(24)
  mergeWeek                      Int?
  mergePlayerCount               Int?
  juryStartAfterMerge            Int                     @default(1)
  exileReturnEnabled             Boolean                 @default(false)
  exileReturnTokens              Int                     @default(4)
  idolCount                      Int                     @default(2)
  idolPowerPool                  Json?
  tribeShuffleEnabled            Boolean                 @default(false)
  tribeShuffleConsecutiveLosses  Int?
  tribeShuffleImbalanceThreshold Float?
  voteDeadlineDayOfWeek          Int?
  voteDeadlineTimeUtc            String?                 @db.VarChar(16)
  selfVoteDisallowed             Boolean                 @default(true)
  tribalCouncilDayOfWeek         Int?
  tribalCouncilTimeUtc           String?                 @db.VarChar(16)
  minigameFrequency              String                  @default("none") @db.VarChar(24)
  seasonThemeLabel               String?                 @db.VarChar(255)
  regularSeasonEndWeek           Int?
  challengesSystemRun            Boolean                 @default(true)
  faqSeededAt                    DateTime?
  createdAt                      DateTime                @default(now())
  updatedAt                      DateTime                @updatedAt
  /// Survivor engine v2 — confessionals, clue chains, minigame pool, exile variants, presets (see `lib/survivor/survivor-engine-spec-v2.ts`).
  engineSpecV2                   Json?
  auditLog                       SurvivorAuditLog[]
  challenges                     SurvivorChallenge[]
  exileLeague                    SurvivorExileLeague?
  idols                          SurvivorIdol[]
  league                         League                  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  councils                       SurvivorTribalCouncil[]
  tribes                         SurvivorTribe[]

  @@map("survivor_league_configs")
}

/// Tribe within a Survivor league.
model SurvivorTribe {
  id              String                    @id @default(uuid())
  leagueId        String                    @db.VarChar(64)
  configId        String
  name            String                    @db.VarChar(128)
  slotIndex       Int                       @default(0)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  chatChannelId   String?
  colorHex        String?
  isActive        Boolean                   @default(true)
  isMerged        Boolean                   @default(false)
  logoUrl         String?
  phase           String                    @default("pre_merge") @db.VarChar(24)
  survivorPlayers SurvivorPlayer[]
  councils        SurvivorTribalCouncil[]
  chatMembers     SurvivorTribeChatMember[]
  members         SurvivorTribeMember[]
  config          SurvivorLeagueConfig      @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, slotIndex])
  @@index([leagueId])
  @@map("survivor_tribes")
}

/// Tribe membership: roster in a tribe. Pre-merge only; merge has no tribes.
model SurvivorTribeMember {
  id       String        @id @default(uuid())
  tribeId  String
  rosterId String        @db.VarChar(64)
  isLeader Boolean       @default(false)
  joinedAt DateTime      @default(now())
  tribe    SurvivorTribe @relation(fields: [tribeId], references: [id], onDelete: Cascade)

  @@unique([tribeId, rosterId])
  @@index([rosterId])
  @@index([tribeId])
  @@map("survivor_tribe_members")
}

/// Hidden idol: player-bound, one-time use. Ownership = current controlling rosterId.
model SurvivorIdol {
  id                  String                    @id @default(uuid())
  leagueId            String                    @db.VarChar(64)
  configId            String
  rosterId            String                    @db.VarChar(64)
  playerId            String                    @db.VarChar(64)
  powerType           String                    @db.VarChar(64)
  status              String                    @default("hidden") @db.VarChar(24)
  assignedAt          DateTime                  @default(now())
  usedAt              DateTime?
  expiredAt           DateTime?
  validUntilPhase     String?                   @db.VarChar(32)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  auditLog            Json?
  currentOwnerUserId  String?                   @db.VarChar(64)
  expiresAtMerge      Boolean                   @default(true)
  expiresAtWeek       Int?
  isPubliclyKnown     Boolean                   @default(false)
  isSecret            Boolean                   @default(true)
  isTradable          Boolean                   @default(false)
  isUsed              Boolean                   @default(false)
  originalOwnerUserId String?                   @db.VarChar(64)
  playWindowRule      String                    @default("before_reveal") @db.VarChar(32)
  powerCategory       String?                   @db.VarChar(64)
  powerDesc           String?
  powerLabel          String?                   @db.VarChar(160)
  rarity              String                    @default("common") @db.VarChar(24)
  transferHistory     Json?
  usedAtCouncilId     String?                   @db.VarChar(64)
  ledgerEntries       SurvivorIdolLedgerEntry[]
  config              SurvivorLeagueConfig      @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([leagueId, rosterId])
  @@index([leagueId, playerId])
  @@index([configId, status])
  @@index([leagueId, currentOwnerUserId])
  @@index([leagueId, powerType])
  @@map("survivor_idols")
}

/// Chain-of-custody for idols: assignment, transfer, use, expiry.
model SurvivorIdolLedgerEntry {
  id           String       @id @default(cuid())
  leagueId     String       @db.VarChar(64)
  idolId       String
  eventType    String       @db.VarChar(32)
  fromRosterId String?      @db.VarChar(64)
  toRosterId   String?      @db.VarChar(64)
  metadata     Json?
  createdAt    DateTime     @default(now())
  idol         SurvivorIdol @relation(fields: [idolId], references: [id], onDelete: Cascade)

  @@index([leagueId, eventType])
  @@index([idolId])
  @@map("survivor_idol_ledger_entries")
}

/// Tribal Council: one per week (or period). Pre-merge = one tribe attends; merge = all remaining.
model SurvivorTribalCouncil {
  id                   String               @id @default(uuid())
  leagueId             String               @db.VarChar(64)
  configId             String
  week                 Int
  phase                String               @db.VarChar(24)
  attendingTribeId     String?              @db.VarChar(64)
  voteDeadlineAt       DateTime
  closedAt             DateTime?
  eliminatedRosterId   String?              @db.VarChar(64)
  tieBreakSeasonPoints Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  auditLog             Json?
  councilNumber        Int                  @default(1)
  doesNotCountVoteIds  String[]             @default([])
  eliminatedName       String?              @db.VarChar(160)
  eliminatedUserId     String?              @db.VarChar(64)
  idolsPlayed          Json?
  isRevealed           Boolean              @default(false)
  isTie                Boolean              @default(false)
  nullifiersPlayed     Json?
  revealSequence       Json?
  revealStartsAt       DateTime?
  rockDrawerUserId     String?              @db.VarChar(64)
  status               String               @default("pending") @db.VarChar(24)
  tiePhase             String?              @db.VarChar(32)
  tiePlayerIds         String[]             @default([])
  votingDeadline       DateTime?
  votingOpensAt        DateTime?
  tribe                SurvivorTribe?       @relation(fields: [attendingTribeId], references: [id])
  config               SurvivorLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  votes                SurvivorVote[]

  @@unique([configId, week, councilNumber])
  @@index([leagueId, week])
  @@map("survivor_tribal_councils")
}

/// Single vote in a Tribal Council (private ballot).
model SurvivorVote {
  id             String                @id @default(cuid())
  councilId      String
  voterRosterId  String                @db.VarChar(64)
  targetRosterId String                @db.VarChar(64)
  doesNotCount   Boolean               @default(false)
  isDoubleVote   Boolean               @default(false)
  isLateVote     Boolean               @default(false)
  leagueId       String?               @db.VarChar(64)
  nullifiedBy    String?               @db.VarChar(64)
  submittedAt    DateTime              @default(now())
  targetName     String?               @db.VarChar(160)
  targetUserId   String?               @db.VarChar(64)
  voterName      String?               @db.VarChar(160)
  voterUserId    String?               @db.VarChar(64)
  council        SurvivorTribalCouncil @relation(fields: [councilId], references: [id], onDelete: Cascade)

  @@unique([councilId, voterRosterId])
  @@index([councilId])
  @@index([voterUserId])
  @@index([leagueId])
  @@map("survivor_votes")
}

/// Link main Survivor league to its Exile Island league.
model SurvivorExileLeague {
  id            String               @id @default(uuid())
  mainLeagueId  String               @unique @db.VarChar(64)
  configId      String               @unique
  exileLeagueId String               @db.VarChar(64)
  createdAt     DateTime             @default(now())
  config        SurvivorLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([exileLeagueId])
  @@map("survivor_exile_leagues")
}

/// Exile token balance per roster (in exile league). Reset when Boss wins.
model SurvivorExileToken {
  id              String   @id @default(uuid())
  exileLeagueId   String   @db.VarChar(64)
  rosterId        String   @db.VarChar(64)
  tokens          Int      @default(0)
  lastAwardedWeek Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([exileLeagueId, rosterId])
  @@index([exileLeagueId])
  @@map("survivor_exile_tokens")
}

/// Jury membership: rosterId = main league roster that was voted out and is now on jury.
model SurvivorJuryMember {
  id           String   @id @default(cuid())
  leagueId     String   @db.VarChar(64)
  rosterId     String   @db.VarChar(64)
  votedOutWeek Int
  joinedAt     DateTime @default(now())

  @@unique([leagueId, rosterId])
  @@index([leagueId])
  @@map("survivor_jury_members")
}

/// Survivor audit log: votes, idol use, shuffle, elimination, overrides.
model SurvivorAuditLog {
  id        String               @id @default(cuid())
  leagueId  String               @db.VarChar(64)
  configId  String
  eventType String               @db.VarChar(64)
  metadata  Json?
  createdAt DateTime             @default(now())
  config    SurvivorLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([leagueId, eventType])
  @@index([createdAt])
  @@map("survivor_audit_logs")
}

/// Mini-game / challenge definition per week.
model SurvivorChallenge {
  id              String                        @id @default(uuid())
  leagueId        String                        @db.VarChar(64)
  configId        String
  week            Int
  challengeType   String                        @db.VarChar(64)
  configJson      Json?
  lockAt          DateTime?
  resultJson      Json?
  createdAt       DateTime                      @default(now())
  updatedAt       DateTime                      @updatedAt
  auditLog        Json?
  challengeNumber Int                           @default(1)
  closesAt        DateTime?
  description     String                        @default("")
  instructions    String                        @default("")
  locksAt         DateTime?
  penaltyDetails  Json?
  penaltyType     String?                       @db.VarChar(64)
  resultSummary   String?
  rewardAmount    Float?
  rewardDetails   Json?
  rewardType      String?                       @db.VarChar(64)
  scope           String                        @default("tribe") @db.VarChar(24)
  status          String                        @default("open") @db.VarChar(24)
  submissionMode  String                        @default("tribe_chat") @db.VarChar(32)
  title           String                        @default("") @db.VarChar(256)
  type            String?                       @db.VarChar(64)
  winnerTribeId   String?                       @db.VarChar(64)
  winnerUserIds   String[]                      @default([])
  submissions     SurvivorChallengeSubmission[]
  config          SurvivorLeagueConfig          @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, week, challengeNumber, challengeType])
  @@index([leagueId, week])
  @@map("survivor_challenges")
}

/// One submission per roster (or tribe) per challenge.
model SurvivorChallengeSubmission {
  id           String            @id @default(cuid())
  challengeId  String
  rosterId     String?           @db.VarChar(64)
  tribeId      String?           @db.VarChar(64)
  submission   Json
  submittedAt  DateTime          @default(now())
  isCorrect    Boolean?
  isLocked     Boolean           @default(false)
