  payload     Json?    // state before/after, reason, etc.
  createdAt   DateTime @default(now())

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId])
  @@index([leagueId, eventType])
  @@index([createdAt])
  @@map("devy_lifecycle_events")
}

/// PROMPT 3: Commissioner override queue for ambiguous devy-to-pro player mapping.
model DevyCommissionerOverride {
