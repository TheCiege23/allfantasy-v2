/// AI integrity monitoring — collusion / tanking flags (no chat content; evidence is on-field only).
model IntegrityFlag {
  id                 String    @id @default(cuid())
  leagueId           String
  flagType           String
  severity           String
  status             String    @default("open")
  affectedRosterIds  String[]
  affectedTeamNames  String[]
  summary            String
  evidenceJson       Json
  aiConfidence       Float
  tradeTransactionId String?
  commissionerNote   String?
  commissionerUserId String?
  reviewedAt         DateTime?
  notifiedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  league             League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId, status])
  @@index([leagueId, flagType])
  @@index([createdAt])
  @@map("integrity_flags")
}

model LeagueIntegritySettings {
  id                         String    @id @default(cuid())
  leagueId                   String    @unique
  collusionMonitoringEnabled Boolean   @default(true)
  collusionSensitivity       String    @default("medium")
  tankingMonitorEnabled      Boolean   @default(false)
  tankingSensitivity         String    @default("medium")
  tankingStartWeek           Int?
  tankingIllegalLineupCheck  Boolean   @default(true)
  tankingBenchPatternCheck   Boolean   @default(true)
  tankingWaiverPatternCheck  Boolean   @default(false)
  lastCollusionScanAt        DateTime?
  lastTankingScanAt          DateTime?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  league                     League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@map("league_integrity_settings")
}

/// Per-user per-league Chimmy AutoCoach™ (AF Pro); commissioner can block via `League.autoCoachEnabled` + `blockedByCommissioner`.
model AutoCoachSetting {
  id                    String    @id @default(cuid())
  userId                String
  leagueId              String
  enabled               Boolean   @default(false)
  blockedByCommissioner Boolean   @default(false)
  lastRunAt             DateTime?
  lastSwapAt            DateTime?
  totalSwapsMade        Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  league                League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user                  AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId])
  @@index([userId])
  @@index([leagueId])
  @@map("auto_coach_settings")
}

model AutoCoachSwapLog {
  id               String    @id @default(cuid())
  userId           String
  leagueId         String
  rosterId         String
  slotPosition     String
  playerOutId      String
  playerOutName    String
  playerOutStatus  String
  playerInId       String
  playerInName     String
  playerInPosition String
  statusSource     String
  statusDetectedAt DateTime
  swapMadeAt       DateTime  @default(now())
  gameStartsAt     DateTime?
  wasPreGame       Boolean   @default(true)
  createdAt        DateTime  @default(now())

  @@index([userId, leagueId])
  @@index([leagueId])
  @@index([swapMadeAt])
  @@map("auto_coach_swap_logs")
}

/// Canonical player inactive-status events for AutoCoach (multi-source aggregation).
model PlayerStatusEvent {
  id                   String    @id @default(cuid())
  externalId           String
  playerName           String
  sport                String
  teamAbbrev           String?
  newStatus            String
  previousStatus       String?
  statusReason         String?
  source               String
  sourceUrl            String?
  sourceRawText        String?
  confidence           Float     @default(1.0)
  gameDate             DateTime?
  detectedAt           DateTime  @default(now())
  autoCoachTriggered   Boolean   @default(false)
  autoCoachTriggeredAt DateTime?

  @@index([externalId, detectedAt])
  @@index([sport, gameDate])
  @@index([detectedAt])
  @@index([autoCoachTriggered])
  @@map("player_status_events")
}

/// Commissioner-managed draft & league draft-time settings (one row per league).
model LeagueSettings {
  id                       String    @id @default(cuid())
  leagueId                 String    @unique
  draftDateUtc             DateTime?
  timezone                 String?   @default("America/New_York")
  autostart                Boolean   @default(false)
  slowDraftPause           Boolean   @default(false)
  slowPauseFrom            String?
  slowPauseUntil           String?
  cpuAutoPick              Boolean   @default(true)
  aiAutoPick               Boolean   @default(false)
  draftType                String    @default("snake")
  pickTimerPreset          String    @default("120s")
  pickTimerCustomValue     Int?
  rounds                   Int       @default(15)
  draftOrderMethod         String    @default("manual")
  randomizeCount           Int?
  draftOrderSlots          Json?
  draftOrderLocked         Boolean   @default(false)
  keeperCount              Int       @default(0)
  keeperRoundCost          Boolean   @default(false)
  keeperSlots              Json?
  dynastyCarryover         Boolean   @default(false)
  playerPool               String    @default("all")
  alphabeticalSort         Boolean   @default(false)
  aiQueueSuggestions       Boolean   @default(true)
  aiBestAvailable          Boolean   @default(true)
  aiRosterGuidance         Boolean   @default(true)
  aiScarcityAlerts         Boolean   @default(true)
  aiDraftGrade             Boolean   @default(true)
  aiSleeperAlerts          Boolean   @default(true)
  aiByeAwareness           Boolean   @default(true)
  aiStackSuggestions       Boolean   @default(false)
  aiRiskUpsideNotes        Boolean   @default(true)
  aiScope                  String    @default("everyone")
  randomizeHistory         Json?
  resetHistory             Json?
  updatedAt                DateTime  @updatedAt
  updatedBy                String?
  /// AF War Room AI — commissioner / league-scoped toggles and defaults.
  aiWarRoomEnabled         Boolean   @default(false)
  aiPlayerOutlookEnabled   Boolean   @default(true)
  aiPlayerCompareEnabled   Boolean   @default(true)
  aiContingencyEnabled     Boolean   @default(true)
  aiManagerTendencyEnabled Boolean   @default(true)
  aiPostDraftReportEnabled Boolean   @default(true)
  aiDefaultStrategyMode    String?   @db.VarChar(32)
  aiAggressiveness         String?   @db.VarChar(16)
  aiRookieBias             Float?    @default(0)
  aiStackPreference        String?   @db.VarChar(32)
  aiRiskTolerance          String?   @db.VarChar(16)
  league                   League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@map("league_settings")
}

/// Per-season snapshot for a league (Sleeper chain via previous_league_id).
model LeagueSeason {
  id                      String      @id @default(cuid())
  leagueId                String
  season                  Int
  /// Sleeper league_id for that season instance
  platformLeagueId        String
  championTeamId          String?
  championName            String?
  championAvatar          String?
  runnerUpName            String?
  regularSeasonWinnerName String?
  /// Array of per-team season stats (see LeagueSeasonTeamRecord in app code)
  teamRecords             Json?
  teamCount               Int?
  scoringFormat           String?
  isDynasty               Boolean     @default(false)
  status                  String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  championTeam            LeagueTeam? @relation("LeagueSeasonChampion", fields: [championTeamId], references: [id])
  league                  League      @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, season])
  @@index([leagueId])
  @@map("league_seasons")
}

model LeagueStoryline {
