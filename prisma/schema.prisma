  rosterId   String   @db.VarChar(64)
  action     String   @db.VarChar(32)   // draft_pick | trade_accept | trade_reject | trade_counter | trade_send
  payload    Json     @default("{}")    // action-specific (e.g. playerName, round, pick; or trade summary)
  reason     String?  @db.Text         // deterministic reasoning / context
  triggeredBy String? @db.VarChar(64)  // userId if commissioner-triggered; null if auto
  createdAt  DateTime @default(now())

  @@index([leagueId])
  @@index([leagueId, rosterId])
  @@index([leagueId, action])
  @@index([createdAt])
  @@map("ai_manager_audit_log")
}

