/// Audit log for IDP config changes (scoring, position mode, starter counts). Preserves integrity on eligibility/setting updates.
model IdpSettingsAuditLog {
  id        String          @id @default(cuid())
  leagueId  String          @db.VarChar(64)
  configId  String
  config    IdpLeagueConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  actorId   String?         @db.VarChar(64)
  /// position_mode_change | scoring_change | starter_count_change | scoring_preset_apply | unlock | lock
  action    String          @db.VarChar(48)
  before    Json?
  after     Json?
  metadata  Json?
  createdAt DateTime        @default(now())

  @@index([leagueId])
  @@index([configId])
  @@index([createdAt])
  @@map("idp_settings_audit_logs")
}

// ========== IDP Salary Cap (GM layer on IDP / redraft shell) ==========

model IDPCapConfig {
  id       String @id @default(cuid())
  leagueId String @unique
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  totalCap Float @default(200.0)

  isHardCap Boolean @default(true)

  capFloorEnabled Boolean @default(false)
  capFloor        Float?

  capRolloverEnabled Boolean @default(false)

  inSeasonHoldbackEnabled Boolean @default(false)
  inSeasonHoldbackPct     Float   @default(0.10)

  franchiseTagEnabled Boolean @default(false)
  franchiseTagValue   Float   @default(20.0)

  draftSalaryMethod String @default("auction")

  snakeScaleHighSalary Float  @default(30.0)
  snakeScaleLowSalary  Float  @default(1.0)
  snakeScaleCurve      String @default("linear")

  auctionDefaultContractYears Int @default(1)
  snakeTopPickContractYears   Int @default(3)
  snakeMidPickContractYears   Int @default(2)
  snakeLatePickContractYears  Int @default(1)

  isDynastyMode      Boolean @default(false)
  contractsCarryOver Boolean @default(false)

  season Int @default(2025)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salaryRecords  IDPSalaryRecord[]
  deadMoney      IDPDeadMoney[]     @relation("CapConfigDeadMoney")
  capProjections IDPCapProjection[]

  @@index([leagueId])
  @@map("idp_cap_configs")
}

model IDPSalaryRecord {
  id        String       @id @default(cuid())
  leagueId  String
  capConfig IDPCapConfig @relation(fields: [leagueId], references: [leagueId], onDelete: Cascade)

  rosterId String
  roster   RedraftRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  playerId    String
  playerName  String
  position    String
  isDefensive Boolean @default(false)

  salary Float

  contractYears  Int @default(1)
  yearsRemaining Int @default(1)

  contractStartYear Int

  status String @default("active")

  acquisitionMethod String

  isFranchiseTagged Boolean @default(false)

  hasBeenExtended   Boolean @default(false)
  extensionBoostPct Float   @default(0.10)

  cutPenaltyCurrent Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deadMoneyRecords IDPDeadMoney[]

  @@unique([leagueId, rosterId, playerId])
  @@index([leagueId, rosterId])
  @@index([leagueId, status])
  @@map("idp_salary_records")
}

model IDPDeadMoney {
  id        String       @id @default(cuid())
  leagueId  String
  capConfig IDPCapConfig @relation("CapConfigDeadMoney", fields: [leagueId], references: [leagueId], onDelete: Cascade)

  rosterId String
  roster   RedraftRoster @relation("RedraftRosterIdpDeadMoney", fields: [rosterId], references: [id], onDelete: Cascade)

  salaryRecordId String
  salaryRecord   IDPSalaryRecord @relation(fields: [salaryRecordId], references: [id], onDelete: Cascade)

  playerId   String
  playerName String

  reason String

  currentYearDead Float
  futureYearsDead Float
  totalDeadMoney  Float

  yearsRemainingAtCut Int
  season              Int

  createdAt DateTime @default(now())

  @@index([leagueId, rosterId])
  @@map("idp_dead_money")
}

model IDPCapProjection {
  id        String       @id @default(cuid())
  leagueId  String
  capConfig IDPCapConfig @relation(fields: [leagueId], references: [leagueId], onDelete: Cascade)

  rosterId String
  roster   RedraftRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  projectionYear  Int
  committedSalary Float
  deadCapHits     Float
  totalCapUsed    Float
  availableCap    Float

  updatedAt DateTime @updatedAt

  @@unique([leagueId, rosterId, projectionYear])
  @@index([leagueId, rosterId])
  @@map("idp_cap_projections")
}

model IDPCapTransaction {
  id       String @id @default(cuid())
  leagueId String

  rosterId String

  playerId    String
  playerName  String
  isDefensive Boolean @default(false)

  transactionType String

  salary           Float
  contractYears    Int?
  deadMoneyCreated Float @default(0)
  capImpact        Float

  notes  String?
  season Int
  week   Int?

  createdAt DateTime @default(now())

  @@index([leagueId, rosterId])
  @@index([leagueId, transactionType])
  @@map("idp_cap_transactions")
}

// ========== Devy Dynasty League Engine (PROMPT 2/6) ==========

/// Devy Dynasty league config. Sport adapter derived from League.sport (nfl_devy | nba_devy).
model DevyLeagueConfig {
  id                            String   @id @default(uuid())
  leagueId                      String   @unique @db.VarChar(64)
  league                        League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  /// Format flags (all true for devy_dynasty).
  dynastyOnly                   Boolean  @default(true)
  supportsStartupVetDraft       Boolean  @default(true)
  supportsRookieDraft           Boolean  @default(true)
  supportsDevyDraft             Boolean  @default(true)
  supportsBestBall              Boolean  @default(true)
  supportsSnakeDraft            Boolean  @default(true)
  supportsLinearDraft           Boolean  @default(true)
  supportsTaxi                  Boolean  @default(true)
  supportsFuturePicks           Boolean  @default(true)
  supportsTradeableDevyPicks    Boolean  @default(true)
  supportsTradeableRookiePicks  Boolean  @default(true)
  /// Commissioner-controlled roster/draft settings.
  devySlotCount                 Int      @default(6)
  devyIRSlots                   Int      @default(0)
  taxiSize                      Int      @default(6)
  devyScoringEnabled            Boolean  @default(false)
  collegeSports                 Json?
  rookieDraftRounds             Int      @default(4)
  devyDraftRounds               Int      @default(4)
  startupVetRounds              Int? // null = derive from roster (active + bench + taxi)
  bestBallEnabled               Boolean  @default(false)
  startupDraftType              String   @default("snake") @db.VarChar(16) // snake | linear
  rookieDraftType               String   @default("snake") @db.VarChar(16)
  devyDraftType                 String   @default("snake") @db.VarChar(16)
  maxYearlyDevyPromotions       Int? // null = no hard cap
  earlyDeclareBehavior          String   @default("allow") @db.VarChar(24) // allow | block | commissioner
  rookiePickOrderMethod         String   @default("reverse_standings") @db.VarChar(32) // reverse_standings | lottery | consolation | custom
  devyPickOrderMethod           String   @default("reverse_standings") @db.VarChar(32)
  devyPickTradeRules            String   @default("allowed") @db.VarChar(24) // allowed | locked_until_draft | commissioner_only
  rookiePickTradeRules          String   @default("allowed") @db.VarChar(24)
  /// NFL-only: exclude K/DST from devy pool (default false = include eligible only; devy pool is QB/RB/WR/TE).
  nflDevyExcludeKDST            Boolean  @default(false)
  /// PROMPT 3: When to apply promotion: immediate_after_pro_draft | rollover | manager_choice_before_rookie_draft
  promotionTiming               String   @default("manager_choice_before_rookie_draft") @db.VarChar(48)
  /// Allow devy players (NCAA, not rostered) on waivers/FA when enabled; FAAB or priority per league.
  dispersalDevyFAEnabled        Boolean  @default(false) @map("supplementalDevyFAEnabled")
  /// If enabled, rights expire after configured period when not promoted (commissioner tool to clean).
  rightsExpirationEnabled       Boolean  @default(false)
  /// PROMPT 3: When player returns to school: restore_rights | hold_rights | commissioner
  returnToSchoolHandling        String   @default("restore_rights") @db.VarChar(32)
  /// PROMPT 4: When best ball is ON, if true then taxi-eligible pro rookies can contribute to best ball lineup; otherwise taxi players do not score.
  taxiProRookiesScoreInBestBall Boolean  @default(false)
  /// PROMPT 4: Superflex slot in best ball (NFL). When true, lineup has SUPER_FLEX in addition to FLEX.
  bestBallSuperflex             Boolean  @default(false)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  @@map("devy_league_configs")
}

/// Full devy league engine config (roster buckets, taxi, devy draft). Distinct from legacy `DevyLeagueConfig`.
model DevyLeague {
  id       String @id @default(cuid())
  leagueId String @unique
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  isDynastyOnly     Boolean @default(true)
  createdByTheCiege Boolean @default(true)

  startupDraftFormat String @default("combined")
  futureDraftFormat  String @default("combined")

  activeRosterSize Int @default(20)
  benchSlots       Int @default(6)
  irSlots          Int @default(2)
  taxiSlots        Int @default(5)
  devySlots        Int @default(10)
  maxDevyPerTeam   Int @default(10)

  taxiRookieOnly           Boolean   @default(true)
  taxiAllowNonRookies      Boolean   @default(false)
  taxiMaxExperienceYears   Int       @default(1)
  taxiLockDeadline         DateTime?
  taxiCanReturnAfterPromo  Boolean   @default(false)
  taxiAutoQualifyRookies   Boolean   @default(true)
  taxiDevyToRookieEligible Boolean   @default(true)
  taxiPointsVisibleDisplay Boolean   @default(true)
  taxiPointsCountToward    Boolean   @default(false)
  taxiPoachaingEnabled     Boolean   @default(false)

  devyFreshmenEligible      Boolean @default(false)
  devyAutoPromoteToRookie   Boolean @default(true)
  devyDeclarationVisibility Boolean @default(true)

  rookiePickTradingEnabled Boolean @default(true)
  devyPickTradingEnabled   Boolean @default(true)

  devyGradBehavior String @default("move_to_taxi")

  season Int @default(2025)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taxiSlotRecords   DevyTaxiSlot[]
  devySlotRecords   DevyDevySlot[]
  rookieTransitions DevyRookieTransition[]
  playerStates      DevyPlayerState[]
  draftPicks        DevyDraftPick[]

  @@index([leagueId])
  @@map("devy_leagues")
}

model DevyPlayerState {
  id         String        @id @default(cuid())
  leagueId   String
  devyLeague DevyLeague    @relation(fields: [leagueId], references: [leagueId], onDelete: Cascade)
  rosterId   String
  roster     RedraftRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  playerId   String
  playerName String
  position   String

  playerType String

  bucketState        String @default("active_bench")
  scoringEligibility String @default("display_only")

  school                   String?
  classYear                String?
  projectedDeclarationYear Int?
  isDevyEligible           Boolean @default(false)

  isRookieEligible Boolean @default(false)
  nflDraftYear     Int?
  nflDraftRound    Int?
  nflDraftPick     Int?

  isTaxiEligible Boolean @default(false)
  taxiYearsUsed  Int     @default(0)

  transitionedFrom String?
  transitionedAt   DateTime?
  transitionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leagueId, rosterId, playerId])
  @@index([leagueId, playerType])
  @@index([leagueId, bucketState])
  @@map("devy_player_states")
}

model DevyTaxiSlot {
  id         String        @id @default(cuid())
  leagueId   String
  devyLeague DevyLeague    @relation(fields: [leagueId], references: [leagueId], onDelete: Cascade)
  rosterId   String
  roster     RedraftRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  playerId   String
  playerName String
  position   String

  taxiYearStart    Int
  taxiYearsCurrent Int     @default(1)
  isEligible       Boolean @default(true)
  isLocked         Boolean @default(false)

  addedAt         DateTime  @default(now())
  promotedAt      DateTime?
  promotedToState String?

  @@unique([leagueId, rosterId, playerId])
  @@index([leagueId, rosterId])
  @@map("devy_taxi_slots")
}

model DevyDevySlot {
  id         String        @id @default(cuid())
  leagueId   String
  devyLeague DevyLeague    @relation(fields: [leagueId], references: [leagueId], onDelete: Cascade)
  rosterId   String
  roster     RedraftRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  playerId String

  playerName               String
  position                 String
  school                   String?
  schoolLogoUrl            String?
  classYear                String?
  projectedDeclarationYear Int?
  hasEnteredNFL            Boolean @default(false)
  nflEntryYear             Int?
  nflEntryStatus           String?

  rightsAcquiredVia String?
  rightsAcquiredAt  DateTime @default(now())

  transitionedAt  DateTime?
  transitionQueue Boolean   @default(false)

  @@unique([leagueId, rosterId, playerId])
  @@index([leagueId, rosterId])
  @@index([leagueId, hasEnteredNFL])
  @@map("devy_devy_slots")
}

model DevyRookieTransition {
  id         String     @id @default(cuid())
  leagueId   String
  devyLeague DevyLeague @relation(fields: [leagueId], references: [leagueId], onDelete: Cascade)

  rosterId String?
  roster   RedraftRoster? @relation(fields: [rosterId], references: [id], onDelete: SetNull)

  playerId   String
  playerName String
  school     String?

  nflEntryYear   Int
  nflEntryMethod String

  previousState    String @default("devy")
  destinationState String

  wasAutoTransitioned    Boolean   @default(false)
  wasCommissionerReview  Boolean   @default(false)
  commissionerApprovedAt DateTime?

  transitionedAt DateTime?
  notes          String?

  @@index([leagueId, nflEntryYear])
  @@map("devy_rookie_transitions")
}

model DevyDraftPick {
  id         String     @id @default(cuid())
  leagueId   String
  devyLeague DevyLeague @relation(fields: [leagueId], references: [leagueId], onDelete: Cascade)

  pickType String
  season   Int
  round    Int

  originalOwnerId String
  currentOwnerId  String

  isTradeable    Boolean   @default(true)
  isUsed         Boolean   @default(false)
  usedOnPlayerId String?
  usedAt         DateTime?

  tradeHistory Json?

  createdAt DateTime @default(now())

  @@unique([leagueId, pickType, season, round, originalOwnerId])
  @@index([leagueId, currentOwnerId])
  @@index([leagueId, pickType, season])
  @@map("devy_draft_picks")
}

/// Multi-source dynasty / devy import merge session (commissioner-driven).
model DevyImportSession {
  id             String  @id @default(cuid())
  leagueId       String
  league         League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  commissionerId String
  commissioner   AppUser @relation("DevyImportSessionCommissioner", fields: [commissionerId], references: [id], onDelete: Cascade)

  status String @default("pending")

  sources         DevyImportSource[]
  playerMappings  DevyPlayerMapping[]
  managerMappings DevyManagerMapping[]
  mergeConflicts  DevyMergeConflict[]
  importedSeasons DevyImportedSeason[]

  summary Json?

  approvedAt DateTime?
  mergedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leagueId])
  @@index([commissionerId])
  @@map("devy_import_sessions")
}

model DevyImportSource {
  id        String            @id @default(cuid())
  sessionId String
  session   DevyImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  sourceType     String
  sourcePlatform String?
  classification String?

  connectionStatus String @default("pending")

  rawData Json?

  importedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([sessionId])
  @@map("devy_import_sources")
}

model DevyPlayerMapping {
  id        String            @id @default(cuid())
  sessionId String
  session   DevyImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  externalId       String
  externalName     String
  externalPlatform String
  externalPosition String?
  externalTeam     String?
  externalSchool   String?

  internalPlayerId   String?
  internalPlayerName String?

  matchConfidence String  @default("unmatched")
  matchMethod     String?

  isConfirmedByCommissioner Boolean @default(false)
  requiresReview            Boolean @default(false)
  playerType                String?

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([sessionId, externalId, externalPlatform])
  @@map("devy_player_mappings")
}

model DevyManagerMapping {
  id        String            @id @default(cuid())
  sessionId String
  session   DevyImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  externalUsername    String
  externalDisplayName String
  externalPlatform    String

  internalUserId   String?
  internalUsername String?

  matchConfidence String @default("unmatched")

  isConfirmedByCommissioner Boolean @default(false)
  requiresReview            Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("devy_manager_mappings")
}

model DevyMergeConflict {
  id        String            @id @default(cuid())
  sessionId String
  session   DevyImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  conflictType     String
  description      String
  affectedEntities Json

  resolution String @default("pending")

  resolvedBy       String?
  resolvedAt       DateTime?
  resolutionNote   String?
  commissionerNote String?

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([sessionId, resolution])
  @@map("devy_merge_conflicts")
}

model DevyImportedSeason {
  id       String @id @default(cuid())
  leagueId String
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  sessionId String
  session   DevyImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  season         Int
  sourceLabel    String
  sourcePlatform String?

  standings      Json?
  scoringRecords Json?

  titleWinner String?
  notes       String?

  importConfidence String @default("high")

  createdAt DateTime @default(now())

  @@index([leagueId, season])
  @@index([sessionId])
  @@map("devy_imported_seasons")
}

/// PROMPT 3: Per-roster devy rights and lifecycle state. One row per (league, roster, devyPlayer) when a manager holds devy rights.
model DevyRights {
  id                  String    @id @default(uuid())
  leagueId            String    @db.VarChar(64)
  rosterId            String    @db.VarChar(64)
  devyPlayerId        String    @db.VarChar(64)
  slotCategory        String    @default("DEVY") @db.VarChar(16)
  c2cLineupRole       String?   @db.VarChar(16)
  /// Lifecycle: NCAA_DEVY_ACTIVE | NCAA_DEVY_TAXI | NCAA_DEVY_LOCKED | DECLARED | DRAFTED_RIGHTS_HELD | PROMOTION_ELIGIBLE | PROMOTED_TO_PRO | RETURNED_TO_SCHOOL | RIGHTS_EXPIRED | ORPHANED_RIGHTS
  state               String    @db.VarChar(32)
  seasonYear          Int? // year of declaration/draft when relevant
  /// After promotion, pro player id (SportsPlayer or platform) when mapped
  promotedProPlayerId String?   @db.VarChar(64)
  promotedAt          DateTime?
  /// When manager chose promotion (if timing = manager_choice_before_rookie_draft)
  managerPromotedAt   DateTime?
  /// If returned to school, restored to NCAA devy state
  returnedToSchoolAt  DateTime?
  /// Source confidence for declare/draft mapping (0-100)
  sourceConfidence    Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  roster Roster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  @@unique([leagueId, rosterId, devyPlayerId])
  @@index([leagueId])
  @@index([rosterId])
  @@index([devyPlayerId])
  @@index([state])
  @@index([leagueId, state])
  @@index([leagueId, rosterId, slotCategory])
  @@map("devy_rights")
}

/// PROMPT 3: Audit log for every graduation, promotion, pool assignment, and commissioner action.
model DevyLifecycleEvent {
  id           String   @id @default(uuid())
  leagueId     String   @db.VarChar(64)
  eventType    String   @db.VarChar(48) // graduation | promotion | return_to_school | rights_expired | orphaned | pool_assignment | commissioner_override
  rosterId     String?  @db.VarChar(64)
  devyPlayerId String?  @db.VarChar(64)
  proPlayerId  String?  @db.VarChar(64)
  payload      Json? // state before/after, reason, etc.
  createdAt    DateTime @default(now())

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId])
  @@index([leagueId, eventType])
  @@index([createdAt])
  @@map("devy_lifecycle_events")
}

/// PROMPT 3: Commissioner override queue for ambiguous devy-to-pro player mapping.
model DevyCommissionerOverride {
  id           String    @id @default(uuid())
  leagueId     String    @db.VarChar(64)
  devyPlayerId String    @db.VarChar(64)
  proPlayerId  String?   @db.VarChar(64) // resolved mapping
  action       String    @db.VarChar(32) // resolve_mapping | force_promote | revoke_promotion | reopen_window
  status       String    @default("pending") @db.VarChar(24) // pending | applied | rejected
  resolvedAt   DateTime?
  resolvedBy   String?   @db.VarChar(64)
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId])
  @@index([status])
  @@map("devy_commissioner_overrides")
}

/// PROMPT 5: Draft history (startup vet, rookie, devy) for audit and AI/rankings.
model DevyDraftHistory {
  id         String   @id @default(uuid())
  leagueId   String   @db.VarChar(64)
  draftKind  String   @db.VarChar(24) // startup_vet | rookie | devy
  seasonYear Int?
  round      Int
  pick       Int
  rosterId   String?  @db.VarChar(64)
  playerId   String?  @db.VarChar(64) // DevyPlayer or pro player id
  isDevy     Boolean  @default(false)
  createdAt  DateTime @default(now())

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId])
  @@index([leagueId, draftKind])
  @@index([seasonYear])
  @@map("devy_draft_histories")
}

/// PROMPT 5: Class strength snapshot by sport and season (deterministic input for AI storytelling).
model DevyClassStrengthSnapshot {
  id         String   @id @default(uuid())
  sport      String   @db.VarChar(8) // NFL | NBA
  seasonYear Int
  payload    Json // { year: { qb, rb, wr, te } } or NBA position counts
  createdAt  DateTime @default(now())

  @@unique([sport, seasonYear])
  @@index([sport])
  @@map("devy_class_strength_snapshots")
}

/// PROMPT 5: Best ball auto-lineup snapshot per roster/period (deterministic result).
model DevyBestBallLineupSnapshot {
  id          String   @id @default(uuid())
  leagueId    String   @db.VarChar(64)
  rosterId    String   @db.VarChar(64)
  periodKey   String   @db.VarChar(32) // e.g. "2024_w1" or "2024_season"
  totalPoints Float?
  starterIds  Json // array of player ids in optimal lineup
  createdAt   DateTime @default(now())

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, rosterId, periodKey])
  @@index([leagueId])
  @@index([rosterId])
  @@map("devy_best_ball_lineup_snapshots")
}

// ========== Merged Devy / C2C (College to Canton) PROMPT 2/6 ==========

/// Merged Devy / C2C league config. Sport adapter: nfl_c2c | nba_c2c. Dynasty only; merged college + pro pipeline.
model C2CLeagueConfig {
  id                                String   @id @default(uuid())
  leagueId                          String   @unique @db.VarChar(64)
  league                            League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  dynastyOnly                       Boolean  @default(true)
  supportsMergedCollegeAndProAssets Boolean  @default(true)
  supportsCollegeScoring            Boolean  @default(true)
  supportsBestBall                  Boolean  @default(true)
  supportsSnakeDraft                Boolean  @default(true)
  supportsLinearDraft               Boolean  @default(true)
  supportsTaxi                      Boolean  @default(true)
  supportsFuturePicks               Boolean  @default(true)
  supportsTradeableCollegeAssets    Boolean  @default(true)
  supportsTradeableCollegePicks     Boolean  @default(true)
  supportsTradeableRookiePicks      Boolean  @default(true)
  supportsPromotionRules            Boolean  @default(true)
  /// Startup: merged (one draft pro+college) | separate (pro draft then college draft)
  startupFormat                     String   @default("merged") @db.VarChar(24)
  mergedStartupDraft                Boolean  @default(true)
  separateStartupCollegeDraft       Boolean  @default(false)
  collegeRosterSize                 Int      @default(20)
  collegeSports                     Json?
  collegeScoringSystem              String   @default("ppr") @db.VarChar(24)
  mixProPlayers                     Boolean  @default(true)
  collegeActiveLineupSlots          Json? // e.g. { qb:1, rb:2, wr:3, te:1, flex:2 } NFL; { g:2, f:2, c:1, flex:2 } NBA
  taxiSize                          Int      @default(6)
  rookieDraftRounds                 Int      @default(4)
  collegeDraftRounds                Int      @default(6)
  bestBallPro                       Boolean  @default(true)
  bestBallCollege                   Boolean  @default(false)
  promotionTiming                   String   @default("manager_choice_before_rookie_draft") @db.VarChar(48)
  maxPromotionsPerYear              Int?
  earlyDeclareBehavior              String   @default("allow") @db.VarChar(24)
  returnToSchoolHandling            String   @default("restore_rights") @db.VarChar(32)
  rookiePickTradeRules              String   @default("allowed") @db.VarChar(24)
  collegePickTradeRules             String   @default("allowed") @db.VarChar(24)
  collegeScoringUntilDeadline       Boolean  @default(true)
  /// unified | separate | hybrid
  standingsModel                    String   @default("unified") @db.VarChar(24)
  mergedRookieCollegeDraft          Boolean  @default(false)
  /// NFL only: exclude K/DST from college pool (default true = exclude)
  nflCollegeExcludeKDST             Boolean  @default(true)
  /// Pro lineup/bench/IR stored in League.settings or here; optional override
  proLineupSlots                    Json?
  proBenchSize                      Int      @default(12)
  proIRSize                         Int      @default(3)
  startupDraftType                  String   @default("snake") @db.VarChar(16)
  rookieDraftType                   String   @default("snake") @db.VarChar(16)
  collegeDraftType                  String   @default("snake") @db.VarChar(16)
  rookiePickOrderMethod             String   @default("reverse_standings") @db.VarChar(32)
  collegePickOrderMethod            String   @default("reverse_standings") @db.VarChar(32)
  /// PROMPT 3: Hybrid championship — weight for pro season (0–100); college = 100 - hybridProWeight.
  hybridProWeight                   Int      @default(60)
  /// PROMPT 3: Hybrid championship — playoff qualification: pro_only | college_only | combined | weighted.
  hybridPlayoffQualification        String   @default("weighted") @db.VarChar(32)
  /// PROMPT 3: Hybrid championship tie-breaker: pro_first | college_first | total_points | head_to_head.
  hybridChampionshipTieBreaker      String   @default("total_points") @db.VarChar(32)
  /// PROMPT 3: College free agency enabled (NCAA-eligible, unrostered only).
  collegeFAEnabled                  Boolean  @default(false)
  /// PROMPT 3: Separate college FAAB budget when true; otherwise shared with pro.
  collegeFAABSeparate               Boolean  @default(false)
  /// PROMPT 3: College FAAB budget per roster when collegeFAABSeparate (optional cap).
  collegeFAABBudget                 Int?
  createdAt                         DateTime @default(now())
  updatedAt                         DateTime @updatedAt

  @@map("c2c_league_configs")
}

model C2CScoringLog {
  id            String   @id @default(uuid())
  leagueId      String   @db.VarChar(64)
  rosterId      String   @db.VarChar(64)
  devyPlayerId  String   @db.VarChar(64)
  gameId        String   @default("season") @db.VarChar(64)
  season        Int
  week          Int
  points        Float
  scoringSystem String   @default("ppr") @db.VarChar(24)
  breakdown     Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, rosterId, devyPlayerId, season, week, gameId])
  @@index([leagueId, week])
  @@index([rosterId, season, week])
  @@index([devyPlayerId, season])
  @@map("c2c_scoring_logs")
}

// ========== Campus 2 Canton (C2C) league engine — dual roster scoring ==========

model C2CLeague {
  id       String @id @default(cuid())
  leagueId String @unique
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  isDynastyOnly     Boolean @default(true)
  createdByTheCiege Boolean @default(true)

  sportPair String @default("NFL_CFB")

  scoringMode       String @default("combined_total")
  campusScoreWeight Float  @default(0.4)
  cantonScoreWeight Float  @default(0.6)

  campusStarterSlots Int @default(8)
  cantonStarterSlots Int @default(8)
  benchSlots         Int @default(8)
  taxiSlots          Int @default(4)
  devySlots          Int @default(6)
  irSlots            Int @default(2)

  taxiRookieOnly         Boolean   @default(true)
  taxiMaxExperienceYears Int       @default(1)
  taxiLockDeadline       DateTime?
  taxiPointsVisible      Boolean   @default(true)

  devyScoringEnabled Boolean @default(false)

  startupDraftFormat String @default("split_campus_canton")
  futureDraftFormat  String @default("combined")

  footballCampusLockDay String @default("saturday_kickoff")
  footballCantonLockDay String @default("sunday_kickoff_per_player")
  basketballLineupFreq  String @default("weekly")

  season Int @default(2025)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  playerStates  C2CPlayerState[]
  matchupScores C2CMatchupScore[]
  draftPicks    C2CDraftPick[]

  @@index([leagueId])
  @@index([sportPair])
  @@map("c2c_leagues")
}

model C2CPlayerState {
  id        String        @id @default(cuid())
  leagueId  String
  c2cLeague C2CLeague     @relation(fields: [leagueId], references: [leagueId], onDelete: Cascade)
  rosterId  String
  roster    RedraftRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  playerId   String
  playerName String
  position   String
  /// Sport key for PlayerWeeklyScore lookup (e.g. NFL, NBA, NCAAF, NCAAB).
  sport      String @default("NFL")

  playerSide String
  playerType String @default("active")

  bucketState        String @default("bench")
  scoringEligibility String

  school                   String?
  schoolLogoUrl            String?
  classYear                String?
  projectedDeclarationYear Int?
  hasEnteredPro            Boolean @default(false)
  proEntryYear             Int?
  proEntryMethod           String?

  nflNbaTeam       String?
  isRookieEligible Boolean @default(false)
  isTaxiEligible   Boolean @default(false)
  taxiYearsUsed    Int     @default(0)

  transitionedFrom String?
  transitionedAt   DateTime?
  transitionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leagueId, rosterId, playerId])
  @@index([leagueId, playerSide, bucketState])
  @@map("c2c_player_states")
}

model C2CMatchupScore {
  id        String    @id @default(cuid())
  leagueId  String
  c2cLeague C2CLeague @relation(fields: [leagueId], references: [leagueId], onDelete: Cascade)

  matchupId String
  matchup   RedraftMatchup @relation(fields: [matchupId], references: [id], onDelete: Cascade)

  rosterId String
  week     Int
  season   Int

  campusStarterScore Float @default(0)
  cantonStarterScore Float @default(0)

  benchDisplayScore Float @default(0)
  taxiDisplayScore  Float @default(0)
  devyDisplayScore  Float @default(0)

  officialTeamScore Float @default(0)

  campusMatchupResult String?
  cantonMatchupResult String?

  isFinalized Boolean   @default(false)
  finalizedAt DateTime?

  @@unique([leagueId, matchupId, rosterId])
  @@index([leagueId, week])
  @@map("c2c_matchup_scores")
}

model C2CDraftPick {
  id        String    @id @default(cuid())
  leagueId  String
  c2cLeague C2CLeague @relation(fields: [leagueId], references: [leagueId], onDelete: Cascade)

  pickSide        String
  season          Int
  round           Int
  originalOwnerId String
  currentOwnerId  String

  isTradeable    Boolean   @default(true)
  isUsed         Boolean   @default(false)
  usedOnPlayerId String?
  usedAt         DateTime?
  tradeHistory   Json?

  @@unique([leagueId, pickSide, season, round, originalOwnerId])
  @@index([leagueId, currentOwnerId])
  @@index([leagueId, pickSide, season])
  @@map("c2c_draft_picks")
}

model C2CTransitionRecord {
  id       String @id @default(cuid())
  leagueId String
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  rosterId   String?
  playerId   String
  playerName String

  fromState String
  toState   String

  proEntryYear   Int
  proEntryMethod String

  destinationBucket String

  wasAutoTransitioned  Boolean   @default(false)
  commissionerApproved Boolean   @default(false)
  approvedAt           DateTime?
  notes                String?
  transitionedAt       DateTime?

  @@index([leagueId, proEntryYear])
  @@map("c2c_transition_records")
}

/// Per-roster status in a Zombie league (Survivor | Zombie | Whisperer).
model ZombieLeagueTeam {
  id               String        @id @default(uuid())
  leagueId         String        @db.VarChar(64)
  zombieLeagueId   String?
  zombieLeague     ZombieLeague? @relation(fields: [zombieLeagueId], references: [id], onDelete: SetNull)
  rosterId         String        @db.VarChar(64)
  status           String        @default("Survivor") @db.VarChar(24) // Survivor | Zombie | Whisperer
  weekBecameZombie Int? // first week as Zombie
  killedByRosterId String?       @db.VarChar(64)
  revivedAt        DateTime? // when revived from Zombie to Survivor
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  displayName           String?
  avatarUrl             String?
  fantasyTeamName       String?
  statusHistory         Json?
  killedByUserId        String?
  killedAtWeek          Int?
  infectionCount        Int     @default(0)
  isWhisperer           Boolean @default(false)
  ambushesRemaining     Int     @default(0)
  ambushesUsed          Int     @default(0)
  wins                  Int     @default(0)
  losses                Int     @default(0)
  pointsFor             Float   @default(0)
  pointsAgainst         Float   @default(0)
  weeklyWinnings        Float   @default(0)
  totalWinnings         Float   @default(0)
  isVeteran             Boolean @default(false)
  yearsInLeague         Int     @default(1)
  universeTierId        String?
  redraftRosterId       String?
  /// Cumulative zombie attacks survived without infection (gun unlock).
  zombieAttacksSurvived Int     @default(0)
  /// Consecutive weeks won as Survivor (bomb unlock).
  survivorWinStreak     Int     @default(0)

  items ZombieTeamItem[]

  @@unique([leagueId, rosterId])
  @@index([leagueId])
  @@index([zombieLeagueId])
  @@index([rosterId])
  @@index([status])
  @@map("zombie_league_teams")
}

model ZombieTeamItem {
  id             String           @id @default(cuid())
  teamStatusId   String
  team           ZombieLeagueTeam @relation(fields: [teamStatusId], references: [id], onDelete: Cascade)
  zombieLeagueId String
  userId         String

  itemType        String
  itemLabel       String
  isUsed          Boolean  @default(false)
  isExpired       Boolean  @default(false)
  acquiredAt      DateTime @default(now())
  acquiredReason  String?
  usedAtWeek      Int?
  usedOnUserId    String?
  usedEffect      String?
  /// ready | pending_activation — serum registers before kickoff, resolves at score finalization.
  activationState String   @default("ready")
  activatesAtWeek Int?

  @@index([teamStatusId])
  @@index([zombieLeagueId, userId])
  @@map("zombie_team_items")
}

/// Infection event: Survivor -> Zombie (loss to Whisperer or Zombie).
model ZombieInfectionLog {
  id                 String        @id @default(cuid())
  leagueId           String        @db.VarChar(64)
  zombieLeagueId     String?
  zombieLeague       ZombieLeague? @relation(fields: [zombieLeagueId], references: [id], onDelete: SetNull)
  week               Int
  survivorRosterId   String        @db.VarChar(64)
  infectedByRosterId String        @db.VarChar(64)
  matchupId          String?       @db.VarChar(64)
  reversedAt         DateTime? // stat correction reversal
  createdAt          DateTime      @default(now())

  @@index([leagueId, week])
  @@index([zombieLeagueId])
  @@index([survivorRosterId])
  @@map("zombie_infection_logs")
}

/// Serums, weapons, ambush balance and ledger (per league or universe).
model ZombieResourceLedger {
  id             String        @id @default(uuid())
  leagueId       String        @db.VarChar(64)
  zombieLeagueId String?
  zombieLeague   ZombieLeague? @relation(fields: [zombieLeagueId], references: [id], onDelete: SetNull)
  rosterId       String        @db.VarChar(64)
  resourceType   String        @db.VarChar(32) // serum | weapon | ambush
  resourceKey    String?       @db.VarChar(64) // e.g. weapon tier
  balance        Int           @default(0)
  awardedInWeek  Int? // week awarded (for ledger line)
  spentAt        DateTime?
  metadata       Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([leagueId, rosterId, resourceType])
  @@index([zombieLeagueId])
  @@map("zombie_resource_ledgers")
}

/// Ledger line for resource award/spend (append-only).
model ZombieResourceLedgerEntry {
  id             String   @id @default(cuid())
  leagueId       String   @db.VarChar(64)
  rosterId       String   @db.VarChar(64)
  resourceType   String   @db.VarChar(32)
  resourceKey    String?  @db.VarChar(64)
  delta          Int // +1 award, -1 spend
  reason         String   @db.VarChar(64) // high_score | bash | maul | revive | ambush | transfer
  week           Int?
  targetRosterId String?  @db.VarChar(64)
  createdAt      DateTime @default(now())

  @@index([leagueId, rosterId])
  @@index([leagueId, week])
  @@map("zombie_resource_ledger_entries")
}

/// Weekly winnings per roster (from matchups, bonuses).
model ZombieWeeklyWinnings {
  id             String        @id @default(uuid())
  leagueId       String        @db.VarChar(64)
  zombieLeagueId String?
  zombieLeague   ZombieLeague? @relation(fields: [zombieLeagueId], references: [id], onDelete: SetNull)
  rosterId       String        @db.VarChar(64)
  week           Int
  amount         Float         @default(0)
  source         String?       @db.VarChar(64) // matchup | bonus | bash | maul
  createdAt      DateTime      @default(now())

  @@unique([leagueId, rosterId, week])
  @@index([zombieLeagueId])
  @@index([leagueId, week])
  @@map("zombie_weekly_winnings")
}

/// Movement projection: who moves up/down next year (computed or stored).
model ZombieMovementProjection {
  id               String   @id @default(uuid())
  universeId       String   @db.VarChar(64)
  rosterId         String   @db.VarChar(64)
  leagueId         String   @db.VarChar(64)
  currentLevelId   String?  @db.VarChar(64)
  projectedLevelId String?  @db.VarChar(64)
  reason           String?  @db.VarChar(64) // promotion | relegation | watch
  season           Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([universeId, rosterId, season])
  @@index([universeId])
  @@index([leagueId])
  @@map("zombie_movement_projections")
}

/// Ambush event: Whisperer remapped matchup (logged).
model ZombieAmbushEvent {
  id                String       @id @default(cuid())
  zombieLeagueId    String
  zombieLeague      ZombieLeague @relation(fields: [zombieLeagueId], references: [id], onDelete: Cascade)
  week              Int
  whispererRosterId String       @db.VarChar(64)
  fromMatchupId     String?      @db.VarChar(64)
  toMatchupId       String?      @db.VarChar(64)
  targetRosterId    String?      @db.VarChar(64)
  metadata          Json?
  createdAt         DateTime     @default(now())

  @@index([zombieLeagueId, week])
  @@map("zombie_ambush_events")
}

/// Zombie audit log: infection, revive, serum/weapon/ambush, movement, overrides.
model ZombieAuditLog {
  id             String          @id @default(cuid())
  leagueId       String          @db.VarChar(64)
  universeId     String?         @db.VarChar(64)
  universe       ZombieUniverse? @relation(fields: [universeId], references: [id], onDelete: SetNull)
  zombieLeagueId String?
  zombieLeague   ZombieLeague?   @relation(fields: [zombieLeagueId], references: [id], onDelete: SetNull)
  eventType      String          @db.VarChar(64)
  metadata       Json?
  createdAt      DateTime        @default(now())

  @@index([leagueId])
  @@index([universeId])
  @@index([zombieLeagueId])
  @@index([eventType])
  @@map("zombie_audit_logs")
}

/// Multi-sport: roster template per sport/format (slot definitions)
model RosterTemplate {
  id         String               @id @default(cuid())
  sportType  String               @db.VarChar(12)
  name       String               @db.VarChar(64)
  formatType String               @db.VarChar(32)
  createdAt  DateTime             @default(now())
  slots      RosterTemplateSlot[]

  @@unique([sportType, formatType], name: "uniq_roster_template_sport_format")
  @@index([sportType])
  @@map("roster_templates")
}

model RosterTemplateSlot {
  id               String         @id @default(cuid())
  templateId       String
  template         RosterTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  slotName         String         @db.VarChar(32)
  allowedPositions Json
  starterCount     Int            @default(0)
  benchCount       Int            @default(0)
  reserveCount     Int            @default(0)
  taxiCount        Int            @default(0)
  devyCount        Int            @default(0)
  isFlexibleSlot   Boolean        @default(false)
  slotOrder        Int            @default(0)

  @@index([templateId])
  @@map("roster_template_slots")
}

/// League-specific roster config (template + overrides)
model LeagueRosterConfig {
  id         String   @id @default(cuid())
  leagueId   String   @unique @db.VarChar(64)
  templateId String
  overrides  Json?
  createdAt  DateTime @default(now())

  @@index([leagueId])
  @@map("league_roster_configs")
}

/// Multi-sport: scoring template per sport/format
model ScoringTemplate {
  id         String        @id @default(cuid())
  sportType  String        @db.VarChar(12)
  name       String        @db.VarChar(64)
  formatType String        @db.VarChar(32)
  createdAt  DateTime      @default(now())
  rules      ScoringRule[]

  @@unique([sportType, formatType], name: "uniq_scoring_template_sport_format")
  @@index([sportType])
  @@map("scoring_templates")
}

model ScoringRule {
  id          String          @id @default(cuid())
  templateId  String
  template    ScoringTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  statKey     String          @db.VarChar(48)
  pointsValue Float           @default(0)
  multiplier  Float           @default(1)
  enabled     Boolean         @default(true)

  @@index([templateId])
  @@index([templateId, statKey])
  @@map("scoring_rules")
}

/// League-level scoring overrides (optional)
model LeagueScoringOverride {
  id          String  @id @default(cuid())
  leagueId    String  @db.VarChar(64)
  statKey     String  @db.VarChar(48)
  pointsValue Float   @default(0)
  enabled     Boolean @default(true)

  @@unique([leagueId, statKey], name: "uniq_league_scoring_override_league_stat")
  @@index([leagueId])
  @@map("league_scoring_overrides")
}

/// Sport-level feature flags: which league options are valid for this sport (PROMPT 2/4).
/// Commissioners can override only where the sport allows; validation uses these flags.
model SportFeatureFlags {
  id                    String   @id @default(cuid())
  sportType             String   @unique @db.VarChar(12)
  supportsBestBall      Boolean  @default(false)
  supportsSuperflex     Boolean  @default(false)
  supportsTePremium     Boolean  @default(false)
  supportsKickers       Boolean  @default(false)
  supportsTeamDefense   Boolean  @default(false)
  supportsIdp           Boolean  @default(false)
  supportsWeeklyLineups Boolean  @default(true)
  supportsDailyLineups  Boolean  @default(false)
  supportsBracketMode   Boolean  @default(false)
  supportsDevy          Boolean  @default(false)
  supportsTaxi          Boolean  @default(false)
  supportsIr            Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("sport_feature_flags")
}

/// Fantasy schedule structure: matchup type, regular/playoff weeks, lock mode (PROMPT 3/4).
/// Separate from real-world season metadata. One default per sport (formatType = 'DEFAULT').
model ScheduleTemplate {
  id                    String   @id @default(cuid())
  sportType             String   @db.VarChar(12)
  name                  String   @db.VarChar(64)
  formatType            String   @db.VarChar(32)
  matchupType           String   @db.VarChar(48)
  regularSeasonWeeks    Int      @default(14)
  playoffWeeks          Int      @default(3)
  byeWeekWindow         Json? // e.g. { start: 5, end: 14 }
  fantasyPlayoffDefault Json? // e.g. { startWeek: 15, endWeek: 17 }
  lineupLockMode        String?  @db.VarChar(32) // weekly | daily
  scoringMode           String?  @db.VarChar(48) // head_to_head_points | roto | etc.
  regularSeasonStyle    String?  @db.VarChar(48) // weekly | long-form | short season | season+tournament
  playoffSupport        Boolean  @default(true)
  bracketModeSupported  Boolean  @default(false)
  marchMadnessMode      Boolean  @default(false)
  bowlPlayoffMetadata   Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([sportType, formatType], name: "uniq_schedule_template_sport_format")
  @@index([sportType])
  @@map("schedule_templates")
}

/// Real-world season calendar: preseason, regular season, playoffs (PROMPT 3/4).
/// One default per sport (formatType = 'DEFAULT').
model SeasonCalendar {
  id                           String   @id @default(cuid())
  sportType                    String   @db.VarChar(12)
  name                         String   @db.VarChar(64)
  formatType                   String   @db.VarChar(32)
  preseasonPeriod              Json? // e.g. { monthStart: 8, monthEnd: 8, label: "August" }
  regularSeasonPeriod          Json // e.g. { monthStart: 9, monthEnd: 1, label: "Sep–Jan" }
  playoffsPeriod               Json? // e.g. { monthStart: 10, monthEnd: 10 }
  championshipPeriod           Json? // e.g. super_bowl: Feb, world_series: late Oct
  internationalBreaksSupported Boolean  @default(false)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@unique([sportType, formatType], name: "uniq_season_calendar_sport_format")
  @@index([sportType])
  @@map("season_calendars")
}

/// Multi-sport: scheduled games for schedule/stats pipeline
model GameSchedule {
  id          String    @id @default(cuid())
  sportType   String    @db.VarChar(12)
  season      Int
  weekOrRound Int
  externalId  String    @db.VarChar(64)
  homeTeamId  String?   @db.VarChar(32)
  awayTeamId  String?   @db.VarChar(32)
  homeTeam    String?   @db.VarChar(16)
  awayTeam    String?   @db.VarChar(16)
  startTime   DateTime?
  venue       String?   @db.VarChar(128)
  weather     Json?
  homeScore   Int?      @map("home_score")
  awayScore   Int?      @map("away_score")
  status      String    @db.VarChar(24)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([sportType, season, weekOrRound, externalId], name: "uniq_game_schedule_sport_season_week_external")
  @@index([sportType, season, weekOrRound])
  @@index([sportType, season])
  @@index([startTime])
  @@map("game_schedules")
}

/// Multi-sport: player stats per game (normalized for fantasy calculation)
model PlayerGameStat {
  id                String   @id @default(cuid())
  playerId          String   @db.VarChar(64)
  sportType         String   @db.VarChar(12)
  gameId            String   @db.VarChar(64)
  season            Int
  weekOrRound       Int
  statPayload       Json     @map("stat_payload")
  normalizedStatMap Json     @map("normalized_stat_map")
  fantasyPoints     Float    @default(0)
  updatedAt         DateTime @updatedAt

  @@unique([playerId, sportType, gameId], name: "uniq_player_game_stat_player_sport_game")
  @@index([sportType, season, weekOrRound])
  @@index([playerId, sportType, season])
  @@map("player_game_stats")
}

/// Multi-sport: team-level game stats (optional aggregate)
model TeamGameStat {
  id          String   @id @default(cuid())
  sportType   String   @db.VarChar(12)
  gameId      String   @db.VarChar(64)
  teamId      String   @db.VarChar(32)
  season      Int
  weekOrRound Int
  statPayload Json     @map("stat_payload")
  updatedAt   DateTime @updatedAt

  @@unique([sportType, gameId, teamId], name: "uniq_team_game_stat_sport_game_team")
  @@index([sportType, season, weekOrRound])
  @@map("team_game_stats")
}

/// Multi-sport: stat ingestion job tracking
model StatIngestionJob {
  id           String    @id @default(cuid())
  sportType    String    @db.VarChar(12)
  season       Int
  weekOrRound  Int?
  source       String    @db.VarChar(32)
  status       String    @db.VarChar(24)
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
