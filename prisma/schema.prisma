  amount         Int?
  source         String?      @default("user")
  createdAt      DateTime     @default(now())
  roundPick      Int?
  ownerUserId    String?
  playerImageUrl String?
  pickedAt       DateTime?
  sportType      String?      @db.VarChar(16)
