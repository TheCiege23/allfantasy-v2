/// AI integrity monitoring — collusion / tanking flags (no chat content; evidence is on-field only).
model IntegrityFlag {
  id                String   @id @default(cuid())
  leagueId          String
  flagType          String // collusion | tanking
  severity          String // low | medium | high
  status            String   @default("open") // open | commissioner_reviewed | dismissed | escalated
  affectedRosterIds String[]
  affectedTeamNames String[]
  summary           String   @db.Text
  evidenceJson      Json
  aiConfidence      Float

  tradeTransactionId String?

  commissionerNote   String?   @db.Text
  commissionerUserId String?
  reviewedAt         DateTime?
  notifiedAt         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId, status])
  @@index([leagueId, flagType])
  @@index([createdAt])
  @@map("integrity_flags")
}

model LeagueIntegritySettings {
  id       String @id @default(cuid())
  leagueId String @unique
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  collusionMonitoringEnabled Boolean @default(true)
