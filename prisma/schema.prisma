  @@index([seasonId, scoringPeriod])
  @@index([rosterId])
  @@map("guillotine_survival_logs")
}

model GuillotineWaiverRelease {
  id                 String           @id @default(cuid())
  seasonId           String
  leagueId           String
  eliminatedRosterId String
  scoringPeriod      Int
  playerId           String
  playerName         String
  position           String
  team               String?
  sport              String
  releaseStatus      String           @default("pending")
  availableAt        DateTime
  claimedByRosterId  String?
  claimedAt          DateTime?
  winningBid         Float?
  season             GuillotineSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([seasonId, releaseStatus])
  @@index([leagueId, scoringPeriod])
  @@map("guillotine_waiver_releases")
}

model GuillotineAIInsight {
  id            String           @id @default(cuid())
  leagueId      String
  seasonId      String
  scoringPeriod Int?
  rosterId      String?
  type          String
  content       Json
  narrative     String?
  generatedAt   DateTime         @default(now())
  league        League           @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season        GuillotineSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([seasonId, type])
  @@index([rosterId, type])
  @@map("guillotine_ai_insights")
}

model WeatherCache {
  id               String   @id @default(cuid())
  cacheKey         String   @unique
  latitude         Float
  longitude        Float
  forecastForTime  DateTime
  fetchedAt        DateTime @default(now())
  expiresAt        DateTime
  temperatureF     Float?
  feelsLikeF       Float?
  windSpeedMph     Float?
  windGustsMph     Float?
  windDirectionDeg Float?
  precipChancePct  Float?
  rainInches       Float?
  snowInches       Float?
  humidityPct      Float?
  visibilityMiles  Float?
  conditionCode    String?
  conditionLabel   String?
  cloudCoverPct    Float?
  isIndoor         Boolean  @default(false)
  isDome           Boolean  @default(false)
  roofClosed       Boolean  @default(false)
  sport            String?
  eventId          String?
  dataSource       String   @default("openweathermap")
  apiResponseRaw   Json?

  @@index([cacheKey])
  @@index([fetchedAt])
  @@index([forecastForTime])
}

model AFProjectionSnapshot {
  id                 String    @id @default(cuid())
  playerId           String
  playerName         String
  sport              String
  position           String
  week               Int?
  season             Int
  eventId            String?
  baselineProjection Float
  weatherAdjustment  Float     @default(0)
  afProjection       Float
  weatherCacheId     String?
  adjustmentFactors  Json?
  adjustmentReason   String?
  confidenceLevel    String    @default("medium")
  isOutdoorGame      Boolean   @default(true)
  venueOverride      Boolean   @default(false)
  computedAt         DateTime  @default(now())
  validUntil         DateTime?
  /// Stable key: `${playerId}|${season}|${week ?? 'w'}|${eventId ?? 'none'}`
  snapshotLookupKey  String    @unique

  @@index([playerId, week, season])
  @@index([sport, week, season])
}

/// Normalized settings row for leagues created via the redraft-only creation API (1:1 with League).
model RedraftLeagueExtendedSettings {
  id                          String   @id @default(cuid())
  leagueId                    String   @unique
  commissionerTradeReviewType String   @default("commissioner")
  languageCode                String   @default("en")
  scoringTypeDefault          String?
  waiverTypeDefault           String?
  rosterPresetKey             String?
  playoffPresetKey            String?
  draftTimerSecondsDefault    Int?
  isPublic                    Boolean  @default(false)
  allowInviteLinks            Boolean  @default(true)
  settingsJson                Json     @default("{}")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  league                      League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@map("redraft_league_extended_settings")
}

/// Draft shell persisted at redraft create (complements `LeagueSettings` / `DraftSession`).
model RedraftLeagueDraftProfile {
  id            String    @id @default(cuid())
  leagueId      String    @unique
  draftType     String
  isOffline     Boolean   @default(false)
  isAuto        Boolean   @default(false)
  rounds        Int       @default(15)
  timerSeconds  Int?
  orderMode     String?
  auctionBudget Int?
  scheduledAt   DateTime?
  draftStatus   String    @default("pre_draft")
  configJson    Json      @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  league        League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@map("redraft_league_draft_profiles")
}

model RedraftLeagueHomepageState {
  id                 String   @id @default(cuid())
  leagueId           String   @unique
  activeTab          String   @default("overview")
  onboardingComplete Boolean  @default(false)
  chatEnabled        Boolean  @default(true)
  draftRoomEnabled   Boolean  @default(true)
  paymentEnabled     Boolean  @default(false)
  homepageConfigJson Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  league             League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@map("redraft_league_homepage_states")
}

model RedraftLeagueSportIntegration {
  id                    String                 @id @default(cuid())
  leagueId              String                 @unique
  sport                 String
  standingsEnabled      Boolean                @default(true)
  schedulesEnabled      Boolean                @default(true)
  injuriesEnabled       Boolean                @default(true)
  newsEnabled           Boolean                @default(true)
  weatherEnabled        Boolean                @default(false)
  playerPoolSource      String?
  gameFeedSource        String?
  integrationConfigJson Json                   @default("{}")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  /// SOCCER only: MLS vs European data pipeline (null for non-soccer leagues).
  soccerPipelineVariant SoccerPipelineVariant?
  league                League                 @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@map("redraft_league_sport_integrations")
}

model RedraftLeagueChatRoom {
  id        String   @id @default(cuid())
  leagueId  String
  roomType  String   @default("league")
  title     String   @default("League chat")
  createdAt DateTime @default(now())
  league    League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@index([leagueId])
  @@map("redraft_league_chat_rooms")
}

model LeagueEntrySlot {
  id         String                @id @default(cuid())
  leagueId   String
  slotNumber Int
  rosterId   String?               @db.VarChar(64)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  status     LeagueEntrySlotStatus @default(OPEN)
  league     League                @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, slotNumber])
  @@index([leagueId])
  @@map("league_entry_slots")
}

model RedraftLeagueMember {
  id         String                  @id @default(cuid())
  leagueId   String
  userId     String
  teamNumber Int?
  joinedAt   DateTime                @default(now())
  createdAt  DateTime                @default(now())
  role       RedraftLeagueMemberRole @default(COMMISSIONER)
  league     League                  @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId])
  @@index([userId])
  @@map("redraft_league_members")
}

/// Soccer data region for redraft creation + integration rows (maps API `mls` / `euro`).
enum SoccerPipelineVariant {
  MLS
  EURO
}

enum LeagueEntrySlotStatus {
  OPEN
  FILLED
  RESERVED
}

enum RedraftLeagueMemberRole {
  COMMISSIONER
  MEMBER
}

enum FeedbackReason {
  OVERVALUED
  TOO_RISKY
  NOT_MY_STYLE
  BAD_ROSTER_FIT
  OTHER
}

enum VoteType {
  UP
  DOWN
}

enum TradeOfferMode {
  INSTANT
  STRUCTURED
  TRADE_HUB
  TRADE_IDEAS
  PROPOSAL_GENERATOR
}

enum TradeOutcome {
  ACCEPTED
  REJECTED
  EXPIRED
  COUNTERED
  UNKNOWN
}

enum VerificationMethod {
  EMAIL
  PHONE
}

enum LeagueSport {
  NFL
  NBA
  MLB
  NHL
  NCAAF
  NCAAB
  SOCCER
}
