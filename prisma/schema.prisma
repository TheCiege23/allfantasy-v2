  rightsExpirationEnabled     Boolean  @default(false)
  /// PROMPT 3: When player returns to school: restore_rights | hold_rights | commissioner
  returnToSchoolHandling      String   @default("restore_rights") @db.VarChar(32)
  /// PROMPT 4: When best ball is ON, if true then taxi-eligible pro rookies can contribute to best ball lineup; otherwise taxi players do not score.
  taxiProRookiesScoreInBestBall Boolean @default(false)
  /// PROMPT 4: Superflex slot in best ball (NFL). When true, lineup has SUPER_FLEX in addition to FLEX.
  bestBallSuperflex           Boolean  @default(false)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@map("devy_league_configs")
}

/// PROMPT 3: Per-roster devy rights and lifecycle state. One row per (league, roster, devyPlayer) when a manager holds devy rights.
model DevyRights {
  id                  String   @id @default(uuid())
  leagueId             String   @db.VarChar(64)
  rosterId             String   @db.VarChar(64)
  devyPlayerId         String   @db.VarChar(64)
  /// Lifecycle: NCAA_DEVY_ACTIVE | NCAA_DEVY_TAXI | NCAA_DEVY_LOCKED | DECLARED | DRAFTED_RIGHTS_HELD | PROMOTION_ELIGIBLE | PROMOTED_TO_PRO | RETURNED_TO_SCHOOL | RIGHTS_EXPIRED | ORPHANED_RIGHTS
  state                String   @db.VarChar(32)
  seasonYear           Int?     // year of declaration/draft when relevant
  /// After promotion, pro player id (SportsPlayer or platform) when mapped
  promotedProPlayerId  String?  @db.VarChar(64)
  promotedAt           DateTime?
  /// When manager chose promotion (if timing = manager_choice_before_rookie_draft)
  managerPromotedAt    DateTime?
  /// If returned to school, restored to NCAA devy state
  returnedToSchoolAt   DateTime?
  /// Source confidence for declare/draft mapping (0-100)
  sourceConfidence     Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  league  League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  roster  Roster  @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  @@unique([leagueId, rosterId, devyPlayerId])
  @@index([leagueId])
  @@index([rosterId])
  @@index([devyPlayerId])
  @@index([state])
  @@index([leagueId, state])
  @@map("devy_rights")
}

