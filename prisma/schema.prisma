  rosterId    String          @db.VarChar(64)
  periodKey   String          @db.VarChar(32)
  totalPoints Float?
  /// Array of { playerId: string, slotName: string } in optimal lineup order
  starterIds  Json
  createdAt   DateTime        @default(now())

  @@unique([leagueId, rosterId, periodKey])
  @@index([leagueId])
  @@index([rosterId])
  @@map("idp_best_ball_lineup_snapshots")
