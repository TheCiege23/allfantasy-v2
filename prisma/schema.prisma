  @@index([configId])
  @@index([createdAt])
  @@map("idp_settings_audit_logs")
}

// ========== Devy Dynasty League Engine (PROMPT 2/6) ==========

/// Devy Dynasty league config. Sport adapter derived from League.sport (nfl_devy | nba_devy).
model DevyLeagueConfig {
  id                          String   @id @default(uuid())
  leagueId                    String   @unique @db.VarChar(64)
  league                      League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  /// Format flags (all true for devy_dynasty).
  dynastyOnly                 Boolean  @default(true)
  supportsStartupVetDraft     Boolean  @default(true)
  supportsRookieDraft         Boolean  @default(true)
