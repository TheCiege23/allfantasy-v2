  survivorTieRule                       String?                                @default("revote_then_rocks")
  survivorTokenEnabled                  Boolean?                               @default(true)
  survivorTribeCount                    Int?                                   @default(4)
  survivorTribeNaming                   String?                                @default("auto")
  survivorTribeSize                     Int?                                   @default(5)
  survivorWeeklyMessages                Boolean?                               @default(true)
  /// Optional cap on exile token balance (null = no cap).
