  tokensCompletion Int?
  createdAt        DateTime @default(now())

  @@index([provider, role, taskType])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model GuardianIntervention {
  id                String   @id @default(uuid())
  userId            String   @db.VarChar(64)
