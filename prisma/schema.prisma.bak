model ChatConversation {
  id              String   @id @default(uuid())
  userId          String
  sleeperUsername String?
  title           String?
  messageCount    Int      @default(0)
  lastMessageAt   DateTime @default(now())
  dataSources     Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([sleeperUsername])
  @@index([lastMessageAt])
  @@map("chat_conversations")
}

model WeeklyMatchup {
  id            String @id @default(cuid())
  leagueId      String @db.VarChar(64)
  seasonYear    Int
  week          Int
  rosterId      Int
  matchupId     Int?
  pointsFor     Float
  pointsAgainst Float
  win           Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leagueId, seasonYear, week, rosterId])
  @@index([leagueId, seasonYear, week])
  @@index([leagueId, seasonYear, rosterId])
}

model RankingsSnapshot {
  id           BigInt   @id @default(autoincrement())
  leagueId     String
  season       String
  week         Int
  rosterId     String
  rank         Int
  composite    Decimal  @db.Decimal(10, 4)
  expectedWins Decimal? @db.Decimal(10, 4)
  luckDelta    Decimal? @db.Decimal(10, 4)
  metricsJson  Json?
  createdAt    DateTime @default(now())

  @@unique([leagueId, season, week, rosterId], name: "uniq_snapshot_league_season_week_roster")
  @@index([leagueId, season, week])
  @@index([leagueId, rosterId, createdAt])
  @@map("rankings_snapshots")
}

model RankingsWeightsSnapshot {
  id        String   @id @default(cuid())
  leagueId  String
  season    String
  week      Int
  weights   Json
  metrics   Json?
  reason    String?
  createdAt DateTime @default(now())

  @@index([leagueId, season, week])
  @@map("rankings_weights_snapshot")
}

model SeasonResult {
  id            String   @id @default(cuid())
  leagueId      String
  season        String
  rosterId      String
  wins          Int?
  losses        Int?
  pointsFor     Decimal? @db.Decimal(12, 2)
  pointsAgainst Decimal? @db.Decimal(12, 2)
  champion      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@unique([leagueId, season, rosterId], name: "uniq_season_result_league_season_roster")
  @@index([leagueId, season])
  @@index([leagueId, rosterId])
  @@map("season_results")
}

model DraftGrade {
  id        String   @id @default(cuid())
  leagueId  String
  season    String
  rosterId  String
  grade     String
  score     Decimal  @db.Decimal(5, 2)
  breakdown Json
  createdAt DateTime @default(now())

  @@unique([leagueId, season, rosterId], name: "uniq_draft_grade_league_season_roster")
  @@index([leagueId, season])
  @@index([leagueId, rosterId, season])
  @@map("draft_grades")
}

model HallOfFameRow {
  id            String   @id @default(cuid())
  leagueId      String
  rosterId      String
  championships Int      @default(0)
  seasonsPlayed Int      @default(0)
  dominance     Decimal  @db.Decimal(10, 4)
  efficiency    Decimal  @db.Decimal(10, 4)
  longevity     Decimal  @db.Decimal(10, 4)
  score         Decimal  @db.Decimal(10, 4)
  updatedAt     DateTime @updatedAt

  @@unique([leagueId, rosterId], name: "uniq_hof_league_roster")
  @@index([leagueId, score])
  @@map("hall_of_fame")
}

model ApiUsageEvent {
  id BigInt   @id @default(autoincrement())
  ts DateTime @default(now())

  userId   String?
  username String?
  leagueId String?

  scope    String
  tool     String?
  endpoint String?
  method   String?
  status   Int?
  ok       Boolean?

  durationMs Int?
  bytesIn    Int?
  bytesOut   Int?

  meta Json?

  @@index([ts])
  @@index([scope, ts])
  @@index([endpoint, ts])
  @@index([tool, ts])
  @@index([leagueId, ts])
  @@index([userId, ts])
}

model ApiUsageRollup {
  id BigInt @id @default(autoincrement())

  bucketStart DateTime
  bucketType  String

  scope    String @default("")
  tool     String @default("")
  endpoint String @default("")
  leagueId String @default("")

  count    Int @default(0)
  okCount  Int @default(0)
  errCount Int @default(0)

  avgMs Int?
  p95Ms Int?
  maxMs Int?

  bytesInSum  BigInt? @default(0)
  bytesOutSum BigInt? @default(0)

  meta Json?

  updatedAt DateTime @updatedAt

  @@unique([bucketType, bucketStart, scope, tool, endpoint, leagueId], name: "uniq_usage_rollup_bucket_key")
  @@index([bucketType, bucketStart])
  @@index([scope, bucketType, bucketStart])
  @@index([endpoint, bucketType, bucketStart])
  @@index([tool, bucketType, bucketStart])
  @@index([leagueId, bucketType, bucketStart])
}

model Player {
  id        String  @id
  name      String
  sport     String
  position  String
  team      String?
  birthYear Int?

  league         String
  devyEligible   Boolean @default(false)
  graduatedToNFL Boolean @default(false)

  recruitingComposite  Float?
  breakoutAge          Float?
  draftProjectionScore Float?
  projectedDraftRound  Int?
  projectedDraftPick   Int?
  devyAdp              Float?
  redshirtStatus       Boolean @default(false)
  transferStatus       Boolean @default(false)
  nilImpactScore       Float?
  injurySeverityScore  Float?

  nflDraftRound Int?
  nflDraftPick  Int?
  nflTeam       String?

  active       Boolean @default(true)
  injuryStatus String?

  lastSyncedAt DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@index([league])
  @@index([devyEligible])
}

model DevyPlayer {
  id             String  @id @default(uuid())
  name           String
  normalizedName String
  position       String
  school         String
  conference     String?
  classYear      Int?
  heightInches   Int?
  weightLbs      Int?

  league            String  @default("NCAA")
  devyEligible      Boolean @default(true)
  graduatedToNFL    Boolean @default(false)
  draftYear         Int?
  draftEligibleYear Int?
  draftRound        Int?
  draftPick         Int?

  draftStatus       String    @default("college")
  statusSource      String?
  statusConfidence  Int       @default(0)
  statusUpdatedAt   DateTime?
  lastRosterYear    Int?
  declaredDraftYear Int?

  cfbdId    String?
  sleeperId String?
  nflTeam   String?

  passingYards   Int?
  passingTDs     Int?
  rushingYards   Int?
  rushingTDs     Int?
  receivingYards Int?
  receivingTDs   Int?
  receptions     Int?
  statSeason     Int?

  devyValue         Int    @default(0)
  projectedNFLValue Int?
  trend             String @default("stable")

  recruitingStars   Int?
  recruitingRanking Int?

  recruitingComposite  Float?
  breakoutAge          Float?
  draftProjectionScore Float?
  projectedDraftRound  Int?
  projectedDraftPick   Int?
  devyAdp              Float?
  redshirtStatus       Boolean @default(false)
  transferStatus       Boolean @default(false)
  transferFromSchool   String?
  transferToSchool     String?
  transferEligibility  String?
  nilImpactScore       Float?
  injurySeverityScore  Float?
  athleticProfileScore Float?
  productionIndex      Float?
  volatilityScore      Float?
  nflDraftRound        Int?
  nflDraftPick         Int?

  usageOverall     Float?
  usagePass        Float?
  usageRush        Float?
  ppaTotal         Float?
  ppaPass          Float?
  ppaRush          Float?
  wepaTotal        Float?
  wepaPass         Float?
  wepaRush         Float?
  returningProdPct Float?
  teamSpRating     Float?
  recruitingCity   String?
  recruitingState  String?

  devyAdpHistory DevyAdp[]

  source           String    @default("cfbd")
  lastClassifiedAt DateTime?
  lastSyncedAt     DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([normalizedName, position, school], name: "uniq_devy_player")
  @@index([devyEligible])
  @@index([league])
  @@index([position])
  @@index([draftEligibleYear])
  @@index([graduatedToNFL])
  @@index([cfbdId])
  @@index([draftStatus])
  @@index([draftProjectionScore])
}

model DevyAdp {
  id        String     @id @default(cuid())
  playerId  String
  player    DevyPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)
  adp       Float
  source    String
  season    Int
  updatedAt DateTime   @updatedAt

  @@unique([playerId, source, season])
  @@index([playerId])
  @@index([season])
}

model RookieClass {
  year      Int      @id
  strength  Float
  qbDepth   Float
  rbDepth   Float
  wrDepth   Float
  teDepth   Float
  updatedAt DateTime @updatedAt
}

model TradeOutcomeTraining {
  id               String @id @default(cuid())
  leagueId         String
  proposerRosterId String
  partnerRosterId  String

  fairnessScore   Float
  ldiAlignment    Float
  needsFitScore   Float
  archetypeMatch  Float
  dealShapeScore  Float
  volatilityDelta Float

  wasAccepted Boolean
  createdAt   DateTime @default(now())

  @@index([leagueId, createdAt])
  @@index([wasAccepted])
}

model TradeShare {
  id        String   @id @default(uuid())
  userId    String?
  analysis  Json
  sideA     Json
  sideB     Json
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
  @@index([userId, createdAt])
}

model EngineSnapshot {
  id        String   @id @default(cuid())
  leagueId  String
  type      String   @db.VarChar(32)
  hash      String   @db.VarChar(64)
  payload   Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([leagueId, type, hash])
  @@index([leagueId, type])
  @@index([expiresAt])
}

model PlayerAnalyticsSnapshot {
  id             String  @id @default(uuid())
  normalizedName String
  name           String
  position       String
  status         String?
  currentTeam    String?
  season         String

  // Combine & Athletic Metrics
  fortyYardDash     Float?
  twentyYardShuttle Float?
  threeConeDrill    Float?
  benchPress        Int?
  broadJump         Int?
  verticalJump      Float?
  athleticismScore  Float?
  speedScore        Float?
  burstScore        Float?
  agilityScore      Float?
  sparqX            Float?
  armLengthIn       Float?
  handSizeIn        Float?
  heightIn          Int?
  weightLb          Int?
  bmi               Float?
  catchRadius       Float?
  throwVelocityMph  Float?

  // College Production
  breakoutAge                   Float?
  breakoutRating                Float?
  breakoutYear                  Int?
  college                       String?
  collegeDominatorRating        Float?
  collegeDynamicScore           Float?
  collegeLevelOfCompetition     Float?
  collegeFreshmanYards          Float?
  collegeTargetShare            Float?
  collegeReceiverRating         String?
  collegeYpr                    Float?
  collegeTeammateScore          Float?
  bestCollegeSeasonYardageShare Float?

  // Draft Info
  draftPick       Float?
  draftYear       Int?
  currentAdp      Float?
  currentAdpTrend Float?
  lifetimeValue   Float?

  // Comparables
  bestComparablePlayers String?

  // Key Production & Fantasy
  totalFantasyPoints           Float?
  fantasyPointsPerGame         Float?
  expectedFantasyPoints        Float?
  expectedFantasyPointsPerGame Float?
  weeklyVolatility             Float?

  // All 355 columns stored as JSON
  rawData Json?

  source      String   @default("csv_import")
  dataVersion String   @default("v1")
  importedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([normalizedName, season, source])
  @@index([normalizedName])
  @@index([position])
  @@index([season])
  @@index([status])
  @@index([currentTeam])
}

model AppUser {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified DateTime?
  username      String    @unique
  passwordHash  String?
  displayName   String?
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  legacyUserId String?     @unique
  legacyUser   LegacyUser? @relation(fields: [legacyUserId], references: [id], onDelete: SetNull)

  accounts AuthAccount[]
  sessions AuthSession[]

  bracketLeaguesOwned     BracketLeague[]          @relation("BracketLeagueOwner")
  bracketMemberships      BracketLeagueMember[]
  bracketEntries          BracketEntry[]
  profile                 UserProfile?
  emailVerifyTokens       EmailVerifyToken[]
  passwordResetTokens     PasswordResetToken[]
  tradeFeedback           Feedback[]
  tradeProfile            TradeProfile?
  waiverPickups           WaiverPickup[]
  leagues                 League[]
  leagueAuths             LeagueAuth[]
  sleeperLeagues          SleeperLeague[]
  mockDrafts              MockDraft[]
  activeLeagueId          String?
  bracketLeagueMessages   BracketLeagueMessage[]   @relation("BracketLeagueMessages")
  bracketMessageReactions BracketMessageReaction[] @relation("BracketMessageReactions")
  bracketPayments         BracketPayment[]         @relation("BracketPayments")
  bracketRiskProfile      BracketRiskProfile?      @relation("BracketRiskProfile")

  platformChatThreadsCreated    PlatformChatThread[]       @relation("PlatformChatThreadCreator")
  platformChatThreadMemberships PlatformChatThreadMember[]
  platformChatMessages          PlatformChatMessage[]      @relation("PlatformChatMessageSender")
  platformNotifications         PlatformNotification[]
  walletAccount                 PlatformWalletAccount?
  walletLedgerEntries           WalletLedgerEntry[]

  @@map("app_users")
}

model AuthAccount {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model AuthSession {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model AuthVerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

model BracketTournament {
  id        String    @id @default(uuid())
  name      String
  season    Int
  sport     String
  lockAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  nodes    BracketNode[]
  leagues  BracketLeague[]
  payments BracketPayment[]

  @@unique([sport, season])
}

model BracketNode {
  id           String  @id @default(uuid())
  tournamentId String
  round        Int
  region       String?
  slot         String

  seedHome Int?
  seedAway Int?

  homeTeamName String?
  awayTeamName String?

  sportsGameId String? @unique

  nextNodeId   String?
  nextNodeSide String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tournament BracketTournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  picks      BracketPick[]

  @@unique([tournamentId, slot])
  @@index([tournamentId, round, region])
}

model BracketLeague {
  id           String    @id @default(uuid())
  tournamentId String
  ownerId      String
  name         String
  joinCode     String    @unique
  isPrivate    Boolean   @default(true)
  maxManagers  Int       @default(100)
  deadline     DateTime?
  scoringRules Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tournament BracketTournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  owner      AppUser           @relation("BracketLeagueOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  members  BracketLeagueMember[]
  entries  BracketEntry[]
  messages BracketLeagueMessage[]
  payments BracketPayment[]

  @@index([tournamentId])
  @@index([ownerId])
}

model BracketLeagueMember {
  id        String   @id @default(uuid())
  leagueId  String
  userId    String
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())

  league BracketLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   AppUser       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId])
  @@index([userId])
}

model BracketEntry {
  id               String    @id @default(uuid())
  leagueId         String
  userId           String
  name             String
  insuredNodeId    String?
  tiebreakerPoints Int?
  status           String    @default("SUBMITTED") // DRAFT | SUBMITTED | LOCKED | SCORED | INVALIDATED
  submittedAt      DateTime?
  lockedAt         DateTime?
  scoredAt         DateTime?
  invalidatedAt    DateTime?
  integrityHash    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  league    BracketLeague          @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user      AppUser                @relation(fields: [userId], references: [id], onDelete: Cascade)
  picks     BracketPick[]          @relation("EntryToPick")
  snapshots BracketEntrySnapshot[] @relation("EntryToSnapshot")

  @@index([leagueId])
  @@index([userId])
}

model BracketEntrySnapshot {
  id              String   @id @default(uuid())
  entryId         String
  tournamentId    String
  leagueId        String
  userId          String
  status          String
  lockedAt        DateTime
  version         Int      @default(1)
  bracketJson     Json
  bracketHash     String
  createdBySystem Boolean  @default(true)
  createdAt       DateTime @default(now())

  entry BracketEntry @relation("EntryToSnapshot", fields: [entryId], references: [id], onDelete: Cascade)

  @@index([tournamentId, leagueId])
  @@index([entryId, createdAt])
}

model BracketPickPopularity {
  id           String   @id @default(uuid())
  tournamentId String
  leagueId     String?
  nodeId       String
  round        Int
  teamName     String
  scope        String // "global" | "league"
  pickCount    Int
  pickPct      Float
  updatedAt    DateTime @default(now()) @updatedAt

  @@unique([tournamentId, leagueId, nodeId, teamName, scope])
  @@index([tournamentId, leagueId, nodeId])
  @@map("bracket_pick_popularity")
}

model BracketSimulationSnapshot {
  id                   String   @id @default(uuid())
  tournamentId         String
  leagueId             String
  entryId              String
  simulations          Int
  winLeagueProbability Float
  top5Probability      Float
  expectedRank         Float
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([tournamentId, leagueId, entryId])
  @@index([leagueId, entryId])
  @@map("bracket_simulation_snapshot")
}

model BracketLeaderboard {
  id           String   @id @default(uuid())
  tournamentId String
  leagueId     String?
  entryId      String
  score        Int
  rank         Int
  previousRank Int?
  tieGroup     Int
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@unique([tournamentId, leagueId, entryId])
  @@index([tournamentId, leagueId, rank])
  @@index([tournamentId, leagueId, score, entryId])
  @@map("bracket_leaderboards")
}

model BracketHealthSnapshot {
  id           String   @id @default(uuid())
  tournamentId String
  leagueId     String
  entryId      String
  healthScore  Int
  statusLabel  String
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@unique([tournamentId, leagueId, entryId])
  @@index([leagueId, entryId])
  @@map("bracket_health_snapshots")
}

model BracketPick {
  id             String    @id @default(uuid())
  entryId        String
  nodeId         String
  pickedTeamName String?
  lockedAt       DateTime?
  points         Int       @default(0)
  isCorrect      Boolean?

  entry BracketEntry @relation("EntryToPick", fields: [entryId], references: [id], onDelete: Cascade)
  node  BracketNode  @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  @@unique([entryId, nodeId])
  @@index([nodeId])
}

model BracketLeagueMessage {
  id        String   @id @default(uuid())
  leagueId  String
  userId    String
  message   String
  type      String   @default("text")
  replyToId String?
  imageUrl  String?
  metadata  Json?
  createdAt DateTime @default(now())

  league    BracketLeague            @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user      AppUser                  @relation("BracketLeagueMessages", fields: [userId], references: [id], onDelete: Cascade)
  replyTo   BracketLeagueMessage?    @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   BracketLeagueMessage[]   @relation("MessageReplies")
  reactions BracketMessageReaction[]

  @@index([leagueId, createdAt])
  @@index([userId])
  @@map("bracket_league_messages")
}

model BracketMessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message BracketLeagueMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    AppUser              @relation("BracketMessageReactions", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("bracket_message_reactions")
}

model BracketPayment {
  id                  String    @id @default(uuid())
  userId              String
  leagueId            String
  tournamentId        String
  paymentType         String
  stripeSessionId     String?   @unique
  stripePaymentIntent String?
  status              String    @default("pending")
  amountCents         Int
  createdAt           DateTime  @default(now())
  completedAt         DateTime?

  user       AppUser           @relation("BracketPayments", fields: [userId], references: [id], onDelete: Cascade)
  league     BracketLeague     @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  tournament BracketTournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@index([userId, leagueId, tournamentId])
  @@index([stripeSessionId])
}

model BracketFeedEvent {
  id           String   @id @default(uuid())
  tournamentId String
  leagueId     String?
  eventType    String
  headline     String
  detail       String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([tournamentId, createdAt])
  @@index([leagueId, createdAt])
  @@map("bracket_feed_events")
}

model BracketRiskProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  riskTolerance    String   @default("balanced")
  poolCount        Int      @default(1)
  poolSizeEstimate Int      @default(20)
  goal             String   @default("mincash")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user AppUser @relation("BracketRiskProfile", fields: [userId], references: [id], onDelete: Cascade)

  @@map("bracket_risk_profiles")
}

model SimulationResult {
  id              String @id @default(uuid())
  bracketId       String
  tournamentId    String
  runs            Int
  modelVersion    String
  scoringMode     String @default("EDGE")
  resultJson      Json
  createdByUserId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bracketId, tournamentId], name: "sim_bracket_tournament")
  @@index([createdByUserId])
  @@map("simulation_results")
}

model BracketChallenge {
  id                String   @id @default(uuid())
  leagueId          String
  challengerEntryId String
  challengedEntryId String
  status            String   @default("pending") // pending, accepted, declined, completed
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([leagueId, challengerEntryId, challengedEntryId])
  @@index([leagueId])
  @@map("bracket_challenges")
}

model UserFollow {
  id         String   @id @default(uuid())
  followerId String
  followeeId String
  createdAt  DateTime @default(now())

  @@unique([followerId, followeeId])
  @@index([followeeId])
  @@map("user_follows")
}

model ActivityEvent {
  id        String   @id @default(uuid())
  leagueId  String?
  entryId   String?
  userId    String?
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([leagueId, createdAt])
  @@index([userId, createdAt])
  @@map("activity_events")
}

model ReactionEvent {
  id         String   @id @default(uuid())
  leagueId   String?
  entryId    String?
  userId     String
  type       String
  targetType String
  targetId   String
  createdAt  DateTime @default(now())

  @@index([leagueId, createdAt])
  @@index([userId, createdAt])
  @@map("reaction_events")
}

model UserRivalry {
  id            String   @id @default(uuid())
  userAId       String
  userBId       String
  totalMeetings Int      @default(0)
  winsA         Int      @default(0)
  winsB         Int      @default(0)
  lastUpdatedAt DateTime @updatedAt

  @@unique([userAId, userBId])
  @@index([userBId])
  @@map("user_rivalries")
}

enum VerificationMethod {
  EMAIL
  PHONE
}

model UserProfile {
  userId             String              @id
  displayName        String?
  phone              String?             @unique
  phoneVerifiedAt    DateTime?
  emailVerifiedAt    DateTime?
  ageConfirmedAt     DateTime?
  verificationMethod VerificationMethod?
  sleeperUsername    String?
  sleeperUserId      String?             @unique
  sleeperLinkedAt    DateTime?
  sleeperVerifiedAt  DateTime?
  profileComplete    Boolean             @default(false)
  timezone           String?
  preferredLanguage  String?
  avatarPreset       String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sleeperUsername])
  @@index([phone])
  @@map("user_profiles")
}

model PendingSignup {
  email       String   @id
  displayName String?
  phone       String?
  createdAt   DateTime @default(now())

  @@map("pending_signups")
}

model EmailVerifyToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verify_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model League {
  id               String      @id @default(uuid())
  userId           String
  platform         String
  platformLeagueId String
  name             String?
  sport            LeagueSport @default(NFL)
  leagueVariant    String?     @db.VarChar(32)
  season           Int?
  leagueSize       Int?
  scoring          String?
  isDynasty        Boolean     @default(false)
  rosterSize       Int?
  starters         Json?
  status           String?
  avatarUrl        String?
  settings         Json?
  lastSyncedAt     DateTime?
  syncStatus       String?
  syncError        String?

  rosters            Roster[]
  teams              LeagueTeam[]
  waiverPickups      WaiverPickup[]
  waiverClaims       WaiverClaim[]
  waiverTransactions WaiverTransaction[]
  waiverSettings     LeagueWaiverSettings?
  mockDrafts         MockDraft[]
  user               AppUser               @relation(fields: [userId], references: [id], onDelete: Cascade)
  legacyLeague       LegacyLeague?         @relation(fields: [legacyLeagueId], references: [id])
  legacyLeagueId     String?               @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, platform, platformLeagueId])
  @@index([userId])
  @@index([userId, isDynasty])
  @@index([sport, season])
  @@index([status])
  @@map("leagues")
}

enum LeagueSport {
  NFL
  NHL
  MLB
  NBA
  NCAAF
  NCAAB
  SOCCER
}

model Roster {
  id             String   @id @default(uuid())
  leagueId       String
  league         League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  platformUserId String
  playerData     Json
  faabRemaining  Int?
  waiverPriority Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  waiverClaims       WaiverClaim[]
  waiverTransactions WaiverTransaction[]

  @@unique([leagueId, platformUserId])
  @@index([leagueId])
  @@index([platformUserId])
  @@map("rosters")
}

model LeagueTeam {
  id            String   @id @default(uuid())
  leagueId      String
  externalId    String
  ownerName     String
  teamName      String
  avatarUrl     String?
  wins          Int      @default(0)
  losses        Int      @default(0)
  ties          Int      @default(0)
  pointsFor     Float    @default(0)
  pointsAgainst Float    @default(0)
  currentRank   Int?
  aiPowerScore  Float?
  projectedWins Float?
  strengthNotes String?
  riskNotes     String?
  lastUpdatedAt DateTime @updatedAt

  league         League            @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  performances   TeamPerformance[]
  legacyRoster   LegacyRoster?     @relation(fields: [legacyRosterId], references: [id])
  legacyRosterId String?           @unique

  @@unique([leagueId, externalId])
  @@index([leagueId, pointsFor])
  @@index([aiPowerScore])
  @@map("league_teams")
}

model TeamPerformance {
  id        String   @id @default(uuid())
  teamId    String
  week      Int
  season    Int
  points    Float
  opponent  String?
  result    String?
  data      Json?
  createdAt DateTime @default(now())

  team LeagueTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, season, week])
  @@index([teamId, season])
  @@map("team_performances")
}

model LeagueAuth {
  id          String   @id @default(uuid())
  userId      String
  platform    String
  apiKey      String?  @db.Text
  oauthToken  String?  @db.Text
  oauthSecret String?  @db.Text
  espnSwid    String?
  espnS2      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
  @@map("league_auths")
}

model LeagueWaiverSettings {
  id                  String    @id @default(uuid())
  leagueId            String    @unique
  league              League    @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  waiverType          String    @default("standard")
  processingDayOfWeek Int?
  processingTimeUtc   String?
  claimLimitPerPeriod Int?
  faabBudget          Int?
  faabResetDate       DateTime?
  tiebreakRule        String?
  lockType            String?
  instantFaAfterClear Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("league_waiver_settings")
}

/// Multi-sport: roster template per sport/format (slot definitions)
model RosterTemplate {
  id         String   @id @default(cuid())
  sportType  String   @db.VarChar(12)
  name       String   @db.VarChar(64)
  formatType String   @db.VarChar(32)
  createdAt  DateTime @default(now())
  slots      RosterTemplateSlot[]

  @@unique([sportType, formatType], name: "uniq_roster_template_sport_format")
  @@index([sportType])
  @@map("roster_templates")
}

model RosterTemplateSlot {
  id              String   @id @default(cuid())
  templateId      String
  template        RosterTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  slotName        String   @db.VarChar(32)
  allowedPositions Json
  starterCount    Int      @default(0)
  benchCount      Int      @default(0)
  reserveCount    Int      @default(0)
  taxiCount       Int      @default(0)
  devyCount       Int      @default(0)
  isFlexibleSlot  Boolean  @default(false)
  slotOrder       Int      @default(0)

  @@index([templateId])
  @@map("roster_template_slots")
}

/// League-specific roster config (template + overrides)
model LeagueRosterConfig {
  id        String   @id @default(cuid())
  leagueId  String   @unique @db.VarChar(64)
  templateId String
  overrides  Json?
  createdAt DateTime @default(now())

  @@index([leagueId])
  @@map("league_roster_configs")
}

/// Multi-sport: scoring template per sport/format
model ScoringTemplate {
  id         String   @id @default(cuid())
  sportType  String   @db.VarChar(12)
  name       String   @db.VarChar(64)
  formatType String   @db.VarChar(32)
  createdAt  DateTime @default(now())
  rules      ScoringRule[]

  @@unique([sportType, formatType], name: "uniq_scoring_template_sport_format")
  @@index([sportType])
  @@map("scoring_templates")
}

model ScoringRule {
  id         String   @id @default(cuid())
  templateId String
  template   ScoringTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  statKey    String   @db.VarChar(48)
  pointsValue Float   @default(0)
  multiplier  Float   @default(1)
  enabled    Boolean  @default(true)

  @@index([templateId])
  @@index([templateId, statKey])
  @@map("scoring_rules")
}

/// League-level scoring overrides (optional)
model LeagueScoringOverride {
  id         String   @id @default(cuid())
  leagueId  String   @db.VarChar(64)
  statKey   String   @db.VarChar(48)
  pointsValue Float  @default(0)
  enabled   Boolean  @default(true)

  @@unique([leagueId, statKey], name: "uniq_league_scoring_override_league_stat")
  @@index([leagueId])
  @@map("league_scoring_overrides")
}

/// Multi-sport: scheduled games for schedule/stats pipeline
model GameSchedule {
  id           String    @id @default(cuid())
  sportType    String    @db.VarChar(12)
  season       Int
  weekOrRound  Int
  externalId   String    @db.VarChar(64)
  homeTeamId   String?   @db.VarChar(32)
  awayTeamId   String?   @db.VarChar(32)
  homeTeam     String?   @db.VarChar(16)
  awayTeam     String?   @db.VarChar(16)
  startTime    DateTime?
  status       String    @db.VarChar(24)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([sportType, season, weekOrRound, externalId], name: "uniq_game_schedule_sport_season_week_external")
  @@index([sportType, season, weekOrRound])
  @@index([sportType, season])
  @@map("game_schedules")
}

/// Multi-sport: player stats per game (normalized for fantasy calculation)
model PlayerGameStat {
  id               String   @id @default(cuid())
  playerId         String   @db.VarChar(64)
  sportType        String   @db.VarChar(12)
  gameId           String   @db.VarChar(64)
  season           Int
  weekOrRound      Int
  statPayload     Json     @map("stat_payload")
  normalizedStatMap Json    @map("normalized_stat_map")
  fantasyPoints    Float    @default(0)
  updatedAt        DateTime @updatedAt

  @@unique([playerId, sportType, gameId], name: "uniq_player_game_stat_player_sport_game")
  @@index([sportType, season, weekOrRound])
  @@index([playerId, sportType, season])
  @@map("player_game_stats")
}

/// Multi-sport: team-level game stats (optional aggregate)
model TeamGameStat {
  id           String   @id @default(cuid())
  sportType    String   @db.VarChar(12)
  gameId       String   @db.VarChar(64)
  teamId       String   @db.VarChar(32)
  season       Int
  weekOrRound  Int
  statPayload  Json     @map("stat_payload")
  updatedAt    DateTime @updatedAt

  @@unique([sportType, gameId, teamId], name: "uniq_team_game_stat_sport_game_team")
  @@index([sportType, season, weekOrRound])
  @@map("team_game_stats")
}

/// Multi-sport: stat ingestion job tracking
model StatIngestionJob {
  id          String    @id @default(cuid())
  sportType   String    @db.VarChar(12)
  season      Int
  weekOrRound Int?
  source      String    @db.VarChar(32)
  status      String    @db.VarChar(24)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  gameCount   Int       @default(0)
  statCount   Int       @default(0)
  errorMessage String?  @db.VarChar(512)

  @@index([sportType, season])
  @@index([status, startedAt])
  @@map("stat_ingestion_jobs")
}

/// Player Trend Detection Engine: platform-wide trend metrics per player/sport
model PlayerMetaTrend {
  id                String   @id @default(cuid())
  playerId          String   @db.VarChar(32)
  sport             String   @db.VarChar(12)
  trendScore        Float    @default(0)
  addRate           Float    @default(0)
  dropRate          Float    @default(0)
  tradeInterest     Float    @default(0)
  draftFrequency    Float    @default(0)
  lineupStartRate   Float    @default(0)
  injuryImpact      Float    @default(0)
  trendingDirection String   @db.VarChar(16)
  previousTrendScore Float?
  updatedAt         DateTime @updatedAt

  @@unique([playerId, sport], name: "uniq_player_meta_trend_player_sport")
  @@index([sport])
  @@index([trendScore])
  @@index([trendingDirection])
  @@index([updatedAt])
  @@map("player_meta_trends")
}

/// Raw trend signal events (waiver add/drop, trade, draft, lineup start)
model TrendSignalEvent {
  id         String   @id @default(cuid())
  playerId   String   @db.VarChar(32)
  sport      String   @db.VarChar(12)
  signalType String   @db.VarChar(24)
  value      Float    @default(1)
  leagueId   String?  @db.VarChar(64)
  timestamp  DateTime @default(now())

  @@index([playerId, sport])
  @@index([sport, signalType, timestamp])
  @@index([timestamp])
  @@map("trend_signal_events")
}

/// Strategy Meta Analyzer: platform-wide strategy usage and success rates
model StrategyMetaReport {
  id                 String   @id @default(cuid())
  strategyType       String   @db.VarChar(32)
  sport              String   @db.VarChar(12)
  usageRate          Float    @default(0)
  successRate        Float    @default(0)
  trendingDirection  String   @db.VarChar(16)
  leagueFormat       String   @db.VarChar(32)
  sampleSize         Int      @default(0)
  createdAt          DateTime @default(now())

  @@unique([strategyType, sport, leagueFormat], name: "uniq_strategy_meta_report_type_sport_format")
  @@index([sport])
  @@index([leagueFormat])
  @@map("strategy_meta_reports")
}

model WaiverClaim {
  id            String    @id @default(uuid())
  leagueId      String
  rosterId      String
  addPlayerId   String
  dropPlayerId  String?
  faabBid       Int?
  priorityOrder Int       @default(0)
  status        String    @default("pending")
  processedAt   DateTime?
  resultMessage String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  roster Roster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  @@index([leagueId, status])
  @@index([rosterId])
  @@index([leagueId, priorityOrder])
  @@map("waiver_claims")
}

model WaiverTransaction {
  id                   String   @id @default(uuid())
  leagueId             String
  rosterId             String
  claimId              String?
  addPlayerId          String
  dropPlayerId         String?
  faabSpent            Int?
  waiverPriorityBefore Int?
  processedAt          DateTime @default(now())

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  roster Roster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  @@index([leagueId, processedAt])
  @@index([rosterId])
  @@map("waiver_transactions")
}

model WaiverPickup {
  id         String   @id @default(uuid())
  userId     String
  leagueId   String
  league     League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  playerName String
  outcome    String?
  week       Int?
  year       Int?
  createdAt  DateTime @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([leagueId])
  @@map("waiver_pickups")
}

model SleeperLeague {
  id              String    @id @default(uuid())
  sleeperLeagueId String    @unique
  userId          String
  name            String
  totalTeams      Int
  season          String
  status          String
  isDynasty       Boolean
  scoringType     String
  rosterSettings  Json
  lastSyncedAt    DateTime?
  syncStatus      String?
  syncError       String?

  rosters SleeperRoster[]
  user    AppUser         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, sleeperLeagueId])
  @@map("sleeper_leagues")
}

model SleeperRoster {
  id             String        @id @default(uuid())
  leagueId       String
  league         SleeperLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  ownerId        String
  rosterId       String
  players        Json
  starters       Json
  bench          Json
  faabRemaining  Int?
  waiverPriority Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leagueId, rosterId])
  @@index([leagueId])
  @@index([ownerId])
  @@map("sleeper_rosters")
}

model RookieRanking {
  id           String   @id @default(cuid())
  year         Int
  name         String
  position     String
  team         String?
  rank         Int
  dynastyValue Int?
  college      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([year, name])
  @@index([year])
  @@index([position])
}

model MockDraft {
  id        String   @id @default(uuid())
  shareId   String?  @unique
  leagueId  String?
  league    League?  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  userId    String
  user      AppUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  rounds    Int      @default(15)
  results   Json
  proposals Json?
  metadata  Json? // sport, leagueType, draftType, numTeams, scoring, timerSeconds, aiEnabled
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leagueId])
  @@index([userId])
  @@map("mock_drafts")
}

model RankingsBacktestResult {
  id            String   @id @default(cuid())
  leagueId      String
  season        String   @db.VarChar(8)
  weekEvaluated Int
  targetType    String   @db.VarChar(32)
  horizonWeeks  Int      @default(3)
  segmentKey    String   @db.VarChar(32)
  nTeams        Int
  brier         Float
  ece           Float
  ndcg          Float
  spearman      Float
  payloadJson   Json?
  createdAt     DateTime @default(now())

  @@unique([leagueId, season, weekEvaluated, targetType], name: "uniq_backtest_league_week_target")
  @@index([leagueId, season])
  @@index([segmentKey])
  @@index([createdAt])
  @@map("rankings_backtest_results")
}

model DraftPredictionSnapshot {
  id           String   @id @default(uuid())
  leagueId     String
  userId       String
  season       Int
  draftId      String?
  rounds       Int      @default(2)
  simulations  Int      @default(250)
  scenarios    Json     @default("[]")
  snapshotJson Json
  createdAt    DateTime @default(now())

  retrospectives DraftRetrospective[]

  @@index([leagueId, season])
  @@index([userId, createdAt])
  @@map("draft_prediction_snapshots")
}

model DraftRetrospective {
  id                   String   @id @default(uuid())
  leagueId             String
  userId               String
  season               Int
  draftId              String
  snapshotId           String
  actualDraftJson      Json
  managerAccuracyJson  Json
  biggestMissesJson    Json
  calibrationDeltaJson Json     @default("{}")
  overallAccuracy      Float    @default(0)
  top3HitRate          Float    @default(0)
  createdAt            DateTime @default(now())

  snapshot DraftPredictionSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([leagueId, season])
  @@index([snapshotId])
  @@map("draft_retrospectives")
}

model LeagueDraftCalibration {
  id             String   @id @default(uuid())
  leagueId       String
  season         Int
  adpWeight      Float    @default(1.0)
  needWeight     Float    @default(1.0)
  tendencyWeight Float    @default(1.0)
  newsWeight     Float    @default(1.0)
  rookieWeight   Float    @default(1.0)
  sampleSize     Int      @default(0)
  lastUpdatedAt  DateTime @default(now())
  createdAt      DateTime @default(now())

  @@unique([leagueId, season])
  @@index([leagueId])
  @@map("league_draft_calibrations")
}

model ShareEngagement {
  id              String   @id @default(uuid())
  sleeperUsername String   @db.VarChar(64)
  shareType       String   @db.VarChar(32)
  platform        String   @db.VarChar(32)
  action          String   @db.VarChar(16)
  style           String?  @db.VarChar(32)
  createdAt       DateTime @default(now())

  @@index([sleeperUsername])
  @@index([sleeperUsername, shareType])
  @@index([createdAt])
  @@map("share_engagements")
}

model PlatformChatThread {
  id              String   @id @default(uuid())
  threadType      String
  productType     String   @default("shared")
  title           String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastMessageAt   DateTime @default(now())

  createdBy AppUser?                   @relation("PlatformChatThreadCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  members   PlatformChatThreadMember[]
  messages  PlatformChatMessage[]

  @@index([threadType, lastMessageAt])
  @@index([createdByUserId])
  @@map("platform_chat_threads")
}

model PlatformChatThreadMember {
  id         String    @id @default(uuid())
  threadId   String
  userId     String
  role       String    @default("member")
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?
  isMuted    Boolean   @default(false)
  isBlocked  Boolean   @default(false)

  thread PlatformChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   AppUser            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId, joinedAt])
  @@map("platform_chat_thread_members")
}

model PlatformChatMessage {
  id           String   @id @default(uuid())
  threadId     String
  senderUserId String?
  messageType  String   @default("text")
  body         String
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  thread PlatformChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender AppUser?           @relation("PlatformChatMessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([threadId, createdAt])
  @@index([senderUserId, createdAt])
  @@map("platform_chat_messages")
}

model PlatformNotification {
  id          String    @id @default(uuid())
  sourceKey   String?   @unique
  userId      String
  productType String    @default("shared")
  type        String
  title       String
  body        String?
  severity    String    @default("low")
  meta        Json?
  createdAt   DateTime  @default(now())
  readAt      DateTime?

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@map("platform_notifications")
}

model PlatformWalletAccount {
  id                  String   @id @default(uuid())
  userId              String   @unique
  currency            String   @default("USD")
  balanceCents        Int      @default(0)
  pendingBalanceCents Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user    AppUser             @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries WalletLedgerEntry[]

  @@map("platform_wallet_accounts")
}

model WalletLedgerEntry {
  id              String    @id @default(uuid())
  sourceKey       String?   @unique
  walletAccountId String
  userId          String
  entryType       String
  status          String    @default("completed")
  amountCents     Int
  description     String?
  refProduct      String?
  refId           String?
  createdAt       DateTime  @default(now())
  effectiveAt     DateTime?

  walletAccount PlatformWalletAccount @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)
  user          AppUser               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([walletAccountId, createdAt])
  @@index([userId, createdAt])
  @@index([entryType, status])
@@map("wallet_ledger_entries")
}

/// Season + Playoff Probability Engine — forecast snapshot per league/season/week
model SeasonForecastSnapshot {
  id           String   @id @default(cuid())
  leagueId     String   @db.VarChar(64)
  season       Int
  week         Int
  teamForecasts Json    // TeamSeasonForecast[]
  generatedAt  DateTime @default(now())

  @@unique([leagueId, season, week], name: "uniq_season_forecast_league_season_week")
  @@index([leagueId, season, week])
  @@map("season_forecast_snapshots")
}

/// Dynasty Projection Engine — long-term outlook snapshot per team
model DynastyProjectionSnapshot {
  id                        String   @id @default(cuid())
  leagueId                  String   @db.VarChar(64)
  teamId                    String   @db.VarChar(64)
  season                    Int
  projectedStrengthNextYear Float
  projectedStrength3Years   Float
  projectedStrength5Years   Float
  rebuildProbability        Float
  contenderProbability      Float
  windowStartYear           Int?
  windowEndYear             Int?
  volatilityScore           Float
  confidenceScore           Float
  generatedAt               DateTime @default(now())

  @@unique([leagueId, teamId, season], name: "uniq_dynasty_projection_league_team_season")
  @@index([leagueId, season])
  @@index([leagueId, teamId, season])
  @@map("dynasty_projection_snapshots")
}

/// Player Aging Curve & Career Projection — multi-year player-level projections
model PlayerCareerProjection {
  id                    String   @id @default(cuid())
  sport                 String   @db.VarChar(16)
  playerId              String
  season                Int
  projectedPointsYear1  Float
  projectedPointsYear2  Float
  projectedPointsYear3  Float
  projectedPointsYear4  Float
  projectedPointsYear5  Float
  breakoutProbability   Float
  declineProbability    Float
  volatilityScore       Float
  createdAt             DateTime @default(now())

  @@unique([sport, playerId, season], name: "uniq_player_career_projection_sport_player_season")
  @@index([sport, season])
  @@index([sport, playerId, season])
  @@map("player_career_projections")
}

/// Franchise Window Detection Engine — competitive lifecycle per team
model TeamWindowProfile {
  id                   String   @id @default(cuid())
  leagueId             String   @db.VarChar(64)
  teamId               String   @db.VarChar(64)
  season               Int
  windowStatus         String   @db.VarChar(32) // Contender, Rising, Competitive, Declining, Rebuilding, Tank Risk
  windowStartYear      Int?
  windowEndYear        Int?
  rebuildRiskScore     Float
  dynastyStrengthScore Float
  trajectoryDirection  String   @db.VarChar(16) // rising, flat, falling
  updatedAt            DateTime @updatedAt

  @@unique([leagueId, teamId, season], name: "uniq_team_window_profile_league_team_season")
  @@index([leagueId, season])
  @@index([leagueId, teamId, season])
  @@map("team_window_profiles")
}

/// League Intelligence Graph — nodes (entities)
model GraphNode {
  id        String   @id @default(cuid())
  nodeId    String   @unique
  nodeType  String   @db.VarChar(32)
  entityId  String   @db.VarChar(128)
  leagueId  String   @db.VarChar(64)
  season    Int?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([leagueId, season])
  @@index([nodeType, leagueId])
  @@index([entityId, leagueId])
  @@map("graph_nodes")
}

/// League Intelligence Graph — edges (relationships)
model GraphEdge {
  id          String   @id @default(cuid())
  edgeId      String   @unique
  fromNodeId  String
  toNodeId    String
  edgeType    String   @db.VarChar(32)
  weight      Float    @default(1)
  season      Int?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([fromNodeId])
  @@index([toNodeId])
  @@index([edgeType, season])
  @@index([fromNodeId, toNodeId, edgeType])
  @@map("graph_edges")
}

/// League Intelligence Graph — snapshot summary per league/season
model LeagueGraphSnapshot {
  id           String   @id @default(cuid())
  leagueId     String   @db.VarChar(64)
  season       Int
  graphVersion Int      @default(1)
  nodeCount    Int      @default(0)
  edgeCount    Int      @default(0)
  summary      Json?
  generatedAt  DateTime @default(now())

  @@unique([leagueId, season], name: "uniq_league_graph_snapshot_league_season")
  @@index([leagueId, season])
  @@map("league_graph_snapshots")
}

/// Dynasty historical import — maps internal league to platform league id per season (for graph/history)
model LeagueDynastySeason {
  id               String   @id @default(cuid())
  leagueId         String   @db.VarChar(64)
  season           Int
  platformLeagueId String   @db.VarChar(64)
  provider         String   @db.VarChar(32)
  importedAt       DateTime @default(now())
  metadata         Json?

  @@unique([leagueId, season], name: "uniq_league_dynasty_season_league_season")
  @@index([leagueId])
  @@index([platformLeagueId])
  @@map("league_dynasty_seasons")
}

/// Dynasty backfill progress and observability — resumable, per-league
model DynastyBackfillStatus {
  id                 String    @id @default(cuid())
  leagueId           String    @db.VarChar(64)
  provider           String    @db.VarChar(32)
  status             String    @db.VarChar(24)
  seasonsDiscovered  Json?
  seasonsImported    Json?
  seasonsSkipped     Json?
  partialSeasons    Json?
  lastStartedAt      DateTime?
  lastCompletedAt    DateTime?
  failureMessage    String?   @db.Text
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([leagueId, provider], name: "uniq_dynasty_backfill_status_league_provider")
  @@index([leagueId])
  @@index([status])
  @@map("dynasty_backfill_status")
}
