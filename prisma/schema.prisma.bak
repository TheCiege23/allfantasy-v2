  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([leagueId])
  @@index([actionType])
  @@index([severity])
  @@index([userDecision])
  @@index([createdAt])
  @@map("guardian_interventions")
}

model AIInsight {
