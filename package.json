{
  "name": "allfantasy-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "node scripts/prisma-migrate-deploy.cjs",
    "db:migrate:baseline": "powershell -ExecutionPolicy Bypass -File \"scripts/baseline-migrations.ps1\"",
    "db:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:core": "playwright test --grep-invert @db",
    "test:e2e:db": "playwright test --grep @db",
    "test:e2e:draft-room": "playwright test --grep @draft-room",
    "test:e2e:draft-room:chromium": "playwright test --grep @draft-room --project=chromium",
    "test:prompt2": "vitest run __tests__/sport-team-player-pool-mapping.test.ts __tests__/sport-default-roster-settings.test.ts __tests__/league-roster-validation-context.test.ts __tests__/league-creation-defaults-loader-variants.test.ts __tests__/prompt2-slot-flex-behavior.test.ts",
    "qa:legacy-smoke": "node scripts/legacy-feature-smoke-test.mjs",
    "qa:legacy-report": "node scripts/legacy-qa-report.mjs",
    "worker:simulations": "tsx scripts/start-simulation-worker.ts",
    "backfill:platform-core": "tsx scripts/backfill-platform-core.ts"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/topojson-specification": "^1.0.5",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.0",
    "canvas-confetti": "^1.9.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "fast-xml-parser": "^5.3.6",
    "framer-motion": "^12.34.2",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.9.3",
    "jspdf": "^4.1.0",
    "lucide-react": "^0.563.0",
    "next": "^14.2.15",
    "next-auth": "^4.24.13",
    "openai": "^6.17.0",
    "p-limit": "^7.2.0",
    "p-retry": "^7.1.1",
    "react": "^18.3.1",
    "react-day-picker": "^9.13.2",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.1",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.7.0",
    "resend": "^6.9.1",
    "sonner": "^2.0.7",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.4.1",
    "twilio": "^5.12.2",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/canvas-confetti": "^1.6.4",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "postcss": "^8.4.47",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  }
}
